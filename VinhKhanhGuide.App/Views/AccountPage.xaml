<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding AccountPageTitle}"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,32" Spacing="14">
            <Border BackgroundColor="#FFFFFF"
                    Padding="16"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="16">
                        <Border BackgroundColor="#E8F1FF"
                                WidthRequest="58"
                                HeightRequest="58"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="{Binding CurrentUserInitials}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#2F80FF" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                            <Label Text="{Binding CurrentUserDisplayName}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Label Text="{Binding CurrentUserStatusLine}"
                                   FontSize="15"
                                   TextColor="#486581" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border BackgroundColor="#F6FAFF"
                            Padding="14,12"
                            Stroke="#E3EEFB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding AccountStatusTitle}"
                                       FontSize="14"
                                       TextColor="#52729C" />
                                <Label Text="{Binding AccountStatusValue}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#163B6D" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="#D9E9FF"
                                    Padding="12,8"
                                    VerticalOptions="Center"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding CurrentUserPasswordLabel}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#2F80FF" />
                            </Border>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding PersonalInfoSectionTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding AccountSettingsAccessMessage}"
                               FontSize="14"
                               TextColor="#6B7C93" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#FFF1F2"
                            Padding="14,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasAccountSettingsError}">
                        <Label Text="{Binding AccountSettingsErrorMessage}"
                               FontSize="14"
                               TextColor="#BE123C" />
                    </Border>

                    <Border BackgroundColor="#ECFDF3"
                            Padding="14,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasAccountSettingsSuccess}">
                        <Label Text="{Binding AccountSettingsSuccessMessage}"
                               FontSize="14"
                               TextColor="#166534" />
                    </Border>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding FullNameLabel}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#163B6D" />
                        <Border BackgroundColor="#F4F8FF"
                                Padding="14,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Entry Text="{Binding AccountProfileFullName}"
                                   Placeholder="{Binding FullNamePlaceholder}"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding EmailLabel}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#163B6D" />
                        <Border BackgroundColor="#F4F8FF"
                                Padding="14,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Entry Text="{Binding AccountProfileEmail}"
                                   Placeholder="{Binding EmailPlaceholder}"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding PhoneLabel}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#163B6D" />
                        <Border BackgroundColor="#F4F8FF"
                                Padding="14,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Entry Text="{Binding AccountProfilePhoneNumber}"
                                   Placeholder="{Binding PhonePlaceholder}"
                                   Keyboard="Telephone"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD" />
                        </Border>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsSavingAccountProfile}"
                                       IsVisible="{Binding IsSavingAccountProfile}"
                                       Color="#2F80FF" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Text="{Binding SaveProfileButtonText}"
                                Command="{Binding SaveAccountProfileCommand}"
                                IsEnabled="{Binding CanSaveAccountProfile}"
                                BackgroundColor="#2F80FF"
                                TextColor="White"
                                FontSize="16"
                                CornerRadius="18" />

                        <Button Grid.Column="1"
                                Text="{Binding ResetButtonText}"
                                Command="{Binding ResetAccountProfileCommand}"
                                BackgroundColor="#E8F1FF"
                                TextColor="#2F80FF"
                                FontSize="16"
                                CornerRadius="18" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding LanguageSectionTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding LanguageSectionSummary}"
                               FontSize="14"
                               TextColor="#6B7C93" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#F4F8FF"
                            Padding="14,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12">
                        <Picker Title="{Binding LanguagePickerTitle}"
                                ItemsSource="{Binding SupportedLanguages}"
                                ItemDisplayBinding="{Binding DisplayLabel}"
                                SelectedItem="{Binding DraftSelectedLanguageOption}" />
                    </Border>

                    <Label Text="{Binding DraftSelectedLanguageDisplayLabel}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#163B6D" />

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding PlaybackModePickerTitle}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#163B6D" />
                        <Border BackgroundColor="#F4F8FF"
                                Padding="14,6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Picker Title="{Binding PlaybackModePickerTitle}"
                                    ItemsSource="{Binding SupportedPlaybackModes}"
                                    ItemDisplayBinding="{Binding Label}"
                                    SelectedItem="{Binding DraftSelectedPlaybackModeOption}" />
                        </Border>
                        <Label Text="{Binding DraftPlaybackModeDescription}"
                               FontSize="13"
                               TextColor="#6B7C93"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#F4F8FF"
                            Padding="14"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding AutoNarrationLabel}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#163B6D" />
                                <Label Text="{Binding DraftAudioSettingsSummary}"
                                       FontSize="13"
                                       TextColor="#6B7C93" />
                            </VerticalStackLayout>

                            <Switch Grid.Column="1"
                                    IsToggled="{Binding DraftIsAutoNarrationEnabled}"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFF1F2"
                            Padding="14,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasAudioSettingsError}">
                        <Label Text="{Binding AudioSettingsErrorMessage}"
                               FontSize="14"
                               TextColor="#BE123C" />
                    </Border>

                    <Border BackgroundColor="#ECFDF3"
                            Padding="14,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasAudioSettingsSuccess}">
                        <Label Text="{Binding AudioSettingsSuccessMessage}"
                               FontSize="14"
                               TextColor="#166534" />
                    </Border>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Text="{Binding PreviewAudioButtonText}"
                                Command="{Binding PreviewAudioSettingsCommand}"
                                IsEnabled="{Binding CanPreviewAudioSettings}"
                                BackgroundColor="#E8F1FF"
                                TextColor="#2F80FF"
                                FontSize="16"
                                CornerRadius="18" />

                        <Button Grid.Column="1"
                                Text="{Binding SaveLanguageButtonText}"
                                Command="{Binding SaveAudioSettingsCommand}"
                                IsEnabled="{Binding CanSaveAudioSettings}"
                                BackgroundColor="#2F80FF"
                                TextColor="White"
                                FontSize="16"
                                CornerRadius="18" />
                    </Grid>

                    <Button Text="{Binding RestoreButtonText}"
                            Command="{Binding ResetAudioSettingsCommand}"
                            IsEnabled="{Binding CanResetAudioSettings}"
                            BackgroundColor="#F4F8FF"
                            TextColor="#2F80FF"
                            FontSize="16"
                            CornerRadius="18" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding ListeningHistorySectionTitle}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Label Text="{Binding ListeningHistorySummary}"
                                   FontSize="14"
                                   TextColor="#6B7C93" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="{Binding RefreshButtonText}"
                                Command="{Binding RefreshListeningHistoryCommand}"
                                BackgroundColor="#E8F1FF"
                                TextColor="#2F80FF"
                                FontSize="15"
                                CornerRadius="16"
                                Padding="14,8" />
                    </Grid>

                    <Label Text="{Binding ListeningHistorySyncStatus}"
                           FontSize="13"
                           TextColor="#7B8BA3" />

                    <ActivityIndicator IsRunning="{Binding IsListeningHistoryLoading}"
                                       IsVisible="{Binding IsListeningHistoryLoading}"
                                       Color="#2F80FF" />

                    <Border BackgroundColor="#FFF1F2"
                            Padding="14,12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasListeningHistoryLoadError}">
                        <Label Text="{Binding ListeningHistoryLoadError}"
                               FontSize="14"
                               TextColor="#BE123C" />
                    </Border>

                    <Border BackgroundColor="#F4F8FF"
                            Padding="16"
                            Stroke="#D9E6F7"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            IsVisible="{Binding IsListeningHistoryDisplayEmpty}">
                        <Label Text="{Binding ListeningHistoryEmptyStateText}"
                               FontSize="15"
                               TextColor="#5E7491"
                               LineBreakMode="WordWrap" />
                    </Border>

                    <Border BackgroundColor="#F8FBFF"
                            Padding="16"
                            Stroke="#D9E6F7"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            IsVisible="{Binding IsListeningHistoryFallbackVisible}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding ListeningHistoryFallbackSummary}"
                                   FontSize="14"
                                   TextColor="#5E7491" />

                            <VerticalStackLayout Spacing="8"
                                                 BindableLayout.ItemsSource="{Binding ListeningHistoryLocalEntries}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}"
                                               FontSize="14"
                                               TextColor="#102A43"
                                               LineBreakMode="WordWrap" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding ListeningHistory}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#F8FBFF"
                                        Padding="14"
                                        Stroke="#D9E6F7"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnListeningHistoryItemTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <Border BackgroundColor="#D9E9FF"
                                                WidthRequest="42"
                                                HeightRequest="42"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 21">
                                            <Image Source="play_icon.svg"
                                                   HeightRequest="18"
                                                   WidthRequest="18"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Aspect="AspectFit" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding PoiName}"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="#102A43"
                                                       LineBreakMode="TailTruncation" />
                                                <Border Grid.Column="1"
                                                        BackgroundColor="#E8F1FF"
                                                        Padding="8,4"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12">
                                                    <Label Text="{Binding StartedAtShortLabel}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#2F80FF" />
                                                </Border>
                                            </Grid>

                                            <Label Text="{Binding DetailSummaryLabel}"
                                                   FontSize="13"
                                                   TextColor="#486581"
                                                   LineBreakMode="TailTruncation" />

                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding StartedAtLabel}"
                                                       FontSize="13"
                                                       TextColor="#6B7C93"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding StatusLabel}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding StatusAccentColor}" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
