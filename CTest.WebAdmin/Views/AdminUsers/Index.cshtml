@using CTest.WebAdmin.Services
@using VinhKhanhGuide.Core.Contracts
@inject WebDisplayClock DisplayClock
@model AdminUsersPageViewModel
@{
    ViewData["Title"] = "Người dùng app";

    string FormatTime(DateTimeOffset? value)
    {
        return value.HasValue
            ? DisplayClock.ToDisplayTime(value.Value).ToString("dd/MM/yyyy HH:mm")
            : "Chưa có";
    }

    string FormatDuration(int seconds)
    {
        if (seconds <= 0)
        {
            return "0 giây";
        }

        var time = TimeSpan.FromSeconds(seconds);
        return time.TotalHours >= 1
            ? $"{(int)time.TotalHours} giờ {time.Minutes} phút"
            : $"{time.Minutes} phút {time.Seconds} giây";
    }

    string StatusLabel(AdminUserSummaryDto user) => user.IsOnline ? "Online" : "Offline";
    string StatusClass(AdminUserSummaryDto user) => user.IsOnline ? "user-status is-online" : "user-status";
}

<style>
    .users-page {
        color: #0f172a;
    }

    .users-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .users-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.4rem);
        font-weight: 800;
    }

    .users-head p,
    .users-muted {
        color: #64748b;
    }

    .users-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
        margin-bottom: 1rem;
    }

    .users-stat,
    .users-panel,
    .user-card,
    .user-detail-card {
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
    }

    .users-stat {
        padding: 1rem;
    }

    .users-stat-label {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .users-stat-value {
        margin-top: 0.35rem;
        font-size: 1.65rem;
        font-weight: 800;
    }

    .users-filter {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) 180px auto auto;
        gap: 0.75rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .users-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 1rem;
    }

    .users-list {
        display: grid;
        gap: 0.75rem;
        padding: 1rem;
    }

    .user-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        padding: 1rem;
        color: inherit;
        text-decoration: none;
    }

    .user-card.is-selected {
        border-color: rgba(37, 99, 235, 0.38);
        background: #eff6ff;
    }

    .user-name {
        font-weight: 800;
        font-size: 1.05rem;
    }

    .user-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem 0.8rem;
        margin-top: 0.45rem;
        color: #64748b;
        font-size: 0.9rem;
    }

    .user-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 84px;
        height: 32px;
        border-radius: 8px;
        background: #f1f5f9;
        color: #475569;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .user-status.is-online {
        background: #dcfce7;
        color: #166534;
    }

    .user-detail-card {
        padding: 1rem;
        position: sticky;
        top: 1rem;
    }

    .user-detail-title {
        font-size: 1.15rem;
        font-weight: 800;
    }

    .user-detail-grid {
        display: grid;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .user-detail-row {
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    }

    .user-detail-label {
        color: #64748b;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .user-detail-value {
        margin-top: 0.25rem;
        font-weight: 700;
    }

    .users-empty {
        padding: 2rem;
        color: #64748b;
        text-align: center;
    }

    @@media (max-width: 1199.98px) {
        .users-layout,
        .users-stats,
        .users-filter {
            grid-template-columns: 1fr;
        }

        .user-detail-card {
            position: static;
        }
    }
</style>

<div class="users-page">
    <div class="users-head">
        <div>
            <h1>Người dùng app</h1>
            <p>Theo dõi tài khoản app, trạng thái online, lịch sử nghe và POI gần nhất từ VKFoodAPI.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning">@Model.LoadErrorMessage</div>
    }

    <div class="users-stats">
        <div class="users-stat">
            <div class="users-stat-label">Tổng người dùng</div>
            <div class="users-stat-value">@Model.TotalUsers</div>
        </div>
        <div class="users-stat">
            <div class="users-stat-label">Đang online</div>
            <div class="users-stat-value">@Model.OnlineUsers</div>
        </div>
        <div class="users-stat">
            <div class="users-stat-label">Offline</div>
            <div class="users-stat-value">@Model.OfflineUsers</div>
        </div>
        <div class="users-stat">
            <div class="users-stat-label">Tổng phiên nghe</div>
            <div class="users-stat-value">@Model.TotalSessions</div>
        </div>
    </div>

    <form asp-action="Index" method="get" class="users-panel users-filter">
        <input class="form-control" name="keyword" value="@Model.SearchTerm" placeholder="Tên, email, mã người dùng, POI gần nhất..." />
        <select class="form-select" name="status">
            <option value="all" selected="@(Model.StatusFilter == "all" ? "selected" : null)">Tất cả trạng thái</option>
            <option value="online" selected="@(Model.StatusFilter == "online" ? "selected" : null)">Online</option>
            <option value="offline" selected="@(Model.StatusFilter == "offline" ? "selected" : null)">Offline</option>
        </select>
        <button class="btn btn-primary px-4" type="submit">Lọc</button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">Đặt lại</a>
    </form>

    <div class="users-layout">
        <div class="users-panel">
            @if (Model.Users.Count == 0)
            {
                <div class="users-empty">Chưa có người dùng phù hợp.</div>
            }
            else
            {
                <div class="users-list">
                    @foreach (var user in Model.Users)
                    {
                        <a asp-action="Index"
                           asp-route-keyword="@Model.SearchTerm"
                           asp-route-status="@Model.StatusFilter"
                           asp-route-userId="@user.Id"
                           class="user-card @(Model.SelectedUserId == user.Id ? "is-selected" : null)">
                            <div>
                                <div class="user-name">@user.DisplayName</div>
                                <div class="user-meta">
                                    <span>@(string.IsNullOrWhiteSpace(user.UserCode) ? "Chưa có mã" : user.UserCode)</span>
                                    <span>@(string.IsNullOrWhiteSpace(user.Email) ? "Chưa có email" : user.Email)</span>
                                    <span>@(string.IsNullOrWhiteSpace(user.DevicePlatform) ? "Chưa rõ thiết bị" : user.DevicePlatform)</span>
                                </div>
                                <div class="user-meta">
                                    <span>POI gần nhất: @(string.IsNullOrWhiteSpace(user.LastPoiName) ? "Chưa có" : user.LastPoiName)</span>
                                    <span>@user.TotalSessions phiên</span>
                                    <span>@FormatDuration(user.TotalListenSeconds)</span>
                                </div>
                            </div>
                            <div class="text-end">
                                <span class="@StatusClass(user)">@StatusLabel(user)</span>
                                <div class="users-muted small mt-2">@FormatTime(user.LastActiveAtUtc)</div>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <aside class="user-detail-card">
            @if (Model.SelectedUser is null)
            {
                <div class="users-empty px-0">Chọn một người dùng để xem chi tiết.</div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                        <div class="user-detail-title">@Model.SelectedUser.DisplayName</div>
                        <div class="users-muted">@Model.SelectedUser.UserCode</div>
                    </div>
                    <span class="@(Model.SelectedUser.IsOnline ? "user-status is-online" : "user-status")">
                        @(Model.SelectedUser.IsOnline ? "Online" : "Offline")
                    </span>
                </div>

                <div class="user-detail-grid">
                    <div class="user-detail-row">
                        <div class="user-detail-label">Email</div>
                        <div class="user-detail-value">@(string.IsNullOrWhiteSpace(Model.SelectedUser.Email) ? "Chưa có" : Model.SelectedUser.Email)</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Vai trò</div>
                        <div class="user-detail-value">@Model.SelectedUser.Role</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Ngôn ngữ</div>
                        <div class="user-detail-value">@Model.SelectedUser.PreferredLanguage</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Thiết bị</div>
                        <div class="user-detail-value">@(string.IsNullOrWhiteSpace(Model.SelectedUser.DevicePlatform) ? "Chưa rõ" : Model.SelectedUser.DevicePlatform)</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Hoạt động cuối</div>
                        <div class="user-detail-value">@FormatTime(Model.SelectedUser.LastActiveAtUtc)</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">POI gần nhất</div>
                        <div class="user-detail-value">@(string.IsNullOrWhiteSpace(Model.SelectedUser.LastPoiName) ? "Chưa có" : Model.SelectedUser.LastPoiName)</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Phiên nghe</div>
                        <div class="user-detail-value">@Model.SelectedUser.CompletedSessions / @Model.SelectedUser.TotalSessions hoàn tất</div>
                    </div>
                    <div class="user-detail-row">
                        <div class="user-detail-label">Tổng thời lượng</div>
                        <div class="user-detail-value">@FormatDuration(Model.SelectedUser.TotalListenSeconds)</div>
                    </div>
                </div>

                @if (Model.SelectedLocation is not null)
                {
                    <div class="mt-3">
                        <a href="@Model.SelectedLocation.MapLink" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary w-100">
                            Mở vị trí POI gần nhất
                        </a>
                    </div>
                }
            }
        </aside>
    </div>
</div>
