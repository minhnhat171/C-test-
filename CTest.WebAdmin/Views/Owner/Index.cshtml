@model OwnerPortalViewModel
@{
    ViewData["Title"] = "Chủ nhà hàng";
    var ownerPoiCount = Model.Pois.Items.Count;
    var activeOwnerPoiCount = Model.Pois.Items.Count(item => item.IsActive);
    var pendingOwnerPoiCount = Model.Pois.Items.Count(item => item.IsPendingApproval);
}

<style>
    .owner-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
        gap: 1rem;
    }

    .owner-overview {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.85rem;
        margin-bottom: 1rem;
    }

    .owner-panel {
        padding: 1.2rem;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 18px 46px rgba(15, 23, 42, 0.08);
    }

    .owner-poi-table {
        max-height: 360px;
        overflow: auto;
    }

    .owner-image-dropzone {
        border: 1px dashed rgba(37, 99, 235, 0.42);
        border-radius: 8px;
        background: #f8fafc;
        padding: 1rem;
        cursor: pointer;
    }

    .owner-image-dropzone.is-dragover {
        border-color: #2563eb;
        background: #eff6ff;
    }

    .owner-image-preview {
        display: none;
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 0.85rem;
        background: #e2e8f0;
    }

    .owner-image-preview.has-image {
        display: block;
    }

    .owner-steps {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .owner-step {
        padding: 0.9rem 1rem;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 8px;
        background: #fff;
    }

    .owner-step-number {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        margin-bottom: 0.55rem;
        border-radius: 999px;
        background: #2563eb;
        color: #fff;
        font-weight: 800;
        font-size: 0.82rem;
    }

    .owner-stat {
        padding: 1rem;
        border: 1px solid rgba(37, 99, 235, 0.14);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .owner-stat-label {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .owner-stat-value {
        margin-top: 0.45rem;
        color: #0f172a;
        font-size: 1.8rem;
        font-weight: 850;
        line-height: 1;
    }

    @@media (max-width: 1199.98px) {
        .owner-grid {
            grid-template-columns: 1fr;
        }

        .owner-steps {
            grid-template-columns: 1fr;
        }

        .owner-overview {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Khu vực chủ nhà hàng</h1>
    </div>
    <div class="badge text-bg-light px-3 py-2">@Model.OwnerDisplayName</div>
</div>

@if (TempData["OwnerMessage"] is string ownerMessage)
{
    <div class="alert alert-success">@ownerMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Pois.LoadErrorMessage))
{
    <div class="alert alert-warning">@Model.Pois.LoadErrorMessage</div>
}

<div class="owner-overview">
    <div class="owner-stat">
        <div class="owner-stat-label">POI của tôi</div>
        <div class="owner-stat-value">@ownerPoiCount</div>
    </div>
    <div class="owner-stat">
        <div class="owner-stat-label">Đang hoạt động</div>
        <div class="owner-stat-value">@activeOwnerPoiCount</div>
    </div>
    <div class="owner-stat">
        <div class="owner-stat-label">Chờ duyệt</div>
        <div class="owner-stat-value">@pendingOwnerPoiCount</div>
    </div>
</div>

<div class="owner-grid mb-4">
    <section class="owner-panel">
        <h2 class="h4 mb-3">Đăng ký POI</h2>
        <form asp-controller="Owner" asp-action="Register" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Registration.OwnerUserCode" type="hidden" />
            <input asp-for="Registration.OwnerDisplayName" type="hidden" />
            <input asp-for="Registration.OwnerEmail" type="hidden" />
            <input asp-for="Registration.ImageSource" type="hidden" id="ownerImageSource" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Registration.Name" class="form-label">Tên quán</label>
                    <input asp-for="Registration.Name" class="form-control" />
                    <span asp-validation-for="Registration.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Code" class="form-label">Mã POI</label>
                    <input asp-for="Registration.Code" class="form-control" placeholder="VD: VK-FOOD-NEW" />
                    <div id="ownerCodeWarning" class="text-danger small mt-1 d-none">Mã POI này đã tồn tại. Hãy chọn mã khác.</div>
                    <span asp-validation-for="Registration.Code" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Category" class="form-label">Danh mục</label>
                    <input asp-for="Registration.Category" class="form-control" />
                </div>
                <div class="col-12">
                        <label asp-for="Registration.Address" class="form-label">Địa chỉ</label>
                    <input asp-for="Registration.Address" class="form-control" />
                    <span asp-validation-for="Registration.Address" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Latitude" class="form-label">Vĩ độ</label>
                    <input asp-for="Registration.Latitude" class="form-control" min="-90" max="90" step="0.000001" />
                    <span asp-validation-for="Registration.Latitude" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Longitude" class="form-label">Kinh độ</label>
                    <input asp-for="Registration.Longitude" class="form-control" min="-180" max="180" step="0.000001" />
                    <span asp-validation-for="Registration.Longitude" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.RadiusInMeters" class="form-label">Bán kính kích hoạt</label>
                    <input asp-for="Registration.RadiusInMeters" class="form-control" />
                    <span asp-validation-for="Registration.RadiusInMeters" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Priority" class="form-label">Ưu tiên</label>
                    <input asp-for="Registration.Priority" class="form-control" />
                    <span asp-validation-for="Registration.Priority" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.SpecialDish" class="form-label">Món nổi bật</label>
                    <input asp-for="Registration.SpecialDish" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Registration.UploadedImage" class="form-label">Ảnh quán</label>
                    <div class="owner-image-dropzone" id="ownerImageDropzone">
                        <img id="ownerImagePreview" class="owner-image-preview" alt="Xem trước ảnh quán" />
                        <div class="fw-semibold">Kéo ảnh vào đây hoặc bấm để chọn</div>
                        <div class="text-muted small mt-1">Hỗ trợ JPG, PNG, WEBP. Tối đa 5 MB.</div>
                        <input asp-for="Registration.UploadedImage" type="file" class="visually-hidden" id="ownerImageFile" accept="image/*" />
                    </div>
                    <span asp-validation-for="Registration.UploadedImage" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Registration.Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Registration.Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.NarrationScript" class="form-label">Nội dung thuyết minh</label>
                    <textarea asp-for="Registration.NarrationScript" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Registration.NarrationScript" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-3">Gửi đăng ký POI</button>
        </form>
    </section>

    <section class="owner-panel">
        <h2 class="h4 mb-3">POI của bạn</h2>
        <div class="owner-poi-table table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên quán</th>
                        <th>Trạng thái</th>
                        <th>Địa chỉ</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Pois.Items.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-muted text-center py-4">Bạn chưa đăng ký POI nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var poi in Model.Pois.Items)
                    {
                        <tr>
                            <td>@poi.Code</td>
                            <td class="fw-semibold">@poi.Name</td>
                            <td>@poi.ApprovalStatusLabel</td>
                            <td>@poi.Address</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

<section class="owner-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1">Lịch sử nghe của quán</h2>
        </div>
        <div class="small text-muted" id="owner-refresh-status">Tự động cập nhật mỗi 8 giây</div>
    </div>

    <form id="owner-history-filter-form" asp-controller="Owner" asp-action="Index" method="get" class="row g-3 align-items-end mb-3">
        <div class="col-lg-5">
            <label class="form-label" for="keyword">Tìm lịch sử</label>
            <input class="form-control" id="keyword" name="keyword" value="@Model.ListeningHistory.SearchTerm" placeholder="Tên POI, mã POI, ngôn ngữ..." />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="period">Mốc thời gian</label>
            <select class="form-select" id="period" name="period">
                <option value="all" selected="@(Model.ListeningHistory.SelectedPeriod == "all" ? "selected" : null)">Tất cả</option>
                <option value="day" selected="@(Model.ListeningHistory.SelectedPeriod == "day" ? "selected" : null)">24 giờ qua</option>
                <option value="week" selected="@(Model.ListeningHistory.SelectedPeriod == "week" ? "selected" : null)">7 ngày qua</option>
                <option value="month" selected="@(Model.ListeningHistory.SelectedPeriod == "month" ? "selected" : null)">30 ngày qua</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label" for="sortBy">Sắp xếp</label>
            <select class="form-select" id="sortBy" name="sortBy">
                <option value="time_desc" selected="@(Model.ListeningHistory.SelectedSortBy == "time_desc" ? "selected" : null)">Mới nhất trước</option>
                <option value="time_asc" selected="@(Model.ListeningHistory.SelectedSortBy == "time_asc" ? "selected" : null)">Cũ nhất trước</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-dark w-100">Lọc</button>
        </div>
    </form>

    <div id="owner-history-content">
        <partial name="~/Views/UsageLogs/_UsageHistoryContent.cshtml" model="Model.ListeningHistory" />
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const imageDropzone = document.getElementById("ownerImageDropzone");
            const imageInput = document.getElementById("ownerImageFile");
            const imagePreview = document.getElementById("ownerImagePreview");
            const container = document.getElementById("owner-history-content");
            const refreshStatus = document.getElementById("owner-refresh-status");
            const existingCodes = new Set(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Pois.Items.Select(item => item.Code.ToUpperInvariant()))));
            const codeInput = document.getElementById("Registration_Code");
            const codeWarning = document.getElementById("ownerCodeWarning");
            const latitudeInput = document.getElementById("Registration_Latitude");
            const longitudeInput = document.getElementById("Registration_Longitude");

            const previewFile = (file) => {
                if (!file || !file.type.startsWith("image/") || !imagePreview) return;

                const reader = new FileReader();
                reader.addEventListener("load", () => {
                    imagePreview.src = reader.result;
                    imagePreview.classList.add("has-image");
                });
                reader.readAsDataURL(file);
            };

            imageDropzone?.addEventListener("click", () => imageInput?.click());
            imageDropzone?.addEventListener("dragover", (event) => {
                event.preventDefault();
                imageDropzone.classList.add("is-dragover");
            });
            imageDropzone?.addEventListener("dragleave", () => {
                imageDropzone.classList.remove("is-dragover");
            });
            imageDropzone?.addEventListener("drop", (event) => {
                event.preventDefault();
                imageDropzone.classList.remove("is-dragover");

                const file = event.dataTransfer?.files?.[0];
                if (!file || !imageInput) return;

                const files = new DataTransfer();
                files.items.add(file);
                imageInput.files = files.files;
                previewFile(file);
            });
            imageInput?.addEventListener("change", () => {
                previewFile(imageInput.files?.[0]);
            });

            const validateCode = () => {
                if (!codeInput || !codeWarning) return;
                const value = codeInput.value.trim().toUpperCase();
                const duplicated = value.length > 0 && existingCodes.has(value);
                codeWarning.classList.toggle("d-none", !duplicated);
                codeInput.setCustomValidity(duplicated ? "Mã POI này đã tồn tại." : "");
            };

            const validateCoordinate = (input, min, max, label) => {
                if (!input) return;
                const value = Number(input.value);
                const invalid = input.value.trim().length > 0 && (!Number.isFinite(value) || value < min || value > max);
                input.setCustomValidity(invalid ? `${label} phải nằm trong khoảng ${min} đến ${max}.` : "");
            };

            codeInput?.addEventListener("input", validateCode);
            latitudeInput?.addEventListener("input", () => validateCoordinate(latitudeInput, -90, 90, "Vĩ độ"));
            longitudeInput?.addEventListener("input", () => validateCoordinate(longitudeInput, -180, 180, "Kinh độ"));
            validateCode();
            validateCoordinate(latitudeInput, -90, 90, "Vĩ độ");
            validateCoordinate(longitudeInput, -180, 180, "Kinh độ");

            if (!container) {
                return;
            }

            async function refreshSnapshot() {
                const url = new URL(window.location.href);
                url.searchParams.set("partial", "true");

                try {
                    const response = await fetch(url.toString(), {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    container.innerHTML = await response.text();
                    if (refreshStatus) {
                        refreshStatus.textContent = `Tự động cập nhật lúc ${new Date().toLocaleTimeString("vi-VN")}`;
                    }
                } catch {
                    if (refreshStatus) {
                        refreshStatus.textContent = "Đang chờ dữ liệu mới từ API...";
                    }
                }
            }

            const timerId = window.setInterval(refreshSnapshot, 8000);
            window.addEventListener("beforeunload", () => window.clearInterval(timerId), { once: true });
        })();
    </script>
}
