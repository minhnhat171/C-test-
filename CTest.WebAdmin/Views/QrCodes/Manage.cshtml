@model QrManagementViewModel
@{
    ViewData["Title"] = "Quản lý QR";
}

<style>
    .qr-page {
        --qr-ink: #0f172a;
        --qr-muted: #64748b;
        --qr-panel: rgba(255,255,255,0.96);
        --qr-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        color: var(--qr-ink);
    }

    .qr-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .qr-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .qr-head p {
        margin: 0.45rem 0 0;
        color: var(--qr-muted);
        max-width: 760px;
    }

    .qr-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) 420px;
        gap: 1.2rem;
    }

    .qr-panel {
        background: var(--qr-panel);
        border-radius: 8px;
        box-shadow: var(--qr-shadow);
        overflow: hidden;
    }

    .qr-table {
        margin-bottom: 0;
        --bs-table-bg: transparent;
    }

    .qr-table thead th {
        background: rgba(248, 250, 252, 0.98);
        color: var(--qr-muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 1rem 1.1rem;
        border-bottom-width: 0;
    }

    .qr-table tbody td {
        padding: 1rem 1.1rem;
        border-color: rgba(148, 163, 184, 0.12);
        vertical-align: middle;
    }

    .qr-kind {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.28rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: #e0f2fe;
        color: #0c4a6e;
    }

    .qr-kind-tour {
        background: #fef3c7;
        color: #92400e;
    }

    .qr-status {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.38rem 0.8rem;
        font-size: 0.84rem;
        font-weight: 700;
        background: #dcfce7;
        color: #166534;
    }

    .qr-preview-panel {
        padding: 1.4rem;
    }

    .qr-preview-card {
        border-radius: 8px;
        padding: 1.3rem;
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    }

    .qr-preview-kicker {
        color: var(--qr-muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .qr-preview-title {
        margin-top: 0.5rem;
        font-size: 1.4rem;
        font-weight: 800;
    }

    .qr-target-summary {
        color: var(--qr-muted);
        line-height: 1.6;
        margin-top: 0.55rem;
    }

    .qr-image-wrap {
        margin: 1.1rem auto;
        width: min(100%, 280px);
        aspect-ratio: 1;
        background: white;
        border-radius: 8px;
        padding: 1rem;
        box-shadow: 0 20px 40px rgba(37, 99, 235, 0.14);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .qr-image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .qr-meta {
        color: var(--qr-muted);
        line-height: 1.6;
    }

    .qr-link-box {
        border-radius: 8px;
        background: rgba(255,255,255,0.8);
        border: 1px solid rgba(148, 163, 184, 0.18);
        padding: 0.9rem;
    }

    .qr-link-box code {
        word-break: break-all;
    }

    .qr-empty {
        padding: 1.4rem;
        color: var(--qr-muted);
    }

    @@media (max-width: 1199.98px) {
        .qr-layout {
            grid-template-columns: 1fr;
        }

        .qr-head {
            flex-direction: column;
        }
    }
</style>

<div class="qr-page">
    <div class="qr-head">
        <div>
            <h1>Quản lý QR</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
    }

    <div class="qr-layout">
        <div class="qr-panel">
            <div class="table-responsive">
                <table class="table qr-table align-middle">
                    <thead>
                        <tr>
                            <th>Đối tượng</th>
                            <th>Mã QR</th>
                            <th>Loại kích hoạt</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var kindClass = item.TargetType == QrTargetTypes.Tour ? "qr-kind qr-kind-tour" : "qr-kind";

                        <tr>
                            <td>
                                <div class="@kindClass">@item.TargetKindLabel</div>
                                <div class="fw-semibold mt-2">@item.TargetName</div>
                                @if (!string.IsNullOrWhiteSpace(item.RouteSummary))
                                {
                                    <div class="small text-muted mt-1">@item.RouteSummary</div>
                                }
                            </td>
                            <td><code>@item.TargetCode</code></td>
                            <td>
                                <div>@item.ActivationType</div>
                                @if (!string.IsNullOrWhiteSpace(item.EstimatedDurationLabel))
                                {
                                    <div class="small text-muted mt-1">@item.EstimatedDurationLabel</div>
                                }
                            </td>
                            <td><span class="qr-status">@item.Status</span></td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-action="Index"
                                       asp-route-selectedTargetType="@item.TargetType"
                                       asp-route-selectedTargetId="@item.TargetId"
                                       class="btn btn-outline-primary btn-sm rounded-pill">
                                        Chọn QR
                                    </a>
                                    <button type="button"
                                            class="btn btn-outline-success btn-sm rounded-pill js-download-qr"
                                            data-qr-url="@item.QrSvgUrl"
                                            data-filename="@($"{item.TargetType}-{item.DisplayId}".ToLowerInvariant())">
                                        Tải QR PNG
                                    </button>
                                    <button type="button" class="btn btn-outline-dark btn-sm rounded-pill" onclick="window.print()">In QR</button>
                                    <a href="@item.PublicUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary btn-sm rounded-pill">Mở thử</a>
                                    <button type="button" class="btn btn-outline-success btn-sm rounded-pill js-copy-link" data-url="@item.PublicUrl">Sao chép liên kết</button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="qr-panel">
            <div class="qr-preview-panel">
                @if (Model.SelectedItem is not null)
                {
                    var selectedKindClass = Model.SelectedItem.TargetType == QrTargetTypes.Tour ? "qr-kind qr-kind-tour" : "qr-kind";

                    <div class="qr-preview-card">
                    <div class="qr-preview-kicker">Xem trước</div>
                        <div class="@selectedKindClass mt-2">@Model.SelectedItem.TargetKindLabel</div>
                        <div class="qr-preview-title">@Model.SelectedItem.TargetName</div>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedItem.RouteSummary))
                        {
                            <div class="qr-target-summary">@Model.SelectedItem.RouteSummary</div>
                        }
                        <div class="qr-link-box mt-3">
                            <div class="small text-uppercase fw-bold text-secondary mb-2">Liên kết QR công khai</div>
                            <code>@Model.SelectedItem.PublicUrl</code>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <a href="@Model.SelectedItem.PublicUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm rounded-pill">Mở link công khai</a>
                                <button type="button" class="btn btn-outline-dark btn-sm rounded-pill js-copy-link" data-url="@Model.SelectedItem.PublicUrl">Sao chép liên kết</button>
                            </div>
                        </div>

                        <div class="qr-image-wrap">
                            <img src="@Model.SelectedItem.QrSvgUrl" alt="Mã QR" />
                        </div>

                        <div class="qr-meta">@Model.SelectedItem.Description</div>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedItem.Address))
                        {
                            <div class="qr-meta mt-2">Địa chỉ: @Model.SelectedItem.Address</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedItem.EstimatedDurationLabel))
                        {
                            <div class="qr-meta mt-2">@Model.SelectedItem.EstimatedDurationLabel</div>
                        }

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            @if (!string.IsNullOrWhiteSpace(Model.SelectedItem.DetailUrl))
                            {
                                <a href="@Model.SelectedItem.DetailUrl" class="btn btn-outline-primary rounded-pill px-4">@Model.SelectedItem.DetailActionLabel</a>
                            }
                            <button type="button"
                                    class="btn btn-success rounded-pill px-4 js-download-qr"
                                    data-qr-url="@Model.SelectedItem.QrSvgUrl"
                                    data-filename="@($"{Model.SelectedItem.TargetType}-{Model.SelectedItem.DisplayId}".ToLowerInvariant())">
                                Tải PNG
                            </button>
                            <button type="button" class="btn btn-dark rounded-pill px-4" onclick="window.print()">In QR</button>
                            <a href="@Model.SelectedItem.PublicUrl" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary rounded-pill px-4">Mở thử</a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="qr-empty">Chưa có POI hoặc tour sẵn để tạo QR.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const downloadQrAsPng = async (svgUrl, fileName) => {
                if (!svgUrl) return;

                const response = await fetch(svgUrl, { credentials: "same-origin" });
                if (!response.ok) {
                    throw new Error("QR image request failed.");
                }

                const source = await response.text();
                const image = new Image();
                const svgBlob = new Blob([source], { type: "image/svg+xml;charset=utf-8" });
                const objectUrl = URL.createObjectURL(svgBlob);

                image.onload = () => {
                    const canvas = document.createElement("canvas");
                    canvas.width = 960;
                    canvas.height = 960;
                    const ctx = canvas.getContext("2d");
                    ctx.fillStyle = "#ffffff";
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    ctx.drawImage(image, 0, 0, canvas.width, canvas.height);

                    const link = document.createElement("a");
                    link.href = canvas.toDataURL("image/png");
                    link.download = `${fileName || "qr-code"}.png`;
                    link.click();
                    URL.revokeObjectURL(objectUrl);
                };

                image.src = objectUrl;
            };

            document.querySelectorAll(".js-download-qr").forEach((button) => {
                button.addEventListener("click", async () => {
                    try {
                        await downloadQrAsPng(button.dataset.qrUrl, button.dataset.filename);
                    } catch {
                        window.alert("Không thể tải QR PNG lúc này.");
                    }
                });
            });

            document.querySelectorAll(".js-copy-link").forEach((button) => {
                button.addEventListener("click", async () => {
                    const { url } = button.dataset;
                    if (!url) return;

                    try {
                        await navigator.clipboard.writeText(url);
                        const originalText = button.textContent;
                        button.textContent = "Đã copy";
                        window.setTimeout(() => {
                            button.textContent = originalText;
                        }, 1600);
                    } catch {
                        window.prompt("Sao chép liên kết này để tạo QR:", url);
                    }
                });
            });
        })();
    </script>
}
