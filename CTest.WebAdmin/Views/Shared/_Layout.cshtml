@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"] as string ?? "Trang quản trị";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isOwner = User.IsInRole("PoiOwner");
    var displayName = User.FindFirst("vkg.display_name")?.Value ?? User.Identity?.Name ?? "Tài khoản";

    string SidebarLinkClass(string controller) =>
        string.Equals(currentController, controller, System.StringComparison.OrdinalIgnoreCase)
            ? "nav-link sidebar-link is-active"
            : "nav-link sidebar-link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Phố ẩm thực Vĩnh Khánh</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        :root {
            --app-ink: #17202a;
            --app-muted: #667085;
            --app-panel: #ffffff;
            --app-border: rgba(102, 112, 133, 0.18);
            --app-shadow: 0 12px 32px rgba(23, 32, 42, 0.08);
            --app-sidebar: #0f766e;
        }

        body {
            min-height: 100vh;
            color: var(--app-ink);
            background: #f5f7f8;
            font-family: "Be Vietnam Pro", system-ui, sans-serif;
        }

        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 300px;
            flex: 0 0 300px;
            background: var(--app-sidebar);
            color: #fff;
        }

        .sidebar-shell {
            position: sticky;
            top: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            padding: 1.2rem;
        }

        .sidebar-brand,
        .sidebar-footer {
            padding: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.10);
        }

        .sidebar-brand h1 {
            margin: 0.55rem 0 0;
            font-size: 1.45rem;
            font-weight: 800;
            line-height: 1.2;
        }

        .sidebar-kicker,
        .sidebar-section-label,
        .sidebar-footer-label {
            color: rgba(255, 255, 255, 0.72);
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .sidebar-nav {
            display: grid;
            gap: 0.45rem;
        }

        .sidebar-link {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.85rem 0.95rem;
            border-radius: 8px;
            color: rgba(255, 255, 255, 0.92) !important;
            border: 1px solid transparent;
        }

        .sidebar-link:hover {
            color: #fff !important;
            background: rgba(255, 255, 255, 0.13);
        }

        .sidebar-link.is-active {
            color: #11423e !important;
            background: #ffffff;
            border-color: rgba(255, 255, 255, 0.7);
        }

        .sidebar-link-label {
            display: block;
            font-weight: 800;
        }

        .sidebar-link-meta {
            display: block;
            margin-top: 0.15rem;
            font-size: 0.78rem;
            opacity: 0.78;
        }

        .sidebar-link-tag {
            font-weight: 800;
        }

        .sidebar-footer {
            margin-top: auto;
        }

        .content-area {
            flex: 1 1 auto;
            min-width: 0;
        }

        .content-header {
            padding: 1.35rem 1.5rem 1rem;
        }

        .content-header-shell {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.15rem;
            border: 1px solid var(--app-border);
            border-radius: 8px;
            background: var(--app-panel);
            box-shadow: var(--app-shadow);
        }

        .content-header-kicker {
            color: var(--app-muted);
            font-size: 0.76rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .content-header-title {
            margin-top: 0.3rem;
            font-size: 1.45rem;
            font-weight: 800;
        }

        .content-body {
            padding: 0 1.5rem 1.5rem;
        }

        @@media (max-width: 991.98px) {
            .app-shell {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                flex-basis: auto;
            }

            .sidebar-shell {
                min-height: auto;
            }

            .sidebar-nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .content-header-shell {
                align-items: flex-start;
                flex-direction: column;
            }
        }

        @@media (max-width: 767.98px) {
            .sidebar-nav {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-shell">
                <div class="sidebar-brand">
                    <div class="sidebar-kicker">VK Admin</div>
                    <h1>Phố ẩm thực Vĩnh Khánh</h1>
                </div>

                <div>
                    <div class="sidebar-section-label">Điều hướng</div>
                    <nav class="nav sidebar-nav mt-2">
                        @if (isAdmin)
                        {
                            <a class="@SidebarLinkClass("Home")" asp-controller="Home" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Dashboard</span>
                                    <span class="sidebar-link-meta">Tổng quan hệ thống</span>
                                </span>
                                <span class="sidebar-link-tag">01</span>
                            </a>
                            <a class="@SidebarLinkClass("Pois")" asp-controller="Pois" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Quản lý POI</span>
                                    <span class="sidebar-link-meta">Điểm nghe và geofence</span>
                                </span>
                                <span class="sidebar-link-tag">02</span>
                            </a>
                            <a class="@SidebarLinkClass("MapPois")" asp-controller="MapPois" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Map Analytics</span>
                                    <span class="sidebar-link-meta">Bản đồ, heatmap, xếp hạng</span>
                                </span>
                                <span class="sidebar-link-tag">03</span>
                            </a>
                            <a class="@SidebarLinkClass("QrCodes")" asp-controller="QrCodes" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">QR code</span>
                                    <span class="sidebar-link-meta">Điều hướng tại điểm</span>
                                </span>
                                <span class="sidebar-link-tag">04</span>
                            </a>
                            <a class="@SidebarLinkClass("Tours")" asp-controller="Tours" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Tour</span>
                                    <span class="sidebar-link-meta">Lộ trình tham quan</span>
                                </span>
                                <span class="sidebar-link-tag">05</span>
                            </a>
                            <a class="@SidebarLinkClass("UsageLogs")" asp-controller="UsageLogs" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Lịch sử nghe</span>
                                    <span class="sidebar-link-meta">GPS, QR và hàng đợi TTS</span>
                                </span>
                                <span class="sidebar-link-tag">06</span>
                            </a>
                        }
                        else if (isOwner)
                        {
                            <a class="@SidebarLinkClass("Owner")" asp-controller="Owner" asp-action="Index">
                                <span>
                                    <span class="sidebar-link-label">Chủ nhà hàng</span>
                                    <span class="sidebar-link-meta">Đăng ký POI và lịch sử nghe</span>
                                </span>
                                <span class="sidebar-link-tag">01</span>
                            </a>
                        }
                    </nav>
                </div>

                <div class="sidebar-footer">
                    <div class="sidebar-footer-label">Tài khoản</div>
                    <div class="mt-2 fw-semibold">@displayName</div>
                    @if (isAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-light btn-sm w-100">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-sm w-100 mt-3">Đăng nhập</a>
                    }
                </div>
            </div>
        </aside>

        <main class="content-area">
            <header class="content-header">
                <div class="content-header-shell">
                    <div>
                        <div class="content-header-kicker">Hệ thống quản trị</div>
                        <div class="content-header-title">@pageTitle</div>
                    </div>
                </div>
            </header>

            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
