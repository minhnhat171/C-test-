@using System.Globalization
@using System.Text.Json
@model MapPoiManagementViewModel
@{
    ViewData["Title"] = "Bản đồ Analytics";

    var analyticsByPoi = Model.TopListeningPois.ToDictionary(item => item.PoiId);
    var topPoi = Model.TopListeningPois.FirstOrDefault();
    var topPoiId = topPoi?.PoiId ?? Guid.Empty;
    var activePois = Model.Pois
        .Where(poi => poi.IsActive)
        .Where(poi =>
            poi.Latitude is >= -90 and <= 90 &&
            poi.Longitude is >= -180 and <= 180 &&
            (Math.Abs(poi.Latitude) > 0.000001 || Math.Abs(poi.Longitude) > 0.000001))
        .OrderByDescending(poi => poi.Id == topPoiId)
        .ThenByDescending(poi => analyticsByPoi.TryGetValue(poi.Id, out var analytics) ? analytics.ListenCount : 0)
        .ThenBy(poi => poi.Name)
        .ToList();

    var averageListenLabel = Model.AverageListenSeconds > 0
        ? $"{Math.Round(Model.AverageListenSeconds)}s"
        : "--";

    var latestMovementLabel = Model.LatestMovementAtUtc.HasValue
        ? Model.LatestMovementAtUtc.Value.ToLocalTime().ToString("dd/MM HH:mm", CultureInfo.InvariantCulture)
        : "--";

    var poisJson = JsonSerializer.Serialize(
        activePois.Select((poi, index) =>
        {
            analyticsByPoi.TryGetValue(poi.Id, out var poiAnalytics);

            return new
            {
                id = poi.Id,
                name = poi.Name,
                address = poi.Address,
                latitude = poi.Latitude,
                longitude = poi.Longitude,
                radiusMeters = poi.RadiusInMeters,
                priority = poi.Priority,
                listenCount = poiAnalytics?.ListenCount ?? 0,
                isTopListened = poi.Id == topPoiId,
                number = index + 1
            };
        }));

    var routesJson = JsonSerializer.Serialize(
        Model.Routes.Select(route => new
        {
            routeId = route.RouteId,
            routeLabel = route.RouteLabel,
            pointCount = route.PointCount,
            durationMinutes = route.DurationMinutes,
            approxDistanceMeters = route.ApproxDistanceMeters,
            points = route.Points.Select(point => new
            {
                latitude = point.Latitude,
                longitude = point.Longitude,
                recordedAtUtc = point.RecordedAtUtc,
                accuracyMeters = point.AccuracyMeters
            })
        }));

    var heatmapJson = JsonSerializer.Serialize(
        Model.HeatmapPoints.Select(point => new
        {
            latitude = point.Latitude,
            longitude = point.Longitude,
            count = point.Count,
            weight = point.Weight
        }));
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/map-analytics.css" asp-append-version="true" />

<section class="map-ops-header">
    <div>
        <p class="section-kicker mb-1">Map Analytics</p>
        <h2>Bản đồ vận hành POI</h2>
    </div>
    <div class="page-actions">
        <a asp-controller="UsageLogs" asp-action="Index" class="btn btn-outline-secondary">Lịch sử nghe</a>
        <a asp-controller="QrCodes" asp-action="Index" class="btn btn-outline-secondary">QR</a>
        <a asp-controller="Pois" asp-action="Index" class="btn btn-primary">Danh sách POI</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.AnalyticsLoadErrorMessage))
{
    <div class="alert alert-info border-0 shadow-sm">@Model.AnalyticsLoadErrorMessage</div>
}

<section class="map-kpi-strip" aria-label="Chỉ số bản đồ">
    <article>
        <span>POI hoạt động</span>
        <strong>@activePois.Count</strong>
    </article>
    <article>
        <span>Thiết bị có tuyến</span>
        <strong>@Model.AnonymousRouteCount</strong>
    </article>
    <article>
        <span>Điểm heatmap</span>
        <strong>@Model.HeatmapPoints.Count</strong>
    </article>
    <article>
        <span>TB nghe / POI</span>
        <strong>@averageListenLabel</strong>
    </article>
</section>

<section class="map-workspace">
    <article class="map-panel">
        <div class="map-panel__header">
            <div>
                <h2>Bản đồ TP.HCM</h2>
            </div>
            <div class="map-panel__badges">
                <span class="map-badge map-badge--poi">POI @activePois.Count</span>
                <span class="map-badge map-badge--route">Tuyến @Model.Routes.Count</span>
                <span class="map-badge map-badge--heat">Heatmap @Model.HeatmapPoints.Count</span>
            </div>
        </div>

        @if (!Model.HasMapData)
        {
            <div class="empty-state">
                <p>Chưa có POI hoặc log di chuyển để hiển thị.</p>
            </div>
        }
        else
        {
            <div id="analytics-map" class="analytics-map" aria-label="Bản đồ Analytics"></div>
            <div id="analytics-map-fallback" class="empty-state mt-3 d-none">
                <p>Không tải được nền bản đồ. Dữ liệu vẫn hiển thị ở bảng bên cạnh.</p>
            </div>
            <div id="analytics-map-heat-warning" class="map-runtime-note d-none">
                Không tải được lớp heatmap. POI và tuyến thiết bị vẫn hoạt động.
            </div>
        }
    </article>

    <aside class="map-inspector">
        <article class="inspector-panel inspector-panel--primary">
            <span class="panel-label">Theo dõi nhanh</span>
            <div class="inspector-row">
                <span>Cập nhật gần nhất</span>
                <strong>@latestMovementLabel</strong>
            </div>
            <div class="inspector-row">
                <span>Điểm tuyến đang dùng</span>
                <strong>@Model.AnalyzedMovementPointCount</strong>
            </div>
            <div class="inspector-row">
                <span>Thiết bị ghi nhận</span>
                <strong>@Model.AnonymousVisitorCount</strong>
            </div>
            <p class="mb-0">@Model.AnalyticsWindowLabel</p>
        </article>

        <article class="inspector-panel">
            <span class="panel-label">POI nghe nhiều nhất</span>
            @if (topPoi is null)
            {
                <p class="panel-empty mb-0">Chưa có lượt nghe.</p>
            }
            else
            {
                <strong class="featured-poi">@topPoi.PoiName</strong>
                <p class="mb-0">@topPoi.ListenCount lượt nghe</p>
            }
        </article>

        <article class="inspector-panel">
            <span class="panel-label">Top POI</span>
            @if (!Model.TopListeningPois.Any())
            {
                <p class="panel-empty mb-0">Chưa có dữ liệu.</p>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var poi in Model.TopListeningPois.Take(5))
                    {
                        <div class="compact-row">
                            <span>@poi.PoiName</span>
                            <strong>@poi.ListenCount</strong>
                        </div>
                    }
                </div>
            }
        </article>

        <article class="inspector-panel">
            <span class="panel-label">Tuyến thiết bị gần đây</span>
            @if (!Model.Routes.Any())
            {
                <p class="panel-empty mb-0">Chưa có tuyến di chuyển.</p>
            }
            else
            {
                <div class="compact-list">
                    @foreach (var route in Model.Routes.Take(6).Select((item, index) => new { Item = item, Number = index + 1 }))
                    {
                        <div class="route-row">
                            <i style="--route-color: var(--route-@((route.Number - 1) % 8));"></i>
                            <div>
                                <strong>@route.Item.RouteLabel</strong>
                                <span>@route.Item.PointCount điểm · @Math.Round(route.Item.DurationMinutes) phút</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </article>
    </aside>
</section>

@if (activePois.Any())
{
    <section class="poi-table-panel">
        <div class="map-panel__header">
            <div>
                <h2>Danh sách POI trên bản đồ</h2>
            </div>
        </div>
        <div class="poi-table">
            @foreach (var poi in activePois.Select((item, index) => new { Item = item, Number = index + 1 }))
            {
                analyticsByPoi.TryGetValue(poi.Item.Id, out var poiAnalytics);
                <div class="poi-table__row">
                    <span class="poi-number @(poi.Item.Id == topPoiId ? "is-hot" : null)">@poi.Number</span>
                    <div>
                        <strong>@poi.Item.Name</strong>
                        <span>@poi.Item.Address</span>
                    </div>
                    <strong>@(poiAnalytics?.ListenCount ?? 0) lượt</strong>
                </div>
            }
        </div>
    </section>
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        (() => {
            const pois = @Html.Raw(poisJson);
            const routes = @Html.Raw(routesJson);
            const heatPoints = @Html.Raw(heatmapJson);
            const mapElement = document.getElementById("analytics-map");
            const fallback = document.getElementById("analytics-map-fallback");
            const heatWarning = document.getElementById("analytics-map-heat-warning");

            if (!mapElement) return;

            if (!window.L) {
                fallback?.classList.remove("d-none");
                return;
            }

            const hcmcCenter = [10.7769, 106.7009];
            const hcmcBounds = [
                [10.33, 106.35],
                [11.17, 107.05]
            ];
            const routePalette = ["#2563eb", "#dc2626", "#16a34a", "#d97706", "#7c3aed", "#0891b2", "#be185d", "#65a30d"];
            const map = L.map(mapElement, {
                zoomControl: true,
                preferCanvas: true,
                maxBounds: hcmcBounds,
                maxBoundsViscosity: 0.55
            }).setView(hcmcCenter, 12);

            const bounds = [];
            const poiLayer = L.layerGroup();
            const routeLayer = L.layerGroup();
            let heatLayer = null;

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "&copy; OpenStreetMap"
            }).addTo(map);

            pois.forEach((poi) => {
                const latLng = [Number(poi.latitude), Number(poi.longitude)];
                bounds.push(latLng);

                const marker = L.marker(latLng, {
                    icon: L.divIcon({
                        className: `analytics-map__poi-marker ${poi.isTopListened ? "is-hot" : ""}`,
                        html: `<span>${escapeHtml(poi.number)}</span>`,
                        iconSize: poi.isTopListened ? [44, 44] : [34, 34],
                        iconAnchor: poi.isTopListened ? [22, 22] : [17, 17]
                    })
                });

                marker.bindPopup(`
                    <strong>${escapeHtml(poi.name)}</strong><br>
                    ${escapeHtml(poi.address)}<br>
                    Bán kính: ${formatNumber(poi.radiusMeters)}m<br>
                    Lượt nghe: ${formatNumber(poi.listenCount)}
                `);

                poiLayer.addLayer(marker);

                if (Number(poi.radiusMeters) > 0) {
                    poiLayer.addLayer(L.circle(latLng, {
                        radius: Number(poi.radiusMeters),
                        color: poi.isTopListened ? "#dc2626" : "#0f766e",
                        fillColor: poi.isTopListened ? "#dc2626" : "#0f766e",
                        fillOpacity: poi.isTopListened ? 0.14 : 0.08,
                        weight: 1
                    }));
                }
            });

            routes.forEach((route, index) => {
                if (!Array.isArray(route.points) || route.points.length < 2) return;

                const color = routePalette[index % routePalette.length];
                const latLngs = route.points.map((point) => [Number(point.latitude), Number(point.longitude)]);
                latLngs.forEach((point) => bounds.push(point));

                const polyline = L.polyline(latLngs, {
                    color,
                    weight: 4,
                    opacity: 0.84
                });

                polyline.bindPopup(`
                    <strong>${escapeHtml(route.routeLabel || `Thiết bị ${index + 1}`)}</strong><br>
                    ${formatNumber(route.pointCount)} điểm · ${formatNumber(route.approxDistanceMeters)}m<br>
                    ${formatNumber(route.durationMinutes)} phút
                `);

                routeLayer.addLayer(polyline);
                routeLayer.addLayer(L.circleMarker(latLngs[0], {
                    radius: 6,
                    color,
                    fillColor: "#ffffff",
                    fillOpacity: 1,
                    weight: 2
                }));
                routeLayer.addLayer(L.circleMarker(latLngs[latLngs.length - 1], {
                    radius: 5,
                    color,
                    fillColor: color,
                    fillOpacity: 0.95,
                    weight: 1
                }));
            });

            if (typeof L.heatLayer === "function" && Array.isArray(heatPoints) && heatPoints.length > 0) {
                const maxHeatCount = heatPoints.reduce((max, point) => Math.max(max, Number(point.count) || 0), 1);
                const heatSamples = heatPoints.map((point) => ([
                    Number(point.latitude),
                    Number(point.longitude),
                    normalizeHeatWeight(point, maxHeatCount)
                ]));

                heatLayer = L.heatLayer(heatSamples, {
                    radius: 32,
                    blur: 24,
                    maxZoom: 18,
                    minOpacity: 0.14,
                    gradient: {
                        0.15: "#60a5fa",
                        0.38: "#22c55e",
                        0.62: "#facc15",
                        0.82: "#fb923c",
                        1.00: "#dc2626"
                    }
                });

                heatPoints.forEach((point) => bounds.push([Number(point.latitude), Number(point.longitude)]));
            } else if (Array.isArray(heatPoints) && heatPoints.length > 0) {
                heatWarning?.classList.remove("d-none");
            }

            if (heatLayer) heatLayer.addTo(map);
            if (routeLayer.getLayers().length > 0) routeLayer.addTo(map);
            if (poiLayer.getLayers().length > 0) poiLayer.addTo(map);

            const overlayLayers = {};
            if (poiLayer.getLayers().length > 0) overlayLayers["POI"] = poiLayer;
            if (routeLayer.getLayers().length > 0) overlayLayers["Tuyến thiết bị"] = routeLayer;
            if (heatLayer) overlayLayers["Heatmap"] = heatLayer;

            if (Object.keys(overlayLayers).length > 0) {
                L.control.layers(null, overlayLayers, {
                    collapsed: false,
                    position: "topright"
                }).addTo(map);
            }

            if (bounds.length > 0) {
                const latLngBounds = L.latLngBounds(bounds);
                if (latLngBounds.isValid()) {
                    map.fitBounds(latLngBounds.pad(0.16), { maxZoom: 17 });
                }
            }

            window.setTimeout(() => map.invalidateSize(), 0);

            function normalizeHeatWeight(point, maxHeatCount) {
                const explicitWeight = Number(point?.weight);
                if (Number.isFinite(explicitWeight) && explicitWeight > 0) {
                    return Math.min(1, Math.max(0.06, explicitWeight));
                }

                const count = Number(point?.count) || 0;
                if (maxHeatCount <= 1) return 0.18;
                return Math.min(1, Math.max(0.06, count / maxHeatCount));
            }

            function escapeHtml(value) {
                return String(value ?? "")
                    .replaceAll("&", "&amp;")
                    .replaceAll("<", "&lt;")
                    .replaceAll(">", "&gt;")
                    .replaceAll('"', "&quot;")
                    .replaceAll("'", "&#039;");
            }

            function formatNumber(value) {
                const numericValue = Number(value ?? 0);
                return new Intl.NumberFormat("vi-VN", {
                    maximumFractionDigits: numericValue >= 100 ? 0 : 1
                }).format(numericValue);
            }
        })();
    </script>
}
