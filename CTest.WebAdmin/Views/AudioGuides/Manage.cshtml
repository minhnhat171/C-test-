@model AudioGuideManagementPageViewModel
@{
    ViewData["Title"] = "Quản lý Audio / TTS";
    var selectedPoiName = Model.Pois.FirstOrDefault(x => x.Id == Model.Editor.PoiId)?.Name ?? "Chưa chọn POI";
}

@if (string.IsNullOrWhiteSpace(selectedPoiName) && Model.HasPoiScope)
{
    selectedPoiName = $"{Model.ScopePoiName} ({Model.ScopePoiCode})";
}

<style>
    .audio-page {
        --audio-ink: #0f172a;
        --audio-muted: #64748b;
        --audio-panel: rgba(255,255,255,0.96);
        --audio-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        color: var(--audio-ink);
    }

    .audio-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .audio-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .audio-head p {
        margin: 0.45rem 0 0;
        color: var(--audio-muted);
        max-width: 760px;
    }

    .audio-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(360px, 0.95fr);
        gap: 1.2rem;
    }

    .audio-panel {
        background: var(--audio-panel);
        border-radius: 28px;
        box-shadow: var(--audio-shadow);
        overflow: hidden;
    }

    .audio-table {
        margin-bottom: 0;
        --bs-table-bg: transparent;
    }

    .audio-table thead th {
        background: rgba(248, 250, 252, 0.98);
        color: var(--audio-muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 1rem 1.1rem;
        border-bottom-width: 0;
    }

    .audio-table tbody td {
        padding: 1rem 1.1rem;
        border-color: rgba(148, 163, 184, 0.12);
        vertical-align: middle;
    }

    .audio-row-selected {
        background: rgba(255, 247, 237, 0.75);
    }

    .audio-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.36rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 700;
    }

    .audio-pill.source-tts {
        background: #e0f2fe;
        color: #0369a1;
    }

    .audio-pill.source-file {
        background: #ede9fe;
        color: #6d28d9;
    }

    .audio-pill.status-published {
        background: #dcfce7;
        color: #166534;
    }

    .audio-pill.status-draft {
        background: #fef3c7;
        color: #92400e;
    }

    .audio-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .audio-panel-body {
        padding: 1.4rem;
    }

    .audio-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .audio-form-grid .full {
        grid-column: 1 / -1;
    }

    .audio-page .form-control,
    .audio-page .form-select {
        min-height: 48px;
        border-radius: 16px;
        border-color: rgba(148, 163, 184, 0.24);
    }

    .audio-page textarea.form-control {
        min-height: 150px;
    }

    .audio-preview {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    }

    .audio-preview-label {
        color: var(--audio-muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .audio-preview-title {
        margin-top: 0.45rem;
        font-size: 1.25rem;
        font-weight: 800;
    }

    .audio-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
        margin-bottom: 1rem;
    }

    .audio-summary-card {
        padding: 1rem;
        border-radius: 8px;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .audio-summary-label {
        color: var(--audio-muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .audio-summary-value {
        margin-top: 0.35rem;
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    @@media (max-width: 1199.98px) {
        .audio-layout {
            grid-template-columns: 1fr;
        }

        .audio-head {
            flex-direction: column;
        }

        .audio-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767.98px) {
        .audio-summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="audio-page" data-audio-base-url="@Model.ApiBaseUrl">
    <div class="audio-head">
        <div>
            <h1>Quản lý Audio / TTS</h1>
            <p>Trang này lưu audio thật vào VKFoodAPI. Các bản ghi đã publish sẽ được đồng bộ để app dùng lại dữ liệu narration và file audio.</p>
        </div>
        <a asp-action="Index" asp-route-poiId="@Model.ScopePoiId" asp-route-createNew="true" class="btn btn-primary btn-lg rounded-pill px-4">+ Tạo audio mới</a>
    </div>

    @if (Model.HasPoiScope)
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a asp-controller="Pois" asp-action="Details" asp-route-id="@Model.ScopePoiId" class="btn btn-outline-secondary rounded-pill px-4">Về POI</a>
            <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4">Tất cả audio</a>
            <a asp-action="Index" asp-route-poiId="@Model.ScopePoiId" asp-route-createNew="true" class="btn btn-primary rounded-pill px-4">+ Tạo audio mới cho POI này</a>
        </div>
        <div class="alert alert-primary border-0 shadow-sm">
            Đang quản lý audio cho POI <strong>@Model.ScopePoiName</strong> (@Model.ScopePoiCode).
            Hiện có <strong>@Model.PoiWithSelectedLanguageAudioCount</strong> bản ghi đúng ngôn ngữ đang chọn.
        </div>
    }

    @if (TempData["AudioMessage"] is string audioMessage)
    {
        <div class="alert alert-info border-0 shadow-sm">@audioMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
    }

    <div class="audio-summary-grid">
        <div class="audio-summary-card">
            <div class="audio-summary-label">POI từ API</div>
            <div class="audio-summary-value">@Model.TotalPoiCount</div>
        </div>
        <div class="audio-summary-card">
            <div class="audio-summary-label">Có TTS ngôn ngữ này</div>
            <div class="audio-summary-value">@Model.PoiWithSelectedLanguageAudioCount</div>
        </div>
        <div class="audio-summary-card">
            <div class="audio-summary-label">Đã publish</div>
            <div class="audio-summary-value">@Model.PublishedPoiAudioCount</div>
        </div>
        <div class="audio-summary-card">
            <div class="audio-summary-label">Cần tạo thêm</div>
            <div class="audio-summary-value">@Model.MissingSelectedLanguageAudioCount</div>
        </div>
    </div>

    <div class="audio-layout">
        <div class="audio-panel">
            <div class="table-responsive">
                <table class="table audio-table align-middle">
                    <thead>
                        <tr>
                            <th>POI</th>
                            <th>Audio / TTS</th>
                            <th>Ngôn ngữ đã có</th>
                            <th>Trạng thái</th>
                            <th>Cập nhật</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.PoiAudioItems.Any())
                    {
                        @foreach (var item in Model.PoiAudioItems)
                        {
                            <tr class="@(item.IsSelected ? "audio-row-selected" : string.Empty)">
                                <td>
                                    <div class="fw-semibold">@item.PoiName</div>
                                    <div class="text-muted small">@item.PoiCode</div>
                                    <div class="text-muted small">@item.PoiAddress</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.DisplayId</div>
                                    <div>@item.LanguageLabel</div>
                                    <div class="text-muted small">@item.VoiceLabel</div>
                                </td>
                                <td>@item.AvailableLanguageLabels</td>
                                <td>
                                    <span class="audio-pill @(item.HasSelectedLanguageAudio ? (item.HasPublishedAudio ? "status-published" : "status-draft") : "source-tts")">
                                        @item.StatusLabel
                                    </span>
                                    <div class="text-muted small mt-1">@item.SourceLabel</div>
                                </td>
                                <td>@(item.UpdatedAtLocal?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa tạo")</td>
                                <td>
                                    <div class="audio-actions">
                                        <a asp-controller="Pois" asp-action="Details" asp-route-id="@item.PoiId" class="btn btn-outline-secondary btn-sm rounded-pill">POI</a>
                                        @if (item.AudioId.HasValue)
                                        {
                                            <a asp-action="Index" asp-route-audioId="@item.AudioId" asp-route-poiId="@item.PoiId" asp-route-languageCode="@item.LanguageCode" class="btn btn-outline-primary btn-sm rounded-pill">Sửa</a>
                                        }
                                        else
                                        {
                                            <a asp-action="Index" asp-route-poiId="@item.PoiId" asp-route-languageCode="@item.LanguageCode" asp-route-createNew="true" class="btn btn-primary btn-sm rounded-pill">Tạo TTS</a>
                                        }
                                        <button type="button"
                                                class="btn btn-outline-dark btn-sm rounded-pill js-audio-preview"
                                                data-script="@item.Script"
                                                data-file-path="@item.FilePath"
                                                data-language-code="@item.LanguageCode"
                                                data-voice-type="@item.VoiceType"
                                                data-source-type="@item.SourceType"
                                                data-poi-name="@item.PoiName">
                                            Nghe thử
                                        </button>
                                        @if (item.AudioId.HasValue)
                                        {
                                            <form asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa audio này không?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.AudioId" />
                                                <input type="hidden" name="scopePoiId" value="@item.PoiId" />
                                                <input type="hidden" name="languageCode" value="@item.LanguageCode" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">Xóa</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">Chưa có POI nào trong VKFoodAPI để tạo Audio / TTS.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="audio-panel">
            <div class="audio-panel-body">
                <form asp-action="Save" method="post" id="audioForm">
                    @Html.AntiForgeryToken()
                    <input asp-for="ScopePoiId" type="hidden" />
                    <input asp-for="Editor.Id" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm" role="alert"></div>

                    <div class="audio-form-grid">
                        <div class="full">
                            <label asp-for="Editor.PoiId" class="form-label">Chọn POI</label>
                            <select asp-for="Editor.PoiId" class="form-select" id="audioPoiId">
                                <option value="">Chọn điểm cần gắn audio</option>
                                @foreach (var poi in Model.Pois)
                                {
                                    <option value="@poi.Id">@poi.Name (@poi.Code)</option>
                                }
                            </select>
                            <span asp-validation-for="Editor.PoiId" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="Editor.LanguageCode" class="form-label">Ngôn ngữ</label>
                            <select asp-for="Editor.LanguageCode" class="form-select" id="audioLanguageCode">
                                <option value="vi">Tiếng Việt</option>
                                <option value="en">Tiếng Anh</option>
                                <option value="zh">Tiếng Trung</option>
                                <option value="ko">Tiếng Hàn</option>
                                <option value="fr">Tiếng Pháp</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.SourceType" class="form-label">Nguồn phát</label>
                            <select asp-for="Editor.SourceType" class="form-select" id="audioSourceType">
                                <option value="tts">TTS</option>
                                <option value="file">File audio</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.VoiceType" class="form-label">Gi?ng d?c</label>
                            <select asp-for="Editor.VoiceType" class="form-select" id="audioVoiceType">
                                <option value="female">Nữ</option>
                                <option value="male">Nam</option>
                                <option value="neutral">Trung tính</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.EstimatedSeconds" class="form-label">Thời lượng dự kiến</label>
                            <input asp-for="Editor.EstimatedSeconds" class="form-control" id="audioEstimatedSeconds" type="number" min="0" />
                            <span asp-validation-for="Editor.EstimatedSeconds" class="text-danger small"></span>
                        </div>

                        <div class="full" id="ttsScriptGroup">
                            <label asp-for="Editor.Script" class="form-label">Nội dung script</label>
                            <textarea asp-for="Editor.Script" class="form-control" id="audioScript"></textarea>
                            <span asp-validation-for="Editor.Script" class="text-danger small"></span>
                        </div>

                        <div class="full d-none" id="audioFileGroup">
                            <label asp-for="Editor.FilePath" class="form-label">Đường dẫn file audio</label>
                            <input asp-for="Editor.FilePath" class="form-control" id="audioFilePath" />
                            <span asp-validation-for="Editor.FilePath" class="text-danger small"></span>
                        </div>

                        <div class="full">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Editor.IsPublished" class="form-check-input" />
                                <label asp-for="Editor.IsPublished" class="form-check-label">Publish để app dùng dữ liệu này</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Lưu vào API</button>
                        <button type="button" class="btn btn-outline-dark rounded-pill px-4" id="previewSpeechButton">Nghe thử</button>
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" id="estimateTtsButton">Ước lượng thời lượng</button>
                    </div>
                </form>

                <div class="audio-preview">
                        <div class="audio-preview-label">Xem trước</div>
                    <div class="audio-preview-title" id="audioPreviewPoi">@selectedPoiName</div>
                    <div class="text-muted mt-2" id="audioPreviewSummary">
                        @(string.Equals(Model.Editor.SourceType, "file", StringComparison.OrdinalIgnoreCase)
                            ? "Bản ghi hiện dùng file audio. App sẽ lấy file này từ dữ liệu dùng chung khi bản ghi được publish."
                            : "Bản ghi hiện dùng TTS. Script sẽ được đồng bộ sang narration trong dữ liệu dùng chung.")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="@Url.Content("~/js/narration-player.js")"></script>
    <script>
        (() => {
            window.__vkWebNarrationEnhanced = true;

            const audioPage = document.querySelector(".audio-page");
            const apiBaseUrl = audioPage?.dataset.audioBaseUrl || window.location.origin;
            const scriptInput = document.getElementById("audioScript");
            const fileInput = document.getElementById("audioFilePath");
            const languageSelect = document.getElementById("audioLanguageCode");
            const voiceSelect = document.getElementById("audioVoiceType");
            const sourceType = document.getElementById("audioSourceType");
            const ttsGroup = document.getElementById("ttsScriptGroup");
            const fileGroup = document.getElementById("audioFileGroup");
            const previewButton = document.getElementById("previewSpeechButton");
            const estimateButton = document.getElementById("estimateTtsButton");
            const estimatedSeconds = document.getElementById("audioEstimatedSeconds");
            const poiSelect = document.getElementById("audioPoiId");
            const previewPoi = document.getElementById("audioPreviewPoi");
            const previewSummary = document.getElementById("audioPreviewSummary");
            const narrationPlayer = window.VinhKhanhNarrationPlayer?.createPlayer({
                onTrạng thái: (message) => {
                    if (previewSummary) {
                        previewSummary.textContent = message;
                    }
                }
            });

            const actionRow = previewButton?.parentElement;
            let stopButton = document.getElementById("stopPreviewButton");

            if (!stopButton && actionRow && estimateButton) {
                stopButton = document.createElement("button");
                stopButton.type = "button";
                stopButton.id = "stopPreviewButton";
                stopButton.className = "btn btn-outline-secondary rounded-pill px-4";
                stopButton.textContent = "Dừng nghe thử";
                actionRow.insertBefore(stopButton, estimateButton);
            }

            const getDefaultSummary = () => sourceType?.value === "file"
                ? "Bản ghi hiện dùng file audio. Web sẽ ưu tiên phát đúng file này giống app nếu file truy cập được."
                : "Bản ghi hiện dùng TTS. Web sẽ đọc theo locale và giọng phù hợp với ngôn ngữ đang chọn.";

            const setSummary = (message) => {
                if (previewSummary) {
                    previewSummary.textContent = message;
                }
            };

            const syncSourceMode = () => {
                const isFile = sourceType?.value === "file";
                ttsGroup?.classList.toggle("d-none", isFile);
                fileGroup?.classList.toggle("d-none", !isFile);
                setSummary(getDefaultSummary());
            };

            const syncPoiLabel = () => {
                if (!previewPoi || !poiSelect) {
                    return;
                }

                previewPoi.textContent = poiSelect.options[poiSelect.selectedIndex]?.text || "Chưa chọn POI";
            };

            const previewEditor = () => {
                if (!narrationPlayer) {
                    setSummary("Web chưa tải được bộ phát thuyết minh.");
                    return;
                }

                syncPoiLabel();
                narrationPlayer.play({
                    playbackMode: sourceType?.value === "file" ? "audio" : "tts",
                    audioAssetPath: fileInput?.value?.trim() || "",
                    narrationText: scriptInput?.value?.trim() || "",
                    languageCode: languageSelect?.value || "vi",
                    voiceType: voiceSelect?.value || "female",
                    allowAudioFallback: false,
                    baseUrl: apiBaseUrl,
                    messages: {
                        playingAudio: "Đang phát đúng file audio đã lưu...",
                        audioEnded: "Đã phát xong file audio mẫu.",
                        audioUnavailable: "Bản ghi này chưa có file audio hợp lệ để preview trên web.",
                        audioFailed: "Không phát được file audio này trên web.",
                        playingTts: "Đang đọc preview TTS theo tùy chọn hiện tại...",
                        ttsEnded: "Đã đọc xong preview TTS.",
                        ttsFailed: "Không thể phát preview TTS. Thử bấm lại một lần nữa.",
                        unsupportedTts: "Trình duyệt này không hỗ trợ TTS preview.",
                        empty: "Hay nhap script truoc khi nghe thu."
                    }
                });
            };

            sourceType?.addEventListener("change", syncSourceMode);
            poiSelect?.addEventListener("change", syncPoiLabel);
            scriptInput?.addEventListener("input", () => setSummary(getDefaultSummary()));
            fileInput?.addEventListener("input", () => setSummary(getDefaultSummary()));
            languageSelect?.addEventListener("change", () => setSummary(getDefaultSummary()));
            voiceSelect?.addEventListener("change", () => setSummary(getDefaultSummary()));
            previewButton?.addEventListener("click", previewEditor);
            stopButton?.addEventListener("click", () => narrationPlayer?.stop("Đã dừng nghe thử."));

            estimateButton?.addEventListener("click", () => {
                const words = (scriptInput?.value || "").trim().split(/\s+/).filter(Boolean).length;
                if (words > 0 && estimatedSeconds) {
                    estimatedSeconds.value = Math.max(15, Math.ceil(words / 2.5));
                }
            });

            document.querySelectorAll(".js-audio-preview").forEach((button) => {
                button.addEventListener("click", () => {
                    if (!narrationPlayer) {
                        setSummary("Web chưa tải được bộ phát thuyết minh.");
                        return;
                    }

                    if (previewPoi) {
                        previewPoi.textContent = button.dataset.poiName || previewPoi.textContent;
                    }

                    narrationPlayer.play({
                        playbackMode: button.dataset.sourceType === "file" ? "audio" : "tts",
                        audioAssetPath: button.dataset.filePath || "",
                        narrationText: button.dataset.script || "",
                        languageCode: button.dataset.languageCode || "vi",
                        voiceType: button.dataset.voiceType || "female",
                        allowAudioFallback: false,
                        baseUrl: apiBaseUrl,
                        messages: {
                            playingAudio: "Đang phát file audio đã publish cho POI này...",
                            audioEnded: "Đã nghe xong bản ghi mẫu của POI.",
                            audioUnavailable: "POI này chưa có file audio hợp lệ để phát trên web.",
                            audioFailed: "Không phát được file audio đã lưu cho POI này.",
                            playingTts: "Đang đọc preview TTS của POI...",
                            ttsEnded: "Đã đọc xong preview POI.",
                            ttsFailed: "Không thể đọc preview TTS của POI này.",
                            unsupportedTts: "Trình duyệt này không hỗ trợ TTS preview.",
                            empty: "POI này chưa có nội dung để nghe thử."
                        }
                    });
                });
            });

            window.addEventListener("beforeunload", () => narrationPlayer?.stop());

            syncSourceMode();
            syncPoiLabel();
        })();
    </script>
    <script>
        (() => {
            if (window.__vkWebNarrationEnhanced) {
                return;
            }

            const scriptInput = document.getElementById("audioScript");
            const sourceType = document.getElementById("audioSourceType");
            const ttsGroup = document.getElementById("ttsScriptGroup");
            const fileGroup = document.getElementById("audioFileGroup");
            const previewButton = document.getElementById("previewSpeechButton");
            const estimateButton = document.getElementById("estimateTtsButton");
            const estimatedSeconds = document.getElementById("audioEstimatedSeconds");
            const poiSelect = document.getElementById("audioPoiId");
            const previewPoi = document.getElementById("audioPreviewPoi");
            const previewSummary = document.getElementById("audioPreviewSummary");

            const syncSourceMode = () => {
                const isFile = sourceType.value === "file";
                ttsGroup.classList.toggle("d-none", isFile);
                fileGroup.classList.toggle("d-none", !isFile);
                previewSummary.textContent = isFile
                    ? "Bản ghi hiện dùng file audio. App sẽ lấy file này từ dữ liệu dùng chung khi bản ghi được publish."
                    : "Bản ghi hiện dùng TTS. Script sẽ được đồng bộ sang narration trong dữ liệu dùng chung.";
            };

            const syncPoiLabel = () => {
                previewPoi.textContent = poiSelect.options[poiSelect.selectedIndex]?.text || "Chưa chọn POI";
            };

            const speakText = (text) => {
                if (!text || !("speechSynthesis" in window)) {
                    return;
                }

                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                window.speechSynthesis.speak(utterance);
            };

            sourceType?.addEventListener("change", syncSourceMode);
            poiSelect?.addEventListener("change", syncPoiLabel);

            previewButton?.addEventListener("click", () => {
                speakText(scriptInput?.value?.trim() || "");
            });

            estimateButton?.addEventListener("click", () => {
                const words = (scriptInput?.value || "").trim().split(/\s+/).filter(Boolean).length;
                if (words > 0) {
                    estimatedSeconds.value = Math.max(15, Math.ceil(words / 2.5));
                }
            });

            document.querySelectorAll(".js-audio-preview").forEach((button) => {
                button.addEventListener("click", () => {
                    speakText(button.dataset.script || "");
                });
            });

            syncSourceMode();
            syncPoiLabel();
        })();
    </script>
}

