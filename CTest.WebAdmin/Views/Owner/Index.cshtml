@model OwnerPortalViewModel
@{
    ViewData["Title"] = "Chu nha hang";
}

<style>
    .owner-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.25fr);
        gap: 1rem;
    }

    .owner-panel {
        padding: 1.2rem;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 18px 46px rgba(15, 23, 42, 0.08);
    }

    .owner-poi-table {
        max-height: 360px;
        overflow: auto;
    }

    .owner-image-dropzone {
        border: 1px dashed rgba(37, 99, 235, 0.42);
        border-radius: 8px;
        background: #f8fafc;
        padding: 1rem;
        cursor: pointer;
    }

    .owner-image-dropzone.is-dragover {
        border-color: #2563eb;
        background: #eff6ff;
    }

    .owner-image-preview {
        display: none;
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 0.85rem;
        background: #e2e8f0;
    }

    .owner-image-preview.has-image {
        display: block;
    }

    @@media (max-width: 1199.98px) {
        .owner-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Khu vuc chu nha hang</h1>
        <div class="text-muted">Dang ky POI cua quan va xem lich su nghe cua cac POI do ban phu trach.</div>
    </div>
    <div class="badge text-bg-light px-3 py-2">@Model.OwnerDisplayName</div>
</div>

@if (TempData["OwnerMessage"] is string ownerMessage)
{
    <div class="alert alert-success">@ownerMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Pois.LoadErrorMessage))
{
    <div class="alert alert-warning">@Model.Pois.LoadErrorMessage</div>
}

<div class="owner-grid mb-4">
    <section class="owner-panel">
        <h2 class="h4 mb-3">Dang ky POI</h2>
        <form asp-controller="Owner" asp-action="Register" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Registration.OwnerUserCode" type="hidden" />
            <input asp-for="Registration.OwnerDisplayName" type="hidden" />
            <input asp-for="Registration.OwnerEmail" type="hidden" />
            <input asp-for="Registration.ImageSource" type="hidden" id="ownerImageSource" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Registration.Name" class="form-label">Ten quan</label>
                    <input asp-for="Registration.Name" class="form-control" />
                    <span asp-validation-for="Registration.Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Code" class="form-label">Ma POI</label>
                    <input asp-for="Registration.Code" class="form-control" placeholder="VD: VK-FOOD-NEW" />
                    <span asp-validation-for="Registration.Code" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Category" class="form-label">Danh muc</label>
                    <input asp-for="Registration.Category" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Registration.Address" class="form-label">Dia chi</label>
                    <input asp-for="Registration.Address" class="form-control" />
                    <span asp-validation-for="Registration.Address" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Latitude" class="form-label">Latitude</label>
                    <input asp-for="Registration.Latitude" class="form-control" />
                    <span asp-validation-for="Registration.Latitude" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Longitude" class="form-label">Longitude</label>
                    <input asp-for="Registration.Longitude" class="form-control" />
                    <span asp-validation-for="Registration.Longitude" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.RadiusInMeters" class="form-label">Ban kinh kich hoat</label>
                    <input asp-for="Registration.RadiusInMeters" class="form-control" />
                    <span asp-validation-for="Registration.RadiusInMeters" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Registration.Priority" class="form-label">Uu tien</label>
                    <input asp-for="Registration.Priority" class="form-control" />
                    <span asp-validation-for="Registration.Priority" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.SpecialDish" class="form-label">Mon noi bat</label>
                    <input asp-for="Registration.SpecialDish" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Registration.UploadedImage" class="form-label">Anh quan</label>
                    <div class="owner-image-dropzone" id="ownerImageDropzone">
                        <img id="ownerImagePreview" class="owner-image-preview" alt="Preview anh quan" />
                        <div class="fw-semibold">Keo anh vao day hoac bam de chon</div>
                        <div class="text-muted small mt-1">Ho tro JPG, PNG, WEBP. Toi da 5 MB.</div>
                        <input asp-for="Registration.UploadedImage" type="file" class="visually-hidden" id="ownerImageFile" accept="image/*" />
                    </div>
                    <span asp-validation-for="Registration.UploadedImage" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.Description" class="form-label">Mo ta</label>
                    <textarea asp-for="Registration.Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Registration.Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Registration.NarrationScript" class="form-label">Noi dung thuyet minh</label>
                    <textarea asp-for="Registration.NarrationScript" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Registration.NarrationScript" class="text-danger small"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-3">Gui dang ky POI</button>
        </form>
    </section>

    <section class="owner-panel">
        <h2 class="h4 mb-3">POI cua ban</h2>
        <div class="owner-poi-table table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Ma</th>
                        <th>Ten quan</th>
                        <th>Trang thai</th>
                        <th>Dia chi</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Pois.Items.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-muted text-center py-4">Ban chua dang ky POI nao.</td>
                    </tr>
                }
                else
                {
                    @foreach (var poi in Model.Pois.Items)
                    {
                        <tr>
                            <td>@poi.Code</td>
                            <td class="fw-semibold">@poi.Name</td>
                            <td>@(poi.IsActive ? "Dang hoat dong" : "Tam khoa")</td>
                            <td>@poi.Address</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

<section class="owner-panel">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1">Lich su nghe cua quan</h2>
            <div class="text-muted">Du lieu duoc loc theo nhung POI do tai khoan nay dang so huu.</div>
        </div>
        <div class="small text-muted" id="owner-refresh-status">Tu dong cap nhat moi 8 giay</div>
    </div>

    <form id="owner-history-filter-form" asp-controller="Owner" asp-action="Index" method="get" class="row g-3 align-items-end mb-3">
        <div class="col-lg-5">
            <label class="form-label" for="keyword">Tim lich su</label>
            <input class="form-control" id="keyword" name="keyword" value="@Model.ListeningHistory.SearchTerm" placeholder="Ten POI, ma POI, ngon ngu..." />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="period">Moc thoi gian</label>
            <select class="form-select" id="period" name="period">
                <option value="all" selected="@(Model.ListeningHistory.SelectedPeriod == "all" ? "selected" : null)">Tat ca</option>
                <option value="day" selected="@(Model.ListeningHistory.SelectedPeriod == "day" ? "selected" : null)">24 gio qua</option>
                <option value="week" selected="@(Model.ListeningHistory.SelectedPeriod == "week" ? "selected" : null)">7 ngay qua</option>
                <option value="month" selected="@(Model.ListeningHistory.SelectedPeriod == "month" ? "selected" : null)">30 ngay qua</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label" for="sortBy">Sap xep</label>
            <select class="form-select" id="sortBy" name="sortBy">
                <option value="time_desc" selected="@(Model.ListeningHistory.SelectedSortBy == "time_desc" ? "selected" : null)">Moi nhat truoc</option>
                <option value="time_asc" selected="@(Model.ListeningHistory.SelectedSortBy == "time_asc" ? "selected" : null)">Cu nhat truoc</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-dark w-100">Loc</button>
        </div>
    </form>

    <div id="owner-history-content">
        <partial name="~/Views/UsageLogs/_UsageHistoryContent.cshtml" model="Model.ListeningHistory" />
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const imageDropzone = document.getElementById("ownerImageDropzone");
            const imageInput = document.getElementById("ownerImageFile");
            const imagePreview = document.getElementById("ownerImagePreview");
            const container = document.getElementById("owner-history-content");
            const refreshStatus = document.getElementById("owner-refresh-status");

            const previewFile = (file) => {
                if (!file || !file.type.startsWith("image/") || !imagePreview) return;

                const reader = new FileReader();
                reader.addEventListener("load", () => {
                    imagePreview.src = reader.result;
                    imagePreview.classList.add("has-image");
                });
                reader.readAsDataURL(file);
            };

            imageDropzone?.addEventListener("click", () => imageInput?.click());
            imageDropzone?.addEventListener("dragover", (event) => {
                event.preventDefault();
                imageDropzone.classList.add("is-dragover");
            });
            imageDropzone?.addEventListener("dragleave", () => {
                imageDropzone.classList.remove("is-dragover");
            });
            imageDropzone?.addEventListener("drop", (event) => {
                event.preventDefault();
                imageDropzone.classList.remove("is-dragover");

                const file = event.dataTransfer?.files?.[0];
                if (!file || !imageInput) return;

                const files = new DataTransfer();
                files.items.add(file);
                imageInput.files = files.files;
                previewFile(file);
            });
            imageInput?.addEventListener("change", () => {
                previewFile(imageInput.files?.[0]);
            });

            if (!container) {
                return;
            }

            async function refreshSnapshot() {
                const url = new URL(window.location.href);
                url.searchParams.set("partial", "true");

                try {
                    const response = await fetch(url.toString(), {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    container.innerHTML = await response.text();
                    if (refreshStatus) {
                        refreshStatus.textContent = `Tu dong cap nhat luc ${new Date().toLocaleTimeString("vi-VN")}`;
                    }
                } catch {
                    if (refreshStatus) {
                        refreshStatus.textContent = "Dang cho du lieu moi tu API...";
                    }
                }
            }

            const timerId = window.setInterval(refreshSnapshot, 8000);
            window.addEventListener("beforeunload", () => window.clearInterval(timerId), { once: true });
        })();
    </script>
}
