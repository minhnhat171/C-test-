<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.PoiDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding PoiDetailPageTitle}"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,28"
                             Spacing="18">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#2F80FF" Offset="0" />
                        <GradientStop Color="#6AA8FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="0">
                    <Image Source="{Binding SelectedPoiImageSource}"
                           HeightRequest="250"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Padding="20"
                                         Spacing="8">
                        <Label Text="{Binding SelectedPoiName}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White" />

                        <Label Text="{Binding SelectedPoiAddress}"
                               FontSize="15"
                               TextColor="#EAF3FF" />

                        <Border BackgroundColor="#FFFFFF"
                                Padding="12,8"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="{Binding SelectedPoiStatusText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#2F80FF" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding PoiDescriptionSectionTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Label Text="{Binding SelectedPoiDescription}"
                           FontSize="16"
                           TextColor="#486581"
                           LineBreakMode="WordWrap" />

                    <Border BackgroundColor="#F4F8FF"
                            Padding="14"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasSelectedPoiDish}">
                        <Label Text="{Binding SelectedPoiDishText}"
                               FontSize="15"
                               TextColor="#2F80FF" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    IsVisible="{Binding HasSelectedPoiPracticalInfo}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding PoiPracticalInfoSectionTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border BackgroundColor="#F8FBFF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiPriceRange}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PoiPriceTitle}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding SelectedPoiPriceRangeText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#F8FBFF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiOpeningHours}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PoiOpeningHoursTitle}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding SelectedPoiOpeningHoursText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Border BackgroundColor="#F8FBFF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiFirstDish}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PoiFirstDishTitle}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding SelectedPoiFirstDishText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#F8FBFF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiTravelEstimate}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PoiTravelEstimateTitle}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding SelectedPoiTravelEstimateText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding PoiNarrationSectionTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Border BackgroundColor="#E8F1FF"
                            Padding="12,8"
                            HorizontalOptions="Start"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16">
                        <Label Text="{Binding SelectedPoiNarrationStateText}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2F80FF" />
                    </Border>

                    <Label Text="{Binding SelectedPoiNarrationPreview}"
                           FontSize="16"
                           TextColor="#486581"
                           LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="12">
                        <Button Text="{Binding SelectedPoiNarrationActionText}"
                                Clicked="OnNarrateSelectedClicked"
                                BackgroundColor="#2F80FF"
                                TextColor="White"
                                FontSize="16"
                                CornerRadius="18"
                                HeightRequest="50" />

                        <Button Grid.Column="1"
                                Text="{Binding PoiDirectionButtonText}"
                                Clicked="OnOpenMapClicked"
                                BackgroundColor="#E8F1FF"
                                TextColor="#2F80FF"
                                FontSize="16"
                                CornerRadius="18"
                                HeightRequest="50" />

                        <Button Grid.Column="2"
                                Text="{Binding PoiSaveOrHistoryButtonText}"
                                Clicked="OnOpenHistoryClicked"
                                BackgroundColor="#F4F8FF"
                                TextColor="#102A43"
                                FontSize="15"
                                CornerRadius="18"
                                HeightRequest="50" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
