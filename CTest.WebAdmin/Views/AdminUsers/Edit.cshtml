@model AdminUserFormViewModel
@{
    ViewData["Title"] = "Sửa tài khoản";
}

<link rel="stylesheet" href="~/css/admin-users.css" asp-append-version="true" />

<div class="admin-users-page">
    <section class="account-page-header">
        <div>
            <p class="account-kicker mb-1">Quản lý tài khoản</p>
            <h2>Sửa tài khoản</h2>
        </div>
    </section>

    <form asp-action="Edit" asp-route-username="@Model.OriginalUsername" method="post">
        @Html.AntiForgeryToken()
        <partial name="_Form" model="Model" />
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const roleSelect = document.getElementById("accountRoleSelect");
            const ownerFields = Array.from(document.querySelectorAll(".owner-field"));
            const sync = () => {
                const isOwner = roleSelect?.value === "PoiOwner";
                ownerFields.forEach((field) => field.classList.toggle("d-none", !isOwner));
            };
            roleSelect?.addEventListener("change", sync);
            sync();
        })();
    </script>
}
