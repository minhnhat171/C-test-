@model List<TranslationEntry>
@{ ViewData["Title"] = "Bản dịch"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">Quản lý bản dịch</h2>
        <div class="text-muted">Quản trị nội dung đa ngôn ngữ cho từng điểm POI.</div>
    </div>
    <button class="btn btn-primary">+ Thêm bản dịch</button>
</div>
<table class="table table-striped align-middle">
    <thead><tr><th>ID</th><th>POI</th><th>Ngôn ngữ</th><th>Tiêu đề</th><th>Duyệt</th></tr></thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Id</td><td>@item.PoiName</td><td>@item.Language</td><td>@item.Title</td><td>@(item.IsApproved ? "Đã duyệt" : "Chờ duyệt")</td>
        </tr>
    }
    </tbody>
</table>
