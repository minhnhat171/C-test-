@model List<TourPlan>
@{ ViewData["Title"] = "Tour"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">Quản lý tour</h2>
    </div>
    <button class="btn btn-primary">+ Thêm tour</button>
</div>
<table class="table table-striped align-middle">
    <thead><tr><th>ID</th><th>Tên tour</th><th>Thời lượng</th><th>Chuỗi POI</th><th>QR</th></tr></thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Id</td><td>@item.Name</td><td>@item.EstimatedMinutes phút</td><td>@item.PoiSequence</td><td>@(item.IsQrEnabled ? "Bật" : "Tắt")</td>
        </tr>
    }
    </tbody>
</table>
