@model ListeningHistoryPageViewModel

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-warning mb-4">
        @Model.LoadErrorMessage
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Tổng lượt nghe</div>
                <div class="display-6">@Model.TotalSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Hoàn tất</div>
                <div class="display-6">@Model.CompletedSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Tỷ lệ hoàn tất</div>
                <div class="display-6">@Model.CompletionRate%</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Nghe nhiều nhất</div>
                <div class="fw-bold fs-5">@Model.MostPlayedPoi</div>
                <div class="small text-muted mt-2">Tổng @Model.TotalListenSeconds giây nghe trong bộ lọc hiện tại</div>
            </div>
        </div>
    </div>
</div>

@if (Model.SelectedView == "ranking")
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Xếp hạng POI được nghe nhiều nhất</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Hạng</th>
                        <th>POI</th>
                        <th style="width: 140px;">Lượt nghe</th>
                        <th style="width: 140px;">Hoàn tất</th>
                        <th style="width: 160px;">Tổng thời gian</th>
                        <th style="width: 180px;">Lần cuối</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RankingItems.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Chưa có dữ liệu nghe từ app trong bộ lọc hiện tại.</td>
                    </tr>
                }
                else
                {
                    @for (var index = 0; index < Model.RankingItems.Count; index++)
                    {
                        var item = Model.RankingItems[index];
                        <tr>
                            <td><span class="badge text-bg-primary">#@(index + 1)</span></td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>@item.ListenCount</td>
                            <td>
                                <div>@item.CompletedCount / @item.ListenCount</div>
                                <div class="small text-muted">@item.CompletionRateLabel</div>
                            </td>
                            <td>@item.TotalListenLabel</td>
                            <td>@item.LastStartedAtDisplay</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">Dòng thời gian nghe</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 180px;">Bắt đầu</th>
                        <th>POI</th>
                        <th style="width: 180px;">Người nghe</th>
                        <th style="width: 110px;">Kích hoạt</th>
                        <th style="width: 110px;">Ngôn ngữ</th>
                        <th style="width: 150px;">Thời gian</th>
                        <th style="width: 150px;">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.TimelineItems.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Chưa có lượt nghe nào được đồng bộ.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.TimelineItems)
                    {
                        var badgeClass = item.Completed
                            ? "text-bg-success"
                            : string.IsNullOrWhiteSpace(item.ErrorMessage)
                                ? "text-bg-warning"
                                : "text-bg-danger";

                        <tr>
                            <td>
                                <div>@item.StartedAtDisplay</div>
                                <div class="small text-muted">Kết thúc: @item.CompletedAtDisplay</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>
                                <div>@item.UserDisplayName</div>
                                <div class="small text-muted">@item.UserCode</div>
                            </td>
                            <td>
                                <div>@item.TriggerType</div>
                                <div class="small text-muted">@item.Source / @item.DevicePlatform</div>
                            </td>
                            <td>@item.Language</td>
                            <td>@item.DurationLabel</td>
                            <td>
                                <span class="badge @badgeClass">@item.StatusLabel</span>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                                {
                                    <div class="small text-danger mt-1">@item.ErrorMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Dòng thời gian nghe</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 180px;">Bắt đầu</th>
                        <th>POI</th>
                        <th style="width: 180px;">Người nghe</th>
                        <th style="width: 110px;">Kích hoạt</th>
                        <th style="width: 110px;">Ngôn ngữ</th>
                        <th style="width: 150px;">Thời gian</th>
                        <th style="width: 150px;">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.TimelineItems.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Chưa có lượt nghe nào được đồng bộ.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.TimelineItems)
                    {
                        var badgeClass = item.Completed
                            ? "text-bg-success"
                            : string.IsNullOrWhiteSpace(item.ErrorMessage)
                                ? "text-bg-warning"
                                : "text-bg-danger";

                        <tr>
                            <td>
                                <div>@item.StartedAtDisplay</div>
                                <div class="small text-muted">Kết thúc: @item.CompletedAtDisplay</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>
                                <div>@item.UserDisplayName</div>
                                <div class="small text-muted">@item.UserCode</div>
                            </td>
                            <td>
                                <div>@item.TriggerType</div>
                                <div class="small text-muted">@item.Source / @item.DevicePlatform</div>
                            </td>
                            <td>@item.Language</td>
                            <td>@item.DurationLabel</td>
                            <td>
                                <span class="badge @badgeClass">@item.StatusLabel</span>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                                {
                                    <div class="small text-danger mt-1">@item.ErrorMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">Xếp hạng POI được nghe nhiều nhất</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Hạng</th>
                        <th>POI</th>
                        <th style="width: 140px;">Lượt nghe</th>
                        <th style="width: 140px;">Hoàn tất</th>
                        <th style="width: 160px;">Tổng thời gian</th>
                        <th style="width: 180px;">Lần cuối</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RankingItems.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Chưa có dữ liệu nghe từ app trong bộ lọc hiện tại.</td>
                    </tr>
                }
                else
                {
                    @for (var index = 0; index < Model.RankingItems.Count; index++)
                    {
                        var item = Model.RankingItems[index];
                        <tr>
                            <td><span class="badge text-bg-primary">#@(index + 1)</span></td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>@item.ListenCount</td>
                            <td>
                                <div>@item.CompletedCount / @item.ListenCount</div>
                                <div class="small text-muted">@item.CompletionRateLabel</div>
                            </td>
                            <td>@item.TotalListenLabel</td>
                            <td>@item.LastStartedAtDisplay</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
}
