<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F4EFE7"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="22,32,22,26" Spacing="18">

            <Border StrokeThickness="0"
                    Padding="22"
                    StrokeShape="RoundRectangle 34">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Color="#173A43" Offset="0.0" />
                        <GradientStop Color="#215C57" Offset="0.55" />
                        <GradientStop Color="#3C7E6C" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="12">
                    <Label Text="VinhKhanh"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#FFF9F2" />

                    <Label Text="Bản hiện tại dành cho du khách vào nhanh để trải nghiệm ngay giao diện chính, chọn box quán và nghe thuyết minh."
                           FontSize="15"
                           LineHeight="1.25"
                           TextColor="#E9F3EF" />

                    <Border BackgroundColor="#F5EBDD"
                            StrokeThickness="0"
                            Padding="14,10"
                            StrokeShape="RoundRectangle 18">
                        <Label Text="Luồng quét QR là hướng đúng và mình đã chừa chỗ để nối ở prompt sau."
                               FontSize="13"
                               TextColor="#1C4748" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFFDFC"
                    Stroke="#E4D8CC"
                    StrokeThickness="1"
                    Padding="20"
                    StrokeShape="RoundRectangle 30">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding WelcomeTitle}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#1B2A2F" />

                        <Label Text="{Binding WelcomeSubtitle}"
                               FontSize="13"
                               TextColor="#67757A" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">
                        <Border Padding="16,14"
                                BackgroundColor="#F5EBDD"
                                Stroke="#E4D5C4"
                                StrokeThickness="1"
                                HeightRequest="88"
                                StrokeShape="RoundRectangle 22">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="B1"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#A96A45" />
                                <Label Text="Mở app"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1C4748" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                Padding="16,14"
                                BackgroundColor="#F5EBDD"
                                Stroke="#E4D5C4"
                                StrokeThickness="1"
                                HeightRequest="88"
                                StrokeShape="RoundRectangle 22">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="B2"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#A96A45" />
                                <Label Text="Bấm vào nhanh"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1C4748" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="16,14"
                                BackgroundColor="#F5EBDD"
                                Stroke="#E4D5C4"
                                StrokeThickness="1"
                                HeightRequest="88"
                                WidthRequest="172"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 22">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="B3"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#A96A45" />
                                <Label Text="Chọn box để nghe"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#1C4748" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Border BackgroundColor="#FDEEEE"
                            Stroke="#E4B6B0"
                            StrokeThickness="1"
                            Padding="14,12"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasErrorMessage}">
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="13"
                               TextColor="#A53A32" />
                    </Border>

                    <Button Text="{Binding EnterAppButtonText}"
                            Command="{Binding EnterAppCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#C6672F"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="18"
                            HeightRequest="54" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#215C57" />

                    <Label Text="{Binding WelcomeHint}"
                           FontSize="12"
                           TextColor="#6C7A7F" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
