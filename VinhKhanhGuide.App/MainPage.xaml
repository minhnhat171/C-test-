<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
    x:Class="VinhKhanhGuide.App.MainPage"
    BackgroundColor="#FBF8F4"
    Shell.NavBarIsVisible="False">

    <Grid x:Name="RootLayout"
          RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,28,20,18" Spacing="22">

                <Label Text="VinhKhanh"
                       HorizontalTextAlignment="Center"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#191919" />

                <Border StrokeThickness="0"
                        BackgroundColor="#FFF2E7"
                        Padding="18"
                        StrokeShape="RoundRectangle 26">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding CurrentUserDisplayName, StringFormat='Xin chào, {0}'}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label Text="{Binding CurrentUserStatusLine}"
                                   FontSize="13"
                                   TextColor="#9A3412" />

                            <Label Text="Bạn đang ở chế độ khách tham quan. Giờ có thể nghe Talk to Speech ngay trên từng box quán ở trang chủ hoặc bật GPS để nghe theo vị trí."
                                   FontSize="13"
                                   TextColor="#7C2D12" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="10"
                                             HorizontalOptions="End">
                            <Border BackgroundColor="#111111"
                                    StrokeThickness="0"
                                    WidthRequest="46"
                                    HeightRequest="46"
                                    StrokeShape="RoundRectangle 23">
                                <Label Text="{Binding CurrentUserInitials}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <Button Text="Về màn chào"
                                    Command="{Binding SignOutCommand}"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#111111"
                                    FontSize="12"
                                    CornerRadius="16"
                                    Padding="12,6" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Label Text="Vị trí của bạn"
                           FontSize="18"
                           TextColor="#5D5D5D"
                           VerticalTextAlignment="Center" />

                    <Button Text="🔔"
                            Clicked="OnTopBellClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#101010"
                            WidthRequest="46"
                            HeightRequest="46"
                            CornerRadius="23" />
                </Grid>

                <Border StrokeThickness="0"
                        BackgroundColor="#FFFFFF"
                        Padding="0"
                        StrokeShape="RoundRectangle 28">
                    <Grid>
                        <mapsui:MapView x:Name="RestaurantMap"
                                        HeightRequest="188"
                                        IsZoomButtonVisible="False"
                                        IsNorthingButtonVisible="False"
                                        IsMyLocationButtonVisible="False"
                                        RotationLock="True" />

                        <VerticalStackLayout Spacing="8"
                                             HorizontalOptions="Start"
                                             VerticalOptions="Start"
                                             Margin="14,14,0,0">
                            <Border BackgroundColor="#FFFFFF"
                                    StrokeThickness="0"
                                    Padding="12,6"
                                    StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding MapModeBadgeText}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#1B2A2F" />
                            </Border>

                            <Border BackgroundColor="#F6EFE5"
                                    StrokeThickness="0"
                                    Padding="12,6"
                                    StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding MapPoiBadgeText}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#7A4D2D" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8"
                                             HorizontalOptions="End"
                                             VerticalOptions="End"
                                             Margin="0,0,14,14">
                            <Button Text="+"
                                    Clicked="OnZoomInClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#111111"
                                    FontSize="22"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    CornerRadius="21" />

                            <Button Text="-"
                                    Clicked="OnZoomOutClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#111111"
                                    FontSize="22"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    CornerRadius="21" />

                            <Button Text="◎"
                                    Clicked="OnCenterCurrentLocationClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#111111"
                                    FontSize="20"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    CornerRadius="21" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding StatusText}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#1B1B1B" />
                    <Label Text="{Binding LocationText}"
                           FontSize="12"
                           TextColor="#666666" />
                    <Label Text="{Binding NearestPoiText}"
                           FontSize="12"
                           TextColor="#666666" />

                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Button Text="Bật GPS"
                                Command="{Binding StartTrackingCommand}"
                                BackgroundColor="#111111"
                                TextColor="White"
                                CornerRadius="18"
                                Padding="16,8" />

                        <Button Text="Tắt GPS"
                                Command="{Binding StopTrackingCommand}"
                                BackgroundColor="#EDE9E3"
                                TextColor="#222222"
                                CornerRadius="18"
                                Padding="16,8" />

                        <Button Grid.Column="2"
                                Text="{Binding AudioSettingsQuickActionText}"
                                Clicked="OnOpenAudioSettingsClicked"
                                BackgroundColor="#FFFFFF"
                                TextColor="#173A43"
                                FontAttributes="Bold"
                                CornerRadius="18"
                                Padding="14,8" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Gói tour"
                                   FontSize="18"
                                   TextColor="#5D5D5D" />

                            <Label Text="{Binding TourSectionSummary}"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="Dừng tour"
                                Clicked="OnStopActiveTourClicked"
                                BackgroundColor="#FFFFFF"
                                TextColor="#173A43"
                                FontAttributes="Bold"
                                CornerRadius="18"
                                Padding="16,8"
                                IsVisible="{Binding HasActiveTour}" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding TourPackages}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnTourSelectionChanged"
                                    HeightRequest="210"
                                    IsVisible="{Binding HasTours}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#FFFFFF"
                                        StrokeThickness="0"
                                        Padding="14"
                                        WidthRequest="290"
                                        StrokeShape="RoundRectangle 22">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#173A43"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Code}"
                                                       FontSize="11"
                                                       TextColor="#64748B" />
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="#F6EFE5"
                                                    StrokeThickness="0"
                                                    Padding="8,4"
                                                    VerticalOptions="Start"
                                                    StrokeShape="RoundRectangle 12">
                                                <Label Text="{Binding StatusLabel}"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="#9A3412" />
                                            </Border>
                                        </Grid>

                                        <Label Text="{Binding Description}"
                                               FontSize="12"
                                               TextColor="#475569"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="3" />

                                        <Border BackgroundColor="#FFF8F1"
                                                StrokeThickness="0"
                                                Padding="12"
                                                StrokeShape="RoundRectangle 16">
                                            <VerticalStackLayout Spacing="6">
                                                <Label Text="{Binding MetaLabel}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#9A3412" />
                                                <Label Text="{Binding StopsSummary}"
                                                       FontSize="12"
                                                       TextColor="#334155"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="3" />
                                            </VerticalStackLayout>
                                        </Border>

                                        <Border BackgroundColor="#173A43"
                                                StrokeThickness="0"
                                                Padding="10,8"
                                                StrokeShape="RoundRectangle 14">
                                            <Label Text="{Binding ActionLabel}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   TextColor="#F8FAFC" />
                                        </Border>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Border BackgroundColor="#FFF7ED"
                            StrokeThickness="0"
                            Padding="16"
                            StrokeShape="RoundRectangle 24"
                            IsVisible="{Binding HasActiveTour}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding ActiveTourName}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#7C2D12" />
                                    <Label Text="{Binding ActiveTourSummary}"
                                           FontSize="12"
                                           TextColor="#9A3412"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#FFFFFF"
                                        StrokeThickness="0"
                                        Padding="10,6"
                                        VerticalOptions="Start"
                                        StrokeShape="RoundRectangle 14">
                                    <Label Text="Tour đang chạy"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#173A43" />
                                </Border>
                            </Grid>

                            <Border BackgroundColor="#FFFFFF"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding ActiveTourCurrentStopText}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#173A43" />
                                    <Label Text="{Binding ActiveTourNextStopText}"
                                           FontSize="12"
                                           TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Border>

                            <CollectionView ItemsSource="{Binding ActiveTourStops}"
                                            SelectionMode="None"
                                            HeightRequest="180"
                                            IsVisible="{Binding HasActiveTourStops}">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                       ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#FFFFFF"
                                                StrokeThickness="0"
                                                Padding="12"
                                                StrokeShape="RoundRectangle 18">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <Border BackgroundColor="#173A43"
                                                        StrokeThickness="0"
                                                        WidthRequest="34"
                                                        HeightRequest="34"
                                                        StrokeShape="RoundRectangle 17">
                                                    <Label Text="{Binding Order}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           TextColor="#F8FAFC" />
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="3">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="#173A43" />
                                                    <Label Text="{Binding Address}"
                                                           FontSize="11"
                                                           TextColor="#64748B"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding StatusLabel}"
                                                           FontSize="11"
                                                           TextColor="#9A3412" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Món nổi bật"
                           FontSize="18"
                           TextColor="#5D5D5D" />

                    <CollectionView ItemsSource="{Binding FeaturedDishes}"
                                    SelectionMode="None"
                                    HeightRequest="110">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="18" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout WidthRequest="80" Spacing="10">
                                    <Border BackgroundColor="#FFF7EB"
                                            StrokeThickness="0"
                                            WidthRequest="72"
                                            HeightRequest="72"
                                            Padding="0"
                                            StrokeShape="RoundRectangle 36">
                                        <Label Text="{Binding Icon}"
                                               FontSize="32"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                    <Label Text="{Binding Name}"
                                           HorizontalTextAlignment="Center"
                                           FontSize="14"
                                           TextColor="#2A2A2A" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <Border BackgroundColor="#173A43"
                        StrokeThickness="0"
                        Padding="18"
                        StrokeShape="RoundRectangle 26">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Talk to Speech tại trang chủ"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#FFF9F2" />

                                <Label Text="{Binding HomeNarrationSummary}"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       TextColor="#D9EEE7" />
                            </VerticalStackLayout>

                            <Border Grid.Column="1"
                                    BackgroundColor="#FDE7D7"
                                    StrokeThickness="0"
                                    Padding="12,8"
                                    VerticalOptions="Start"
                                    StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding AudioSettingsSummary}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="#F7E9D8"
                                    StrokeThickness="0"
                                    Padding="12,10"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="B1"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#A16207" />
                                    <Label Text="Vào app"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#173A43" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#F7E9D8"
                                    StrokeThickness="0"
                                    Padding="12,10"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="B2"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#A16207" />
                                    <Label Text="Chọn box quán"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#173A43" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2"
                                    BackgroundColor="#F7E9D8"
                                    StrokeThickness="0"
                                    Padding="12,10"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="B3"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#A16207" />
                                    <Label Text="Nghe thuyết minh"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#173A43" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="#214A53"
                                StrokeThickness="0"
                                Padding="14,12"
                                StrokeShape="RoundRectangle 18">
                            <Label Text="{Binding HomeNarrationAvailabilityText}"
                                   FontSize="12"
                                   TextColor="#E8F6F2" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Danh sách quán"
                           FontSize="18"
                           TextColor="#5D5D5D" />

                    <Label Text="Mỗi quán là một box thông tin riêng. Bạn có thể nghe giới thiệu trực tiếp ngay tại đây mà không cần rời trang chủ."
                           FontSize="13"
                           TextColor="#6B7280" />
                </VerticalStackLayout>

                <Label Text="{Binding SearchResultStatusText}"
                       FontSize="13"
                       TextColor="#8A8A8A"
                       IsVisible="{Binding IsSearchResultEmpty}" />

                <CollectionView ItemsSource="{Binding FilteredPoiStatuses}"
                                SelectionMode="Single"
                                SelectionChanged="OnPoiSelectionChanged">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="18" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#FFFFFF"
                                    StrokeThickness="0"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="112,*"
                                          ColumnSpacing="14">
                                        <Border BackgroundColor="#F5F1EA"
                                                StrokeThickness="0"
                                                HeightRequest="112"
                                                StrokeShape="RoundRectangle 16">
                                            <Image Source="{Binding ImageSource}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#242424"
                                                       LineBreakMode="TailTruncation" />

                                                <Border Grid.Column="1"
                                                        BackgroundColor="#173A43"
                                                        StrokeThickness="0"
                                                        Padding="8,4"
                                                        StrokeShape="RoundRectangle 12"
                                                        IsVisible="{Binding IsNarrationActive}">
                                                    <Label Text="Đang phát"
                                                           FontSize="10"
                                                           TextColor="White" />
                                                </Border>
                                            </Grid>

                                            <Label Text="{Binding Address}"
                                                   FontSize="12"
                                                   TextColor="#6B7280"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />

                                            <Border BackgroundColor="#E0F2FE"
                                                    StrokeThickness="0"
                                                    Padding="8,4"
                                                    HorizontalOptions="Start"
                                                    StrokeShape="RoundRectangle 12"
                                                    IsVisible="{Binding HasTourBadge}">
                                                <Label Text="{Binding TourBadgeText}"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="#0F766E" />
                                            </Border>

                                            <Label Text="{Binding DistanceLabel}"
                                                   FontSize="12"
                                                   TextColor="#9A3412"
                                                   MaxLines="2" />

                                            <Label Text="{Binding SpecialDishLabel}"
                                                   FontSize="12"
                                                   TextColor="#374151"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="#404040"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="3" />

                                    <Border BackgroundColor="#FFF8F1"
                                            StrokeThickness="0"
                                            Padding="12"
                                            StrokeShape="RoundRectangle 16"
                                            IsVisible="{Binding HasNarrationPreview}">
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="Xem trước nội dung TTS"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#9A3412" />

                                            <Label Text="{Binding NarrationPreview}"
                                                   FontSize="12"
                                                   TextColor="#4B5563"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="3" />

                                            <Label Text="{Binding NarrationGuideText}"
                                                   FontSize="11"
                                                   TextColor="#7C2D12" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Grid ColumnDefinitions="*"
                                          ColumnSpacing="10">
                                        <Button Text="{Binding NarrationActionText}"
                                                Clicked="OnPoiNarrationClicked"
                                                BackgroundColor="#FFF2E7"
                                                TextColor="#9A3412"
                                                CornerRadius="16"
                                                Padding="14,10">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsNarrationActive}"
                                                             Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#173A43" />
                                                    <Setter Property="TextColor"
                                                            Value="White" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Border BackgroundColor="#FFFFFF"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="0,6,0,0"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="12">
                        <Image Source="{Binding SelectedPoiImageSource}"
                               HeightRequest="180"
                               Aspect="AspectFill" />

                        <Label Text="{Binding SelectedPoiName}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#161616" />

                        <Label Text="{Binding SelectedPoiAddress}"
                               FontSize="13"
                               TextColor="#666666" />

                        <Label Text="{Binding SelectedPoiStatusText}"
                               FontSize="12"
                               TextColor="#666666" />

                        <Label Text="{Binding SelectedPoiDescription}"
                               FontSize="14"
                               TextColor="#303030"
                               LineBreakMode="WordWrap" />

                        <Label Text="{Binding SelectedPoiDishText}"
                               FontSize="13"
                               TextColor="#9A3412" />

                        <Label Text="Nội dung phát hiện tại"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#111111" />

                        <Label Text="{Binding SelectedPoiNarrationPreview}"
                               FontSize="13"
                               TextColor="#404040" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Text="{Binding SelectedPoiNarrationActionText}"
                                    Clicked="OnNarrateSelectedClicked"
                                    BackgroundColor="#111111"
                                    TextColor="White"
                                    CornerRadius="18"
                                    Padding="16,10" />

                            <Button Grid.Column="1"
                                    Text="Chỉ đường"
                                    Clicked="OnOpenMapClicked"
                                    BackgroundColor="#F2ECE4"
                                    TextColor="#202020"
                                    CornerRadius="18"
                                    Padding="16,10" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="0,6,0,0"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Lịch sử sử dụng"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#161616" />

                                <Label Text="{Binding EventLogSummary}"
                                       FontSize="12"
                                       TextColor="#6B7280" />
                            </VerticalStackLayout>

                            <Button Text="Xóa"
                                    Command="{Binding ClearEventLogsCommand}"
                                    IsEnabled="{Binding HasEventLogs}"
                                    BackgroundColor="#FFF2E7"
                                    TextColor="#9A3412"
                                    CornerRadius="16"
                                    Padding="12,8" />
                        </Grid>

                        <Label Text="Lịch sử sẽ hiện khi bạn bật GPS, nghe thuyết minh, chạm bản đồ hoặc thao tác trong app."
                               FontSize="13"
                               TextColor="#6B7280"
                               IsVisible="{Binding IsEventLogEmpty}" />

                        <VerticalStackLayout Spacing="10"
                                             BindableLayout.ItemsSource="{Binding EventLogs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FFF8F1"
                                            StrokeThickness="0"
                                            Padding="14,12"
                                            StrokeShape="RoundRectangle 18">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10">
                                            <Label Text="•"
                                                   FontSize="18"
                                                   TextColor="#EA580C"
                                                   VerticalTextAlignment="Start" />

                                            <Label Grid.Column="1"
                                                   Text="{Binding .}"
                                                   FontSize="13"
                                                   TextColor="#374151"
                                                   LineBreakMode="WordWrap" />
