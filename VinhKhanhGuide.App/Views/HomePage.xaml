<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="VinhKhanhGuide.App.Views.HomePage">

    <ScrollView>
        <VerticalStackLayout Padding="10">

            <Label Text="Your Location"
                   FontSize="24"
                   FontAttributes="Bold"/>

            <WebView x:Name="MyWebView"
                     HeightRequest="400"/>

            <Label Text="Món đặc trưng"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding Foods}"
                            ItemsLayout="HorizontalList">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout WidthRequest="100">
                            <Image Source="{Binding Image}"
                                   HeightRequest="80"/>
                            <Label Text="{Binding Name}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Tên nhà hàng"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding Restaurants}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="5">
                            <VerticalStackLayout>
                                <Image Source="{Binding Image}"
                                       HeightRequest="120"/>
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Address}"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>