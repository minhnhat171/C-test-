<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.PoiDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Chi tiết địa điểm"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,28"
                             Spacing="18">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#2F80FF" Offset="0" />
                        <GradientStop Color="#6AA8FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="0">
                    <Image Source="{Binding SelectedPoiImageSource}"
                           HeightRequest="250"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Padding="20"
                                         Spacing="8">
                        <Label Text="{Binding SelectedPoiName}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White" />

                        <Label Text="{Binding SelectedPoiAddress}"
                               FontSize="15"
                               TextColor="#EAF3FF" />

                        <Border BackgroundColor="#FFFFFF"
                                Padding="12,8"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                            <Label Text="{Binding SelectedPoiStatusText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#2F80FF" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Mô tả quán"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Label Text="{Binding SelectedPoiDescription}"
                           FontSize="16"
                           TextColor="#486581"
                           LineBreakMode="WordWrap" />

                    <Border BackgroundColor="#F4F8FF"
                            Padding="14"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasSelectedPoiDish}">
                        <Label Text="{Binding SelectedPoiDishText}"
                               FontSize="15"
                               TextColor="#2F80FF" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Thuyết minh"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Label Text="{Binding SelectedPoiNarrationPreview}"
                           FontSize="16"
                           TextColor="#486581"
                           LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Button Text="{Binding SelectedPoiNarrationActionText}"
                                Clicked="OnNarrateSelectedClicked"
                                BackgroundColor="#2F80FF"
                                TextColor="White"
                                FontSize="16"
                                CornerRadius="18"
                                HeightRequest="50" />

                        <Button Grid.Column="1"
                                Text="Chỉ đường"
                                Clicked="OnOpenMapClicked"
                                BackgroundColor="#E8F1FF"
                                TextColor="#2F80FF"
                                FontSize="16"
                                CornerRadius="18"
                                HeightRequest="50" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
