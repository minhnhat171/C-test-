@model PoiEditorViewModel
@{
    var imagePreviewSource = !string.IsNullOrWhiteSpace(Model.ImageSource) &&
        (Model.ImageSource.StartsWith("/", StringComparison.Ordinal) ||
         Model.ImageSource.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
         Model.ImageSource.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            ? Model.ImageSource
            : string.Empty;
}
@{
    ViewData["Title"] = "Chi tiết POI";
}

<style>
    .poi-details {
        --poi-muted: #64748b;
        --poi-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    }

    .poi-detail-shell {
        background: rgba(255,255,255,0.96);
        border-radius: 28px;
        box-shadow: var(--poi-shadow);
        padding: 1.5rem;
    }

    .poi-detail-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .poi-detail-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .poi-detail-subtitle {
        margin-top: 0.4rem;
        color: var(--poi-muted);
    }

    .poi-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .poi-detail-card {
        border-radius: 24px;
        padding: 1.15rem;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.16);
    }

    .poi-detail-grid .poi-detail-card:nth-child(5) {
        display: none;
    }

    .poi-detail-label {
        color: var(--poi-muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .poi-detail-value {
        margin-top: 0.45rem;
        font-size: 1.08rem;
        font-weight: 700;
    }

    .poi-detail-script {
        white-space: pre-wrap;
        line-height: 1.7;
        color: #1e293b;
    }

    .poi-detail-image {
        width: 100%;
        max-height: 320px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 1rem;
        background: #e2e8f0;
    }

    @@media (max-width: 991.98px) {
        .poi-detail-grid {
            grid-template-columns: 1fr;
        }

        .poi-detail-head {
            flex-direction: column;
        }
    }
</style>

<div class="poi-details">
    <div class="poi-detail-shell">
        <div class="poi-detail-head">
            <div>
                <h1>@Model.Name</h1>
                <div class="poi-detail-subtitle">@Model.Address</div>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="MapPois" asp-action="Index" asp-route-poiId="@Model.Id" class="btn btn-outline-dark rounded-pill px-4">Map Analytics</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill px-4">Sửa</a>
                <a asp-controller="QrCodes" asp-action="Index" asp-route-selectedTargetType="poi" asp-route-selectedTargetId="@Model.Id" class="btn btn-outline-success rounded-pill px-4">Tạo QR</a>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Quay lại</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(imagePreviewSource))
        {
            <img class="poi-detail-image" src="@imagePreviewSource" alt="Anh minh hoa POI" />
        }

        <div class="poi-detail-grid">
            <div class="poi-detail-card">
                <div class="poi-detail-label">Thông tin cơ bản</div>
                <div class="poi-detail-value">@Model.Description</div>
            </div>
            <div class="poi-detail-card">
                <div class="poi-detail-label">Vị trí</div>
                <div class="poi-detail-value">@Model.Latitude, @Model.Longitude</div>
            </div>
            <div class="poi-detail-card">
                <div class="poi-detail-label">Geofence</div>
                <div class="poi-detail-value">Bán kính @Model.RadiusInMeters m, ưu tiên #@Model.Priority</div>
            </div>
            <div class="poi-detail-card">
                <div class="poi-detail-label">Tình trạng</div>
                <div class="poi-detail-value">@(Model.IsActive ? "Đang hoạt động" : "Tạm khóa")</div>
            </div>
            <div class="poi-detail-card">
                <div class="poi-detail-label">Audio liên quan</div>
                <div class="poi-detail-value">@Model.RelatedAudioCount bản ghi</div>
            </div>
            <div class="poi-detail-card">
                <div class="poi-detail-label">Map Analytics</div>
                <div class="poi-detail-value">@(string.IsNullOrWhiteSpace(Model.MapLink) ? "Chưa có liên kết bản đồ" : "Sẵn sàng mở từ web quản lý")</div>
            </div>
        </div>

        <div class="poi-detail-card mb-3">
            <div class="poi-detail-label">Narration script</div>
            <div class="poi-detail-value poi-detail-script">@Model.NarrationScript</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.MapLink))
        {
            <a href="@Model.MapLink" target="_blank" class="btn btn-outline-primary rounded-pill px-4">Mở bản đồ</a>
        }
    </div>
</div>
