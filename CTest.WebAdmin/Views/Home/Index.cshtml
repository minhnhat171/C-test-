@model DashboardViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl-2"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">POI</div><div class="display-6">@Model.TotalPois</div></div></div></div>
    <div class="col-md-4 col-xl-2 d-none"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">Audio</div><div class="display-6">@Model.TotalAudioGuides</div></div></div></div>
    <div class="col-md-4 col-xl-2"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">Map Analytics</div><div class="display-6">@Model.MappedPoiCount</div></div></div></div>
    <div class="col-md-4 col-xl-2"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">Tour</div><div class="display-6">@Model.TotalTours</div></div></div></div>
    <div class="col-md-4 col-xl-2"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">Lịch sử sử dụng</div><div class="display-6">@Model.TotalUsageLogs</div></div></div></div>
    <div class="col-md-4 col-xl-2"><div class="card shadow-sm stat-card"><div class="card-body"><div class="text-muted">Nghe nhiều nhất</div><div class="fw-bold fs-5">@Model.MostPlayedPoi</div></div></div></div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Luồng nghiệp vụ theo tài liệu</div>
            <div class="card-body">
                <ol class="mb-0">
                    <li>App tải danh sách POI gồm tọa độ, bán kính, ưu tiên và nội dung thuyết minh.</li>
                    <li>Background service cập nhật vị trí người dùng theo GPS.</li>
                    <li>Geofence Engine xác định POI gần nhất hoặc ưu tiên cao nhất.</li>
                    <li>Narration Engine quyết định phát TTS hay file audio, tránh phát lặp.</li>
                    <li>Hệ thống lưu lịch sử sử dụng để phục vụ analytics và heatmap.</li>
                    <li>QR code dùng tại điểm dừng để nghe ngay mà không cần GPS.</li>
                </ol>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white fw-semibold">Phân tích nhanh</div>
            <div class="card-body">
                <p><strong>Thời gian nghe trung bình:</strong> @Model.AverageListenSeconds.ToString("0.0") giây</p>
                <p><strong>Mục tiêu dashboard:</strong> theo dõi top địa điểm, lịch sử sử dụng audio, tour và nhật ký QR/GPS.</p>
                <div class="alert alert-info mb-0">Bản này dùng dữ liệu mẫu trong bộ nhớ để bạn dễ chạy trước. Khi cần mình có thể nâng tiếp sang Entity Framework Core + SQL Server hoặc SQLite.</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-white fw-semibold">Lịch sử sử dụng nghe gần đây</div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Mã người dùng</th>
                    <th>POI</th>
                    <th>Kích hoạt</th>
                    <th>Ngôn ngữ</th>
                    <th>Thời gian nghe</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.RecentLogs)
            {
                <tr>
                    <td>@item.UserCode</td>
                    <td>@item.PoiName</td>
                    <td>@item.TriggerType</td>
                    <td>@item.Language</td>
                    <td>@item.ListenSeconds giây</td>
                    <td>
                        @if (item.Completed)
                        {
                            <span class="badge text-bg-success">Hoàn tất</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Đang nghe</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
