<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
    x:Name="MainRootPage"
    x:Class="VinhKhanhGuide.App.Views.MainPage"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView x:Name="MainScrollView"
                    Grid.Row="0">
            <VerticalStackLayout Padding="16,18,16,14"
                                 Spacing="14">
                <Border BackgroundColor="#FFFFFF"
                        Padding="14"
                        Stroke="#D9E6F7"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Vinh Khanh Guide"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#2F80FF" />

                                <Label Text="{Binding GreetingText}"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />

                                <Label Text="{Binding HomeIntroText}"
                                       FontSize="13"
                                       TextColor="#486581"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding CurrentUserInitials}"
                                    Clicked="OnOpenAccountPageClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#2F80FF"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    WidthRequest="48"
                                    HeightRequest="48"
                                    CornerRadius="24"
                                    Padding="0" />
                        </Grid>

                        <Border BackgroundColor="#F6FAFF"
                                Stroke="#E3EEFB"
                                StrokeThickness="1"
                                Padding="12"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#102A43" />
                                    <Label Text="{Binding LocationText}"
                                           FontSize="12"
                                           TextColor="#4F7096" />
                                    <Label Text="{Binding NearestPoiText}"
                                           FontSize="12"
                                           TextColor="#4F7096"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#E8F1FF"
                                        StrokeThickness="0"
                                        Padding="10,6"
                                        VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding MapModeBadgeText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#2F80FF" />
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding HomeQuickActionsTitle}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,*"
                          RowSpacing="10"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#102A43"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTourShortcutTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">
                                <Image Source="tour_route_icon.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Start"
                                       Aspect="AspectFit" />
                                <Label Text="{Binding HomeTourActionTitle}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding HomeTourActionText}"
                                       FontSize="12"
                                       TextColor="#DCEBFF"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#FFFFFF"
                                Padding="14"
                                Stroke="#D9E6F7"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenFullScreenMapTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">
                                <Image Source="map_nav_icon.svg"
                                       HeightRequest="28"
                                       WidthRequest="28"
                                       HorizontalOptions="Start"
                                       Aspect="AspectFit" />
                                <Label Text="{Binding HomeMapActionTitle}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding HomeMapActionText}"
                                       FontSize="12"
                                       TextColor="#486581"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                BackgroundColor="#EAF3FF"
                                Padding="12"
                                Stroke="#CFE2FF"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="10">
                                <Image Source="qr_scan_icon.svg"
                                       HeightRequest="34"
                                       WidthRequest="34"
                                       VerticalOptions="Center"
                                       Aspect="AspectFit" />

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding HomeQrActionTitle}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#102A43"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding HomeQrActionText}"
                                           FontSize="12"
                                           TextColor="#486581"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2" />
                                </VerticalStackLayout>

                                <Button Grid.Column="2"
                                        Text="{Binding HomeQrCtaText}"
                                        Clicked="OnOpenQrScannerClicked"
                                        BackgroundColor="#2F80FF"
                                        TextColor="White"
                                        FontSize="12"
                                        CornerRadius="12"
                                        Padding="10,7"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding SearchSectionTitle}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Border BackgroundColor="#FFFFFF"
                            Padding="18,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <Image Source="search_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit"
                                   VerticalOptions="Center" />

                            <Entry x:Name="RestaurantSearchEntry"
                                   Grid.Column="1"
                                   Text="{Binding SearchQuery}"
                                   Placeholder="{Binding SearchPlaceholderText}"
                                   Completed="OnSearchCompleted"
                                   Focused="OnSearchFocused"
                                   Unfocused="OnSearchUnfocused"
                                   ReturnType="Search"
                                   BackgroundColor="Transparent"
                                   FontSize="17"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD"
                                   VerticalTextAlignment="Center" />

                            <ImageButton Grid.Column="2"
                                         Source="close_icon.svg"
                                         Clicked="OnClearSearchClicked"
                                         IsVisible="{Binding HasSearchQuery}"
                                         BackgroundColor="#E8F1FF"
                                         WidthRequest="34"
                                         HeightRequest="34"
                                         CornerRadius="17"
                                         Padding="8"
                                         Aspect="AspectFit"
                                         VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            IsVisible="{Binding HasSearchPreviewResults}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Label Text="{Binding SearchPreviewSummaryText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Button Grid.Column="1"
                                        Text="{Binding SearchPreviewOpenAllText}"
                                        Clicked="OnOpenPoiBrowsePageClicked"
                                        BackgroundColor="#E8F1FF"
                                        TextColor="#2F80FF"
                                        FontSize="13"
                                        CornerRadius="16"
                                        Padding="12,8" />
                            </Grid>

                            <VerticalStackLayout Spacing="8"
                                                 BindableLayout.ItemsSource="{Binding SearchPreviewItems}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F8FBFF"
                                                Padding="14"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="10">
                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="#102A43" />
                                                        <Label Text="{Binding Address}"
                                                               FontSize="13"
                                                               TextColor="#6B7C93"
                                                               LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DistanceLabel}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#2F80FF"
                                                           VerticalOptions="Center" />
                                                </Grid>

                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="10">
                                                    <Button Text="{Binding Source={x:Reference MainRootPage}, Path=BindingContext.SelectedPoiDetailButtonText}"
                                                            Clicked="OnSearchPreviewDetailClicked"
                                                            BackgroundColor="#E8F1FF"
                                                            TextColor="#2F80FF"
                                                            FontSize="14"
                                                            CornerRadius="16" />

                                                    <Button Grid.Column="1"
                                                            Text="{Binding NarrationActionText}"
                                                            Clicked="OnSearchPreviewNarrationClicked"
                                                            BackgroundColor="#2F80FF"
                                                            TextColor="White"
                                                            FontSize="14"
                                                            CornerRadius="16" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            IsVisible="{Binding IsSearchSuggestionsVisible}">
                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding SearchSuggestions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FBFF"
                                            Padding="12,10"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSearchSuggestionTapped" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10">
                                            <Image Source="{Binding LeadingIconSource}"
                                                   HeightRequest="20"
                                                   WidthRequest="20"
                                                   Aspect="AspectFit"
                                                   VerticalOptions="Center" />

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="{Binding Text}"
                                                       FontSize="15"
                                                       TextColor="#102A43" />
                                                <Label Text="{Binding SupportingText}"
                                                       FontSize="13"
                                                       TextColor="#6B7C93"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding SearchResultStatusText}"
                           FontSize="14"
                           TextColor="#7B8BA3"
                           IsVisible="{Binding IsSearchResultEmpty}" />
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Padding="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 18">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="18,18,18,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding MapSectionTitle}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Label Text="{Binding MapPoiBadgeText}"
                                       FontSize="14"
                                       TextColor="#6B7C93" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding MapOpenLargeText}"
                                    Clicked="OnOpenFullScreenMapClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="16"
                                    Padding="14,8" />
                        </Grid>

                        <Border BackgroundColor="#F4F8FF"
                                Margin="18,0,18,12"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasMapCategoryFilter}">
                            <Label Text="{Binding ActiveMapCategoryFilterText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#2F80FF" />
                        </Border>

                        <Grid>
                            <mapsui:MapView x:Name="RestaurantMap"
                                            HeightRequest="240"
                                            IsZoomButtonVisible="False"
                                            IsNorthingButtonVisible="False"
                                            IsMyLocationButtonVisible="False"
                                            RotationLock="True" />

                            <VerticalStackLayout Spacing="8"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="End"
                                                 Margin="0,0,14,14">
                                <ImageButton Source="zoom_in_icon.svg"
                                             Clicked="OnZoomInClicked"
                                             BackgroundColor="#FFFFFF"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             CornerRadius="20"
                                             Padding="9"
                                             Aspect="AspectFit" />

                                <ImageButton Source="zoom_out_icon.svg"
                                             Clicked="OnZoomOutClicked"
                                             BackgroundColor="#FFFFFF"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             CornerRadius="20"
                                             Padding="9"
                                             Aspect="AspectFit" />

                                <ImageButton Source="locate_control_icon.svg"
                                             Clicked="OnCenterCurrentLocationClicked"
                                             Aspect="AspectFit"
                                             Padding="10"
                                        BackgroundColor="#FFFFFF"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             CornerRadius="20" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid Padding="18,14,18,18"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Text="{Binding StartGpsButtonText}"
                                    Clicked="OnStartTrackingClicked"
                                    IsEnabled="{Binding CanStartTracking}"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="{Binding StopGpsButtonText}"
                                    Clicked="OnStopTrackingClicked"
                                    IsEnabled="{Binding IsTracking}"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="2"
                                    Text="{Binding GoToEntranceButtonText}"
                                    Clicked="OnGpsOriginClicked"
                                    BackgroundColor="#102A43"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFF7ED"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasOfflineSnapshotNotice}">
                    <Label Text="{Binding OfflineSnapshotNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#9A3412"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#EEF7FF"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasManualLocationNotice}">
                    <Label Text="{Binding ManualLocationNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#1D4ED8"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#F8FAFC"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasNoTourNotice}">
                    <Label Text="{Binding NoTourNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#475569"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#102A43"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding TourSectionTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="{Binding TourSectionSummary}"
                               FontSize="14"
                               TextColor="#DCEBFF"
                               LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Button Text="{Binding HomePrimaryCtaText}"
                                    Clicked="OnOpenTourPageClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#102A43"
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    CornerRadius="18"
                                    HeightRequest="50" />

                            <Button Grid.Column="1"
                                    Text="{Binding StopTourButtonText}"
                                    Clicked="OnStopActiveTourClicked"
                                    BackgroundColor="#FFE7E1"
                                    TextColor="#B42318"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    CornerRadius="18"
                                    Padding="16,0"
                                    HeightRequest="50"
                                    IsVisible="{Binding HasActiveTour}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding FeaturedSectionTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Grid ColumnDefinitions="*,*,*,*"
                          ColumnSpacing="8"
                          HeightRequest="76"
                          VerticalOptions="Start">
                        <Border Grid.Column="0"
                                BindingContext="{Binding FeaturedDishes[0]}"
                                BackgroundColor="{Binding BackgroundColor}"
                                Padding="6"
                                HeightRequest="76"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFeaturedDishCategoryTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="4"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Border BackgroundColor="White"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Icon}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           FontSize="16" />
                                </Border>

                                <Label Text="{Binding Name}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BindingContext="{Binding FeaturedDishes[1]}"
                                BackgroundColor="{Binding BackgroundColor}"
                                Padding="6"
                                HeightRequest="76"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFeaturedDishCategoryTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="4"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Border BackgroundColor="White"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Icon}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           FontSize="16" />
                                </Border>

                                <Label Text="{Binding Name}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                BindingContext="{Binding FeaturedDishes[2]}"
                                BackgroundColor="{Binding BackgroundColor}"
                                Padding="6"
                                HeightRequest="76"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFeaturedDishCategoryTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="4"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Border BackgroundColor="White"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Icon}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           FontSize="16" />
                                </Border>

                                <Label Text="{Binding Name}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="3"
                                BindingContext="{Binding FeaturedDishes[3]}"
                                BackgroundColor="{Binding BackgroundColor}"
                                Padding="6"
                                HeightRequest="76"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFeaturedDishCategoryTapped" />
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="4"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center">
                                <Border BackgroundColor="White"
                                        WidthRequest="34"
                                        HeightRequest="34"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Icon}"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           FontSize="16" />
                                </Border>

                                <Label Text="{Binding Name}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Label Text="{Binding SelectedPoiSectionTitle}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Button Grid.Column="1"
                                    Text="{Binding PoiBrowseOpenPageText}"
                                    Clicked="OnOpenPoiBrowsePageClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="14"
                                    CornerRadius="16"
                                    Padding="12,8" />
                        </Grid>

                        <Grid ColumnDefinitions="88,*"
                              ColumnSpacing="12">
                            <Border BackgroundColor="#E8F1FF"
                                    HeightRequest="88"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16">
                                <Image Source="{Binding SelectedPoiImageSource}"
                                       Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="{Binding SelectedPoiName}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Text="{Binding SelectedPoiAddress}"
                                       FontSize="13"
                                       TextColor="#6B7C93"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Text="{Binding SelectedPoiStatusText}"
                                       FontSize="13"
                                       TextColor="#4F7096"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Text="{Binding SelectedPoiNarrationStateText}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#2F80FF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <Button Text="{Binding SelectedPoiNarrationActionText}"
                                    Clicked="OnNarrateSelectedClicked"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="16"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="{Binding SelectedPoiDetailButtonText}"
                                    Clicked="OnOpenSelectedPoiDetailClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="16"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Padding="20,8,20,18">
            <Border BackgroundColor="#FFFFFF"
                    Padding="8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">
                <Grid ColumnDefinitions="*,*,*,*,*"
                      ColumnSpacing="7">
                    <Border BackgroundColor="#2F80FF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHomeTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="home_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding HomeNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="White" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenFullScreenMapTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="map_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding MapNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTourShortcutTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="tour_route_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding TourNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoryShortcutTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="history_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding HistoryNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="4"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenAccountPageTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="account_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding SettingsNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="FullScreenMapOverlay"
              Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#F4F8FF"
              ZIndex="20">
            <Grid RowDefinitions="Auto,*"
                  Padding="16,48,16,20">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <ImageButton Source="back_icon.svg"
                                 Clicked="OnCloseFullScreenMapClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="52"
                                 HeightRequest="52"
                                 CornerRadius="26"
                                 Padding="13"
                                 Aspect="AspectFit" />

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="{Binding FullScreenMapTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding FullScreenMapSubtitle}"
                               FontSize="14"
                               TextColor="#6B7C93" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="{Binding StopListeningButtonText}"
                            Command="{Binding StopNarrationCommand}"
                            IsEnabled="{Binding IsNarrating}"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="15"
                            CornerRadius="20"
                            Padding="14,10" />
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,14,0,0">
                    <mapsui:MapView x:Name="FullScreenRestaurantMap"
                                    IsZoomButtonVisible="False"
                                    IsNorthingButtonVisible="False"
                                    IsMyLocationButtonVisible="False"
                                    RotationLock="True" />
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="10"
                                     HorizontalOptions="Start"
                                     VerticalOptions="End"
                                     Margin="14,0,0,16">
                    <ImageButton Source="map_nav_icon.svg"
                                 Clicked="OnOpenPoiBrowsePageClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="46"
                                 HeightRequest="46"
                                 CornerRadius="23"
                                 Padding="11"
                                 Aspect="AspectFit"
                                 SemanticProperties.Description="{Binding FullScreenMapNearbyText}" />

                    <ImageButton Source="filter_icon.svg"
                                 Clicked="OnOpenDishFilterClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="46"
                                 HeightRequest="46"
                                 CornerRadius="23"
                                 Padding="11"
                                 Aspect="AspectFit"
                                 SemanticProperties.Description="{Binding FullScreenMapFilterText}" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="12"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Margin="0,0,18,18">
                    <ImageButton Source="zoom_in_icon.svg"
                                 Clicked="OnFullScreenZoomInClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="52"
                                 HeightRequest="52"
                                 CornerRadius="26"
                                 Padding="12"
                                 Aspect="AspectFit" />

                    <ImageButton Source="zoom_out_icon.svg"
                                 Clicked="OnFullScreenZoomOutClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="52"
                                 HeightRequest="52"
                                 CornerRadius="26"
                                 Padding="12"
                                 Aspect="AspectFit" />

                    <ImageButton Source="locate_control_icon.svg"
                                 Clicked="OnFullScreenCenterCurrentLocationClicked"
                                 BackgroundColor="#FFFFFF"
                                 WidthRequest="52"
                                 HeightRequest="52"
                                 CornerRadius="26"
                                 Padding="12"
                                 Aspect="AspectFit"
                                 SemanticProperties.Description="{Binding StartGpsButtonText}" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
