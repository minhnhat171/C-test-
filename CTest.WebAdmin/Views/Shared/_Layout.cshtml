@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"] as string ?? "Trang quản trị";

    pageTitle = string.IsNullOrWhiteSpace(pageTitle) ? "Trang quản trị" : pageTitle;

    string SidebarLinkClass(string controller) =>
        string.Equals(currentController, controller, System.StringComparison.OrdinalIgnoreCase)
            ? "nav-link sidebar-link is-active"
            : "nav-link sidebar-link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phố Ẩm Thực Vĩnh Khánh</title>
    <title>@pageTitle - Phố Ẩm Thực Vĩnh Khánh</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        :root {
            --app-ink: #0f172a;
            --app-muted: #64748b;
            --app-panel: rgba(255, 255, 255, 0.92);
            --app-border: rgba(255, 255, 255, 0.82);
            --app-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
            --app-sidebar: linear-gradient(180deg, #0d4cc9 0%, #0b3f9f 42%, #08265e 100%);
        }

        body {
            min-height: 100vh;
            color: var(--app-ink);
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.14), rgba(59, 130, 246, 0) 25rem),
                linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
        }

        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 312px;
            flex: 0 0 312px;
            background: var(--app-sidebar);
            color: #fff;
            box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.08);
        }

        .sidebar > h4,
        .sidebar-nav > .nav-link.text-white {
            display: none;
        }

        .sidebar-shell {
            position: sticky;
            top: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            padding: 1.4rem 1.15rem;
            background:
                radial-gradient(circle at top right, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0) 11rem),
                linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0));
        }

        .sidebar-brand {
            padding: 1.15rem;
            border-radius: 28px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.14);
            backdrop-filter: blur(12px);
        }

        .sidebar-kicker {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.35rem 0.72rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.15);
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.74rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .sidebar-brand h1 {
            margin: 0.9rem 0 0;
            font-size: clamp(1.45rem, 1.1rem + 1.1vw, 1.95rem);
            font-weight: 800;
            line-height: 1.16;
            letter-spacing: -0.03em;
        }

        .sidebar-brand p {
            margin: 0.7rem 0 0;
            color: rgba(255, 255, 255, 0.76);
            line-height: 1.65;
            font-size: 0.95rem;
        }

        .sidebar-brand p {
            font-size: 0;
        }

        .sidebar-brand p::after {
            content: "Quan ly POI, Map Analytics, QR va lich su nghe tren cung mot bang dieu khien ro rang, hien dai.";
            font-size: 0.95rem;
        }

        .sidebar-section-label {
            padding: 0 0.45rem;
            color: rgba(255, 255, 255, 0.62);
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.12em;
            text-transform: uppercase;
        }

        .sidebar-nav {
            display: grid;
            gap: 0.45rem;
        }

        .sidebar-link {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.95rem 1rem;
            border-radius: 18px;
            color: rgba(255, 255, 255, 0.92) !important;
            border: 1px solid transparent;
            transition: transform 0.18s ease, background-color 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
        }

        .sidebar-link:hover {
            color: #fff !important;
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.14);
            transform: translateX(3px);
        }

        .sidebar-link.is-active {
            color: #0b3b92 !important;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.99), rgba(219, 234, 254, 0.95));
            border-color: rgba(255, 255, 255, 0.6);
            box-shadow: 0 18px 40px rgba(8, 38, 94, 0.24);
        }

        .sidebar-link.is-active::before {
            content: "";
            position: absolute;
            left: 0.55rem;
            top: 50%;
            transform: translateY(-50%);
            width: 0.3rem;
            height: 1.6rem;
            border-radius: 999px;
            background: linear-gradient(180deg, #0ea5e9 0%, #2563eb 100%);
        }

        .sidebar-link-copy {
            min-width: 0;
            padding-left: 0.45rem;
        }

        .sidebar-link-label {
            display: block;
            font-size: 0.98rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .sidebar-link-meta {
            display: block;
            margin-top: 0.2rem;
            font-size: 0.79rem;
            opacity: 0.74;
        }

        .sidebar-link-tag {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 2.45rem;
            height: 2.45rem;
            padding: 0 0.75rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.12);
            font-size: 0.76rem;
            font-weight: 800;
        }

        .sidebar-link.is-active .sidebar-link-tag {
            background: rgba(14, 165, 233, 0.12);
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 1rem 1.05rem;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.14);
            background: rgba(255, 255, 255, 0.08);
        }

        .sidebar-footer-label {
            color: rgba(255, 255, 255, 0.66);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .sidebar-footer-value {
            margin-top: 0.5rem;
            line-height: 1.65;
            font-weight: 600;
        }

        .content-area {
            flex: 1 1 auto;
            min-width: 0;
            min-height: 100vh;
        }

        .content-header {
            padding: 1.55rem 2rem 1rem;
        }

        .content-header-shell {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.15rem 1.35rem;
            border-radius: 28px;
            background: var(--app-panel);
            border: 1px solid var(--app-border);
            box-shadow: var(--app-shadow);
            backdrop-filter: blur(12px);
        }

        .content-header > div:not(.content-header-shell) {
            display: none;
        }

        .content-header-kicker {
            color: #64748b;
            font-size: 0.76rem;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .content-header-title {
            margin-top: 0.35rem;
            font-size: clamp(1.3rem, 1.05rem + 0.85vw, 1.8rem);
            font-weight: 800;
            letter-spacing: -0.03em;
        }

        .content-header-note {
            max-width: 430px;
            color: #64748b;
            text-align: right;
            line-height: 1.6;
        }

        .content-body {
            padding: 0 2rem 2rem;
        }

        @@media (max-width: 1199.98px) {
            .sidebar {
                width: 286px;
                flex-basis: 286px;
            }

            .content-header,
            .content-body {
                padding-left: 1.25rem;
                padding-right: 1.25rem;
            }
        }

        @@media (max-width: 991.98px) {
            .app-shell {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                flex-basis: auto;
            }

            .sidebar-shell {
                min-height: auto;
            }

            .sidebar-nav {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .content-header-shell {
                flex-direction: column;
                align-items: flex-start;
            }

            .content-header-note {
                max-width: none;
                text-align: left;
            }
        }

        @@media (max-width: 767.98px) {
            .sidebar-nav {
                grid-template-columns: 1fr;
            }

            .content-header {
                padding-top: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <h4 class="mb-4">Quản lý phố ẩm thực Vĩnh Khánh</h4>
            <div class="sidebar-shell">
                <div class="sidebar-brand">
                    <div class="sidebar-kicker">VK Admin</div>
                    <h1>Phố ẩm thực Vĩnh Khánh</h1>
                    <p>Quản lý POI, map marker, audio và lịch sử nghe trên cùng một bảng điều khiển rõ ràng, hiện đại.</p>
                </div>

                <div>
                    <div class="sidebar-section-label">Điều hướng</div>
                    <nav class="nav sidebar-nav mt-2">
                        <a class="@SidebarLinkClass("Home")" asp-controller="Home" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Dashboard</span>
                                <span class="sidebar-link-meta">Tổng quan hệ thống</span>
                            </span>
                            <span class="sidebar-link-tag">01</span>
                        </a>
                        <a class="@SidebarLinkClass("Pois")" asp-controller="Pois" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Quản lý POI</span>
                                <span class="sidebar-link-meta">Điểm nghe và geofence</span>
                            </span>
                            <span class="sidebar-link-tag">02</span>
                        </a>
                        <a class="@SidebarLinkClass("MapPois")" asp-controller="MapPois" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Map Analytics</span>
                                <span class="sidebar-link-meta">Ban do, heatmap va ranking</span>
                            </span>
                            <span class="sidebar-link-tag">03</span>
                        </a>
                        <a class="@SidebarLinkClass("AudioGuides") d-none" asp-controller="AudioGuides" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Audio / TTS</span>
                                <span class="sidebar-link-meta">Kịch bản và file phát</span>
                            </span>
                            <span class="sidebar-link-tag">03</span>
                        </a>
                        <a class="@SidebarLinkClass("QrCodes")" asp-controller="QrCodes" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">QR code</span>
                                <span class="sidebar-link-meta">Điều hướng tại điểm</span>
                            </span>
                            <span class="sidebar-link-tag">04</span>
                        </a>
                        <a class="@SidebarLinkClass("Tours")" asp-controller="Tours" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Tour</span>
                                <span class="sidebar-link-meta">Lộ trình tham quan</span>
                            </span>
                            <span class="sidebar-link-tag">05</span>
                        </a>
                        <a class="@SidebarLinkClass("UsageLogs")" asp-controller="UsageLogs" asp-action="Index">
                            <span class="sidebar-link-copy">
                                <span class="sidebar-link-label">Lịch sử sử dụng</span>
                                <span class="sidebar-link-meta">Theo dõi GPS và QR</span>
                            </span>
                            <span class="sidebar-link-tag">06</span>
                        </a>
                <a class="nav-link text-white" asp-controller="Pois" asp-action="Index">Quản lý POI</a>
                <a class="nav-link text-white d-none" asp-controller="AudioGuides" asp-action="Index">Audio / TTS</a>
                <a class="nav-link text-white" asp-controller="QrCodes" asp-action="Index">QR code</a>
                <a class="nav-link text-white" asp-controller="Tours" asp-action="Index">Tour</a>
                <a class="nav-link text-white" asp-controller="UsageLogs" asp-action="Index">Lịch sử sử dụng</a>
                    </nav>
                </div>

                <div class="sidebar-footer">
                    <div class="sidebar-footer-label">Chế độ quản trị</div>
                    <div class="sidebar-footer-value">Sẵn sàng cập nhật nội dung, QR và cấu hình geofence cho toàn bộ tuyến phố.</div>
                </div>
            </div>
        </aside>

        <main class="content-area">
            <header class="content-header">
                <div class="content-header-shell">
                    <div>
                        <div class="content-header-kicker">Hệ thống quản trị</div>
                        <div class="content-header-title">@pageTitle</div>
                    </div>
                    <div class="content-header-note">
                        Giao diện được tinh chỉnh để thao tác nhanh hơn, nhìn dữ liệu rõ hơn và tạo cảm giác đồng bộ như một bảng điều khiển chuyên nghiệp.
                    </div>
                </div>
                <div>
                    <div class="fw-semibold fs-5 text-primary">Hệ thống quản trị thuyết minh tự động</div>
                </div>
            </header>

            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
