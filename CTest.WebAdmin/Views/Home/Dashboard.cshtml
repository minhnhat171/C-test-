@using System.Linq
@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";

    var maxDailyCount = Math.Max(1, Model.DailyListenPoints.Select(x => x.Count).DefaultIfEmpty(0).Max());
    var maxTopPoiCount = Math.Max(1, Model.TopPois.Select(x => x.Count).DefaultIfEmpty(0).Max());
    var activeDevices = Model.ActiveDeviceStats.Devices;
    var jsonOptions = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web);
}

<style>
    .dashboard-page {
        --line: rgba(148, 163, 184, 0.22);
        --muted: #64748b;
        color: #0f172a;
    }

    .metric-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 0.85rem;
        margin-bottom: 1rem;
    }

    .metric {
        min-height: 126px;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
    }

    .metric-label {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .metric-value {
        margin-top: 0.65rem;
        font-size: 2rem;
        line-height: 1;
        font-weight: 850;
    }

    .metric-note {
        margin-top: 0.65rem;
        color: var(--muted);
        font-size: 0.88rem;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.75fr);
        gap: 1rem;
    }

    .panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .panel-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        border-bottom: 1px solid var(--line);
    }

    .panel-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
    }

    .panel-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.34rem 0.75rem;
        color: #0f766e;
        background: #ccfbf1;
        font-size: 0.82rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .device-list {
        display: grid;
        gap: 0.75rem;
        padding: 1rem;
    }

    .device-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 0.85rem;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 8px;
        background: #f8fafc;
    }

    .device-name {
        font-weight: 800;
    }

    .device-meta {
        margin-top: 0.22rem;
        color: var(--muted);
        font-size: 0.86rem;
    }

    .device-signal {
        display: grid;
        justify-items: end;
        gap: 0.3rem;
        color: var(--muted);
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .signal-dot {
        width: 0.72rem;
        height: 0.72rem;
        border-radius: 999px;
        background: #10b981;
        box-shadow: 0 0 0 5px rgba(16, 185, 129, 0.14);
    }

    .empty-state {
        padding: 1rem;
        color: var(--muted);
    }

    .chart {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0.55rem;
        align-items: end;
        min-height: 220px;
        padding: 1rem;
    }

    .chart-col {
        display: grid;
        gap: 0.5rem;
        justify-items: center;
        align-items: end;
        height: 100%;
    }

    .chart-bar-wrap {
        display: flex;
        align-items: end;
        width: 100%;
        height: 150px;
        max-width: 42px;
        border-radius: 8px;
        background: #f1f5f9;
        overflow: hidden;
    }

    .chart-bar {
        width: 100%;
        min-height: 6px;
        background: #0f766e;
    }

    .chart-label {
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 700;
    }

    .top-list {
        display: grid;
        gap: 0.75rem;
        padding: 1rem;
    }

    .top-row {
        display: grid;
        gap: 0.35rem;
    }

    .top-row-head {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        font-size: 0.9rem;
    }

    .top-track {
        height: 8px;
        border-radius: 999px;
        background: #e2e8f0;
        overflow: hidden;
    }

    .top-fill {
        height: 100%;
        background: #2563eb;
    }

    .history-table {
        margin: 0;
        --bs-table-bg: transparent;
    }

    .history-table thead th {
        padding: 0.85rem 1rem;
        color: var(--muted);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: #f8fafc;
        border-bottom-width: 0;
        white-space: nowrap;
    }

    .history-table tbody td {
        padding: 0.9rem 1rem;
        border-color: rgba(148, 163, 184, 0.14);
        vertical-align: middle;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.3rem 0.68rem;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 0.8rem;
        font-weight: 800;
    }

    .pill.done {
        background: #dcfce7;
        color: #166534;
    }

    .pill.pending {
        background: #fef3c7;
        color: #92400e;
    }

    @@media (max-width: 1199.98px) {
        .metric-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .metric-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .device-row {
            grid-template-columns: 1fr;
        }

        .device-signal {
            justify-items: start;
        }

        .history-table th:nth-child(4),
        .history-table td:nth-child(4),
        .history-table th:nth-child(6),
        .history-table td:nth-child(6) {
            display: none;
        }
    }
</style>

<div class="dashboard-page">
    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
    }

    <div class="metric-grid">
        <div class="metric">
            <div class="metric-label">Realtime</div>
            <div class="metric-value" id="activeDeviceCount">@Model.ActiveDeviceCount</div>
            <div class="metric-note" id="activeDeviceNote">@Model.ActiveDeviceCount thiết bị online</div>
        </div>
        <div class="metric">
            <div class="metric-label">Hôm nay</div>
            <div class="metric-value" id="todayListenCountValue">@Model.TodayListenCount</div>
            <div class="metric-note">Lượt nghe</div>
        </div>
        <div class="metric">
            <div class="metric-label">POI</div>
            <div class="metric-value">@Model.TotalPois</div>
            <div class="metric-note">@Model.ActivePoiCount đang hoạt động</div>
        </div>
        <div class="metric">
            <div class="metric-label">QR</div>
            <div class="metric-value">@Model.TotalQrCodes</div>
            <div class="metric-note">@Model.QrListenRate% từ QR</div>
        </div>
        <div class="metric">
            <div class="metric-label">Tour</div>
            <div class="metric-value">@Model.TotalTours</div>
            <div class="metric-note">Đang cấu hình</div>
        </div>
        <div class="metric">
            <div class="metric-label">Hoàn tất</div>
            <div class="metric-value">@Model.CompletionRate%</div>
            <div class="metric-note">@Model.AverageListenSeconds.ToString("0") giây trung bình</div>
        </div>
    </div>

    <div class="dashboard-grid mb-3">
        <div class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Thiết bị đang hoạt động</h2>
                <span class="panel-chip" id="activeDevicePanelCount">@Model.ActiveDeviceCount thiết bị</span>
            </div>
            <div class="device-list" id="activeDeviceList">
                @if (activeDevices.Any())
                {
                    @foreach (var item in activeDevices)
                    {
                        var shortDeviceId = item.DeviceId.Length > 8
                            ? item.DeviceId[^8..].ToUpperInvariant()
                            : item.DeviceId.ToUpperInvariant();
                        var shortInstanceId = item.ClientInstanceId.Length > 8
                            ? item.ClientInstanceId[^8..].ToUpperInvariant()
                            : item.ClientInstanceId.ToUpperInvariant();
                        var deviceName = string.IsNullOrWhiteSpace(item.UserDisplayName)
                            ? item.UserCode
                            : item.UserDisplayName;
                        var platform = string.IsNullOrWhiteSpace(item.DevicePlatform) ? "App" : item.DevicePlatform;
                        var deviceModel = string.IsNullOrWhiteSpace(item.DeviceModel) ? platform : $"{platform} - {item.DeviceModel}";
                        var signalText = item.SecondsSinceLastSeen <= 30 ? "Online" : "Mất tín hiệu";

                        <div class="device-row">
                            <div>
                                <div class="device-name">@deviceName</div>
                                <div class="device-meta">@deviceModel</div>
                                <div class="device-meta">Device #@shortDeviceId · Instance #@shortInstanceId</div>
                                @if (item.Latitude.HasValue && item.Longitude.HasValue)
                                {
                                    <div class="device-meta">@item.Latitude.Value.ToString("0.000000"), @item.Longitude.Value.ToString("0.000000")</div>
                                }
                            </div>
                            <div class="device-signal">
                                <span class="signal-dot"></span>
                                <span>@signalText · @item.LastSeenAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">Chưa có thiết bị online.</div>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Top POI</h2>
                <span class="panel-chip" id="mostPlayedPoiValue">@Model.MostPlayedPoi</span>
            </div>
            <div class="top-list">
                @if (Model.TopPois.Any())
                {
                    @foreach (var item in Model.TopPois)
                    {
                        var width = Math.Max(10, (int)Math.Round(item.Count * 100.0 / maxTopPoiCount));
                        <div class="top-row">
                            <div class="top-row-head">
                                <span class="fw-semibold text-truncate">@item.Name</span>
                                <span class="text-muted">@item.Count</span>
                            </div>
                            <div class="top-track"><div class="top-fill" style="width:@width%;"></div></div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state">Chưa có dữ liệu.</div>
                }
            </div>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="panel">
            <div class="panel-head">
                <h2 class="panel-title">Lịch sử gần đây</h2>
                <span class="panel-chip">@Model.RecentLogs.Count phiên</span>
            </div>
            <div class="table-responsive">
                <table class="table history-table align-middle">
                    <thead>
                        <tr>
                            <th>Người dùng</th>
                            <th>POI</th>
                            <th>Nguồn</th>
                            <th>Ngôn ngữ</th>
                            <th>Thời điểm</th>
                            <th>Thời lượng</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.RecentLogs.Any())
                    {
                        @foreach (var item in Model.RecentLogs)
                        {
                            <tr>
                                <td><span class="pill">@item.UserCode</span></td>
                                <td class="fw-semibold">@item.PoiName</td>
                                <td>@item.TriggerType</td>
                                <td>@item.Language</td>
                                <td>@item.StartedAt.ToString("dd/MM HH:mm")</td>
                                <td>@item.ListenSeconds giây</td>
                                <td><span class="pill @(item.Completed ? "done" : "pending")">@(item.Completed ? "Xong" : "Đang nghe")</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Chưa có lịch sử.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="panel">
            <div class="panel-head">
                <h2 class="panel-title">7 ngày</h2>
                <span class="panel-chip">@Model.TotalUsageLogs lượt</span>
            </div>
            <div class="chart">
                @foreach (var point in Model.DailyListenPoints)
                {
                    var barHeight = point.Count == 0 ? 4 : Math.Max(8, (int)Math.Round(point.Count * 100.0 / maxDailyCount));
                    <div class="chart-col">
                        <div class="chart-bar-wrap">
                            <div class="chart-bar" style="height:@barHeight%;"></div>
                        </div>
                        <div class="fw-bold">@point.Count</div>
                        <div class="chart-label">@point.Label</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const initialStats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ActiveDeviceStats, jsonOptions));
            const initialUsageSnapshot = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
            {
                todayListenCount = Model.TodayListenCount,
                mostPlayedPoi = Model.MostPlayedPoi,
                recentLogs = Model.RecentLogs
            }, jsonOptions));
            const statsUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("ActiveDevices", "Home")));
            const eventsUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("ActiveDeviceEvents", "Home")));
            const usageHistorySnapshotUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("UsageHistorySnapshot", "Home")));
            const countEl = document.getElementById("activeDeviceCount");
            const noteEl = document.getElementById("activeDeviceNote");
            const panelCountEl = document.getElementById("activeDevicePanelCount");
            const listEl = document.getElementById("activeDeviceList");
            const todayListenCountEl = document.getElementById("todayListenCountValue");
            const mostPlayedPoiEl = document.getElementById("mostPlayedPoiValue");
            const recentHistoryCountEl = document.querySelector(".history-table")?.closest(".panel")?.querySelector(".panel-chip");
            const recentHistoryBodyEl = document.querySelector(".history-table tbody");
            let pollingTimer = 0;
            let isLoadingStats = false;
            let isLoadingUsageSnapshot = false;
            let lastStats = initialStats;
            let lastUsageSnapshot = initialUsageSnapshot;

            const escapeHtml = (value) => String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const shortId = (value) => {
                const text = String(value ?? "").toUpperCase();
                return text.length > 8 ? text.slice(-8) : text;
            };

            const formatTime = (value, withSeconds = true) => {
                const date = new Date(value);
                if (Number.isNaN(date.getTime())) {
                    return "--";
                }

                return date.toLocaleString("vi-VN", {
                    day: "2-digit",
                    month: "2-digit",
                    hour: "2-digit",
                    minute: "2-digit",
                    second: withSeconds ? "2-digit" : undefined
                });
            };

            const formatCoordinate = (value) => {
                const coordinate = Number(value);
                return Number.isFinite(coordinate) ? coordinate.toFixed(6) : "";
            };

            const hasLocation = (device) =>
                Number.isFinite(Number(device?.latitude)) &&
                Number.isFinite(Number(device?.longitude));

            const renderDevices = (devices) => {
                if (!listEl) {
                    return;
                }

                if (!Array.isArray(devices) || devices.length === 0) {
                    listEl.innerHTML = '<div class="empty-state">Chưa có thiết bị online.</div>';
                    return;
                }

                listEl.innerHTML = devices.map((device) => {
                    const name = device.userDisplayName || device.userCode || "Khách tham quan";
                    const platform = device.devicePlatform || "App";
                    const model = device.deviceModel ? `${platform} - ${device.deviceModel}` : platform;
                    const seconds = Number(device.secondsSinceLastSeen ?? 999);
                    const statusText = seconds <= 30 ? "Online" : "Mất tín hiệu";
                    const location = hasLocation(device)
                        ? `<div class="device-meta">${escapeHtml(formatCoordinate(device.latitude))}, ${escapeHtml(formatCoordinate(device.longitude))}</div>`
                        : "";

                    return `
                        <div class="device-row">
                            <div>
                                <div class="device-name">${escapeHtml(name)}</div>
                                <div class="device-meta">${escapeHtml(model)}</div>
                                <div class="device-meta">Device #${escapeHtml(shortId(device.deviceId))} · Instance #${escapeHtml(shortId(device.clientInstanceId))}</div>
                                ${location}
                            </div>
                            <div class="device-signal">
                                <span class="signal-dot"></span>
                                <span>${escapeHtml(statusText)} · ${escapeHtml(formatTime(device.lastSeenAtUtc))}</span>
                            </div>
                        </div>`;
                }).join("");
            };

            const renderUsageHistory = (snapshot) => {
                const logs = Array.isArray(snapshot?.recentLogs) ? snapshot.recentLogs : [];
                const todayListenCount = Number(snapshot?.todayListenCount ?? 0);
                const mostPlayedPoi = snapshot?.mostPlayedPoi || "Chưa có dữ liệu";

                if (todayListenCountEl) {
                    todayListenCountEl.textContent = todayListenCount.toString();
                }

                if (mostPlayedPoiEl) {
                    mostPlayedPoiEl.textContent = mostPlayedPoi;
                }

                if (recentHistoryCountEl) {
                    recentHistoryCountEl.textContent = `${logs.length} phiên`;
                }

                if (!recentHistoryBodyEl) {
                    return;
                }

                if (logs.length === 0) {
                    recentHistoryBodyEl.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">Chưa có lịch sử.</td></tr>';
                    return;
                }

                recentHistoryBodyEl.innerHTML = logs.map((item) => {
                    const completed = item?.completed === true;
                    const listenSeconds = Number(item?.listenSeconds ?? 0);

                    return `
                        <tr>
                            <td><span class="pill">${escapeHtml(item?.userCode || "Khách")}</span></td>
                            <td class="fw-semibold">${escapeHtml(item?.poiName || "POI")}</td>
                            <td>${escapeHtml(item?.triggerType || "APP")}</td>
                            <td>${escapeHtml(item?.language || "vi")}</td>
                            <td>${escapeHtml(formatTime(item?.startedAt, false))}</td>
                            <td>${Number.isFinite(listenSeconds) ? listenSeconds : 0} giây</td>
                            <td><span class="pill ${completed ? "done" : "pending"}">${completed ? "Xong" : "Đang nghe"}</span></td>
                        </tr>`;
                }).join("");
            };

            const updateStats = (stats) => {
                const count = Number(stats?.activeDeviceCount ?? 0);
                const devices = stats?.devices ?? [];

                if (countEl) {
                    countEl.textContent = count.toString();
                }

                if (noteEl) {
                    noteEl.textContent = `${count} thiết bị online`;
                }

                if (panelCountEl) {
                    panelCountEl.textContent = `${count} thiết bị`;
                }

                renderDevices(devices);
            };

            const loadStats = async () => {
                if (!statsUrl || isLoadingStats) {
                    return;
                }

                isLoadingStats = true;
                try {
                    const response = await fetch(statsUrl, { cache: "no-store" });
                    if (response.ok) {
                        lastStats = await response.json();
                        updateStats(lastStats);
                    }
                } catch {
                } finally {
                    isLoadingStats = false;
                }
            };

            const loadUsageSnapshot = async () => {
                if (!usageHistorySnapshotUrl || isLoadingUsageSnapshot) {
                    return;
                }

                isLoadingUsageSnapshot = true;
                try {
                    const response = await fetch(usageHistorySnapshotUrl, { cache: "no-store" });
                    if (response.ok) {
                        lastUsageSnapshot = await response.json();
                        renderUsageHistory(lastUsageSnapshot);
                    }
                } catch {
                } finally {
                    isLoadingUsageSnapshot = false;
                }
            };

            const startPolling = () => {
                if (pollingTimer) {
                    return;
                }

                void loadStats();
                void loadUsageSnapshot();
                pollingTimer = window.setInterval(() => {
                    void loadStats();
                    void loadUsageSnapshot();
                }, 3000);
            };

            updateStats(lastStats);
            renderUsageHistory(lastUsageSnapshot);
            startPolling();

            if ("EventSource" in window && eventsUrl) {
                const source = new EventSource(eventsUrl);
                source.addEventListener("active-devices", (event) => {
                    try {
                        lastStats = JSON.parse(event.data);
                        updateStats(lastStats);
                    } catch {
                        startPolling();
                    }
                });
                source.onerror = () => {
                    source.close();
                };
            }

            document.addEventListener("visibilitychange", () => {
                if (!document.hidden) {
                    void loadStats();
                    void loadUsageSnapshot();
                }
            });
        })();
    </script>
}
