@model ListeningHistoryPageViewModel

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-warning mb-4">
        @Model.LoadErrorMessage
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Tong luot nghe</div>
                <div class="display-6">@Model.TotalSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Hoan tat</div>
                <div class="display-6">@Model.CompletedSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Ty le hoan tat</div>
                <div class="display-6">@Model.CompletionRate%</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Nghe nhieu nhat</div>
                <div class="fw-bold fs-5">@Model.MostPlayedPoi</div>
                <div class="small text-muted mt-2">Tong @Model.TotalListenSeconds giay nghe trong bo loc hien tai</div>
            </div>
        </div>
    </div>
</div>

@if (Model.SelectedView == "ranking")
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Xep hang POI duoc nghe nhieu nhat</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 80px;">Top</th>
                        <th>POI</th>
                        <th style="width: 140px;">Luot nghe</th>
                        <th style="width: 140px;">Hoan tat</th>
                        <th style="width: 160px;">Tong thoi gian</th>
                        <th style="width: 180px;">Lan cuoi</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RankingItems.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Chua co du lieu nghe tu app trong bo loc hien tai.</td>
                    </tr>
                }
                else
                {
                    @for (var index = 0; index < Model.RankingItems.Count; index++)
                    {
                        var item = Model.RankingItems[index];
                        <tr>
                            <td><span class="badge text-bg-primary">#@(index + 1)</span></td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>@item.ListenCount</td>
                            <td>
                                <div>@item.CompletedCount / @item.ListenCount</div>
                                <div class="small text-muted">@item.CompletionRateLabel</div>
                            </td>
                            <td>@item.TotalListenLabel</td>
                            <td>@item.LastStartedAtDisplay</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white fw-semibold">Dong thoi gian nghe</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 180px;">Bat dau</th>
                        <th>POI</th>
                        <th style="width: 180px;">Nguoi nghe</th>
                        <th style="width: 110px;">Kich hoat</th>
                        <th style="width: 110px;">Ngon ngu</th>
                        <th style="width: 150px;">Thoi gian</th>
                        <th style="width: 150px;">Trang thai</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.TimelineItems.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Chua co luot nghe nao duoc dong bo.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.TimelineItems)
                    {
                        var badgeClass = item.Completed
                            ? "text-bg-success"
                            : string.IsNullOrWhiteSpace(item.ErrorMessage)
                                ? "text-bg-warning"
                                : "text-bg-danger";

                        <tr>
                            <td>
                                <div>@item.StartedAtDisplay</div>
                                <div class="small text-muted">Ket thuc: @item.CompletedAtDisplay</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@item.PoiName</div>
                                <div class="small text-muted">@item.PoiCode</div>
                            </td>
                            <td>
                                <div>@item.UserDisplayName</div>
                                <div class="small text-muted">@item.UserCode</div>
                            </td>
                            <td>
                                <div>@item.TriggerType</div>
                                <div class="small text-muted">@item.Source / @item.DevicePlatform</div>
                            </td>
                            <td>@item.Language</td>
                            <td>@item.DurationLabel</td>
                            <td>
                                <span class="badge @badgeClass">@item.StatusLabel</span>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                                {
                                    <div class="small text-danger mt-1">@item.ErrorMessage</div>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">Dong thoi gian nghe</div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 180px;">Bat dau</th>
                        <th>POI</th>
                        <th style="width: 180px;">Nguoi nghe</th>
                        <th style="width: 110px;">Kich hoat</th>
                        <th style="width: 110px;">Ngon ngu</th>
                        <th style="width: 150px;">Thoi gian</th>
