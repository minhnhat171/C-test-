@model QrScanViewModel
@{
    Layout = null;
    var narrationText = string.IsNullOrWhiteSpace(Model.NarrationText)
        ? Model.Description
        : Model.NarrationText;
    var hasAppLaunchUrl = !string.IsNullOrWhiteSpace(Model.AppLaunchUrl);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.TargetName - Mở trên ứng dụng</title>
    <meta name="description" content="@Model.Description" />
    <style>
        :root {
            --bg-top: #fff5df;
            --bg-bottom: #f4efe8;
            --card: rgba(255, 255, 255, 0.94);
            --ink: #18212f;
            --muted: #5b6472;
            --accent: #c2410c;
            --accent-dark: #9a3412;
            --line: rgba(148, 163, 184, 0.18);
            --shadow: 0 24px 60px rgba(24, 33, 47, 0.14);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans", Arial, sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.85), transparent 32%),
                linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
            display: flex;
            justify-content: center;
            padding: 24px 16px 48px;
        }

        .scan-shell {
            width: min(100%, 760px);
        }

        .scan-card {
            background: var(--card);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 28px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .scan-hero {
            padding: 24px 24px 20px;
            background:
                radial-gradient(circle at right top, rgba(251, 191, 36, 0.28), transparent 36%),
                linear-gradient(135deg, rgba(255, 247, 237, 0.96), rgba(255, 255, 255, 0.97));
            border-bottom: 1px solid var(--line);
        }

        .scan-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 237, 213, 0.95);
            color: var(--accent-dark);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-title {
            margin: 14px 0 8px;
            font-size: clamp(1.9rem, 1.45rem + 2vw, 2.8rem);
            line-height: 1.06;
            letter-spacing: -0.04em;
        }

        .scan-description {
            margin: 0;
            color: var(--muted);
            line-height: 1.7;
            font-size: 1rem;
        }

        .scan-body {
            padding: 22px;
            display: grid;
            gap: 16px;
        }

        .scan-panel {
            border-radius: 22px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, 0.84);
            padding: 18px;
        }

        .scan-panel-highlight {
            background: linear-gradient(180deg, rgba(255, 247, 237, 0.95), rgba(255, 255, 255, 0.92));
            border-color: rgba(194, 65, 12, 0.18);
        }

        .scan-panel-label {
            margin: 0 0 10px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-text {
            margin: 0;
            line-height: 1.8;
            white-space: pre-wrap;
        }

        .scan-meta {
            display: grid;
            gap: 12px;
        }

        .scan-stop-list {
            margin: 0;
            padding-left: 1.2rem;
            line-height: 1.8;
        }

        .scan-meta-item {
            padding: 14px 16px;
            border-radius: 18px;
            background: #fffaf2;
            border: 1px solid rgba(251, 191, 36, 0.18);
        }

        .scan-meta-label {
            display: block;
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .scan-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 14px;
        }

        .scan-btn {
            appearance: none;
            border: 0;
            border-radius: 20px;
            min-height: 56px;
            padding: 14px 18px;
            font: inherit;
            font-weight: 700;
            text-decoration: none;
            text-align: center;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .scan-btn:hover {
            transform: translateY(-1px);
        }

        .scan-btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, #ea580c 100%);
            color: white;
            box-shadow: 0 18px 30px rgba(194, 65, 12, 0.22);
        }

        .scan-btn-secondary {
            background: #fff7ed;
            color: var(--accent-dark);
            border: 1px solid rgba(194, 65, 12, 0.16);
        }

        .scan-link {
            color: var(--accent-dark);
            word-break: break-all;
        }

        .scan-note {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        @@media (max-width: 640px) {
            body {
                padding-inline: 12px;
            }

            .scan-hero,
            .scan-body {
                padding: 18px;
            }

            .scan-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <main class="scan-shell">
        <section class="scan-card">
            <header class="scan-hero">
                <div class="scan-badge">@Model.TargetKindLabel thuyết minh</div>
                <h1 class="scan-title">@Model.TargetName</h1>
                <p class="scan-description">@Model.Description</p>
            </header>

            <div class="scan-body">
                <section class="scan-panel scan-panel-highlight">
                    <p class="scan-panel-label">Nghe trên ứng dụng</p>
                    <p class="scan-note">Trang QR này chỉ mở nội dung trên ứng dụng. Nếu máy chưa cài app, hãy tải ứng dụng để tiếp tục nghe.</p>

                    <div class="scan-actions">
                        @if (hasAppLaunchUrl)
                        {
                            <button type="button" class="scan-btn scan-btn-primary" id="openAppBtn">Nghe trên ứng dụng</button>
                        }
                        <a class="scan-btn scan-btn-secondary" href="/download-app">Tải ứng dụng để nghe</a>
                    </div>

                    <p class="scan-note" id="openStatus">
                        @(hasAppLaunchUrl
                            ? "Nếu điện thoại hỏi xác nhận, hãy chọn Mở ứng dụng. Nếu chưa mở được app, hãy dùng nút tải ứng dụng."
                            : "Ứng dụng chưa sẵn sàng trên thiết bị này. Hãy tải ứng dụng để tiếp tục nghe.")
                    </p>
                </section>

                <section class="scan-panel">
                    <p class="scan-panel-label">Nội dung thuyết minh</p>
                    <p class="scan-text">@narrationText</p>
                </section>

                @if (Model.TourStops.Count > 0)
                {
                    <section class="scan-panel">
                        <p class="scan-panel-label">Lộ trình tour</p>
                        <ol class="scan-stop-list">
                            @foreach (var stop in Model.TourStops)
                            {
                                <li>@stop</li>
                            }
                        </ol>
                    </section>
                }

                <section class="scan-meta">
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Địa chỉ</span>
                            <div>@Model.Address</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SpecialDish))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Món gợi ý</span>
                            <div>@Model.SpecialDish</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.EstimatedDurationLabel))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Thông tin thêm</span>
                            <div>@Model.EstimatedDurationLabel</div>
                        </div>
                    }

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Mã đối tượng</span>
                        <div>@Model.TargetCode</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.MapLink))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Bản đồ</span>
                            <a class="scan-link" href="@Model.MapLink" target="_blank" rel="noopener noreferrer">@Model.MapLink</a>
                        </div>
                    }

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Liên kết công khai</span>
                        <a class="scan-link" href="@Model.PublicUrl">@Model.PublicUrl</a>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <script>
        (() => {
            const appLaunchUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AppLaunchUrl));
            const heartbeatUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("WebHeartbeat", "QrCodes")));
            const openAppBtn = document.getElementById("openAppBtn");
            const openStatus = document.getElementById("openStatus");
            const deviceStorageKey = "vinhkhanh.qr.deviceId.v1";
            const createId = () => globalThis.crypto?.randomUUID
                ? globalThis.crypto.randomUUID()
                : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
            const clientInstanceId = `${Date.now().toString(16)}-${createId()}`;
            let lastLocation = null;
            let heartbeatTimer = 0;

            const getOrCreateDeviceId = () => {
                try {
                    const existing = localStorage.getItem(deviceStorageKey);
                    if (existing) {
                        return existing;
                    }

                    const next = `web-${createId()}`;
                    localStorage.setItem(deviceStorageKey, next);
                    return next;
                } catch {
                    return `web-${clientInstanceId}`;
                }
            };

            const buildHeartbeatPayload = () => {
                const payload = {
                    deviceId: getOrCreateDeviceId(),
                    clientInstanceId,
                    userCode: "qr-web",
                    userDisplayName: "Khách quét QR",
                    userEmail: "",
                    devicePlatform: navigator.platform || "Web",
                    deviceModel: navigator.userAgent || "Trình duyệt",
                    appVersion: "web-qr",
                    sentAtUtc: new Date().toISOString()
                };

                if (lastLocation) {
                    payload.latitude = lastLocation.latitude;
                    payload.longitude = lastLocation.longitude;
                    payload.accuracyMeters = lastLocation.accuracyMeters;
                    payload.locationTimestampUtc = lastLocation.locationTimestampUtc;
                }

                return payload;
            };

            const postJson = (url, payload, keepalive = false) => {
                if (!url) {
                    return Promise.resolve();
                }

                return fetch(url, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                    cache: "no-store",
                    keepalive
                }).catch(() => {});
            };

            const sendHeartbeat = () => postJson(heartbeatUrl, buildHeartbeatPayload());

            const captureLocation = () => {
                if (!("geolocation" in navigator)) {
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        lastLocation = {
                            latitude: position.coords.latitude,
                            longitude: position.coords.longitude,
                            accuracyMeters: position.coords.accuracy,
                            locationTimestampUtc: new Date(position.timestamp || Date.now()).toISOString()
                        };
                        void sendHeartbeat();
                    },
                    () => {},
                    {
                        enableHighAccuracy: true,
                        maximumAge: 60000,
                        timeout: 5000
                    });
            };

            const startHeartbeat = () => {
                void sendHeartbeat();
                captureLocation();

                heartbeatTimer = window.setInterval(() => {
                    if (!document.hidden) {
                        void sendHeartbeat();
                    }
                }, 8000);
            };

            if (!openAppBtn || !appLaunchUrl) {
                startHeartbeat();
                return;
            }

            openAppBtn.addEventListener("click", () => {
                void sendHeartbeat();
                captureLocation();

                if (openStatus) {
                    openStatus.textContent = "Đang mở ứng dụng trên thiết bị...";
                }

                window.setTimeout(() => {
                    if (!document.hidden && openStatus) {
                        openStatus.textContent = "Nếu ứng dụng chưa mở, hãy cài app bằng nút tải ứng dụng rồi quét lại mã QR.";
                    }
                }, 1500);

                window.location.href = appLaunchUrl;
            });

            startHeartbeat();
        })();
    </script>
</body>
</html>
