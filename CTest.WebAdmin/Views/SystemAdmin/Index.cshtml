@model SystemAdminViewModel
@{
    ViewData["Title"] = "Tài khoản";
}

<style>
    .system-page {
        --line: rgba(148, 163, 184, 0.22);
        --muted: #64748b;
        color: #0f172a;
    }

    .system-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 1rem;
    }

    .system-panel {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .system-panel-body {
        padding: 1rem;
    }

    .system-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem;
        border-bottom: 1px solid var(--line);
    }

    .system-title h2 {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
    }

    .system-table {
        margin: 0;
        --bs-table-bg: transparent;
    }

    .system-table thead th {
        padding: 0.85rem 1rem;
        color: var(--muted);
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        background: #f8fafc;
        border-bottom-width: 0;
        white-space: nowrap;
    }

    .system-table tbody td {
        padding: 0.9rem 1rem;
        border-color: rgba(148, 163, 184, 0.14);
        vertical-align: middle;
    }

    .role-chip,
    .status-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.32rem 0.72rem;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .role-chip.admin {
        background: #e0f2fe;
        color: #075985;
    }

    .role-chip.owner {
        background: #fef3c7;
        color: #92400e;
    }

    .status-chip.online {
        background: #dcfce7;
        color: #166534;
    }

    .status-chip.offline {
        background: #f1f5f9;
        color: #475569;
    }

    .system-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.45rem;
    }

    .system-form-grid {
        display: grid;
        gap: 0.8rem;
    }

    .form-control,
    .form-select {
        border-color: rgba(148, 163, 184, 0.28);
        border-radius: 8px;
        min-height: 44px;
    }

    .form-label {
        font-weight: 700;
        font-size: 0.86rem;
    }

    .app-user-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.7rem;
    }

    @@media (max-width: 1199.98px) {
        .system-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .app-user-toolbar {
            grid-template-columns: 1fr;
        }

        .system-actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="system-page">
    @if (TempData["SystemAdminMessage"] is string message)
    {
        <div class="alert alert-success border-0 shadow-sm">@message</div>
    }

    @if (TempData["SystemAdminError"] is string error)
    {
        <div class="alert alert-danger border-0 shadow-sm">@error</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger border-0 shadow-sm" asp-validation-summary="All"></div>
    }

    <div class="system-grid mb-4">
        <div class="system-panel">
            <div class="system-title">
                <h2>Admin và chủ cửa hàng</h2>
                <span class="text-muted small">@Model.WebAdminAccounts.Count tài khoản</span>
            </div>
            <div class="table-responsive">
                <table class="table system-table align-middle">
                    <thead>
                        <tr>
                            <th>Tài khoản</th>
                            <th>Vai trò</th>
                            <th>Owner code</th>
                            <th>Email</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.WebAdminAccounts)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.DisplayName</div>
                                <div class="text-muted small">@item.Username</div>
                            </td>
                            <td>
                                <span class="role-chip @(item.IsAdmin ? "admin" : "owner")">@item.RoleLabel</span>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.OwnerCode) ? "-" : item.OwnerCode)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.OwnerEmail) ? "-" : item.OwnerEmail)</td>
                            <td>
                                <div class="system-actions">
                                    <a asp-action="Index"
                                       asp-route-editAdmin="@item.Username"
                                       class="btn btn-outline-primary btn-sm">Sửa</a>
                                    <form asp-action="DeleteAccount"
                                          method="post"
                                          onsubmit="return confirm('Xóa tài khoản này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="username" value="@item.Username" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="system-panel">
            <div class="system-title">
                <h2>@(Model.AccountForm.IsEditMode ? "Sửa tài khoản" : "Thêm tài khoản")</h2>
                @if (Model.AccountForm.IsEditMode)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Hủy</a>
                }
            </div>
            <div class="system-panel-body">
                <form asp-action="SaveAccount" method="post" class="system-form-grid">
                    @Html.AntiForgeryToken()
                    <input asp-for="AccountForm.OriginalUsername" type="hidden" />
                    <input asp-for="AppUserKeyword" type="hidden" />

                    <div>
                        <label asp-for="AccountForm.Username" class="form-label">Tên đăng nhập</label>
                        <input asp-for="AccountForm.Username" class="form-control" autocomplete="off" />
                    </div>

                    <div>
                        <label asp-for="AccountForm.DisplayName" class="form-label">Tên hiển thị</label>
                        <input asp-for="AccountForm.DisplayName" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AccountForm.Role" class="form-label">Vai trò</label>
                        <select asp-for="AccountForm.Role" class="form-select" id="adminRoleSelect">
                            <option value="Admin">Admin</option>
                            <option value="PoiOwner">Chủ cửa hàng</option>
                        </select>
                    </div>

                    <div class="owner-field">
                        <label asp-for="AccountForm.OwnerCode" class="form-label">Owner code</label>
                        <input asp-for="AccountForm.OwnerCode" class="form-control" />
                    </div>

                    <div class="owner-field">
                        <label asp-for="AccountForm.OwnerEmail" class="form-label">Email chủ cửa hàng</label>
                        <input asp-for="AccountForm.OwnerEmail" class="form-control" type="email" />
                    </div>

                    <div>
                        <label asp-for="AccountForm.Password" class="form-label">Mật khẩu</label>
                        <input asp-for="AccountForm.Password" class="form-control" type="password" autocomplete="new-password" />
                    </div>

                    <div>
                        <label asp-for="AccountForm.ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="AccountForm.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" />
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        @(Model.AccountForm.IsEditMode ? "Lưu thay đổi" : "Tạo tài khoản")
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="system-grid">
        <div class="system-panel">
            <div class="system-title">
                <h2>Người dùng app</h2>
                <span class="text-muted small">@Model.AppUsers.Count hồ sơ</span>
            </div>
            <div class="system-panel-body border-bottom">
                <form method="get" asp-action="Index" class="app-user-toolbar">
                    <input class="form-control" type="search" name="keyword" value="@Model.AppUserKeyword" placeholder="Tìm theo tên, email, mã người dùng..." />
                    <div class="d-flex gap-2">
                        <button class="btn btn-dark" type="submit">Tìm</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Đặt lại</a>
                    </div>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.AppUserLoadErrorMessage))
            {
                <div class="alert alert-warning m-3">@Model.AppUserLoadErrorMessage</div>
            }

            <div class="table-responsive">
                <table class="table system-table align-middle">
                    <thead>
                        <tr>
                            <th>Người dùng</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th>Lượt nghe</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.AppUsers.Any())
                    {
                        @foreach (var item in Model.AppUsers)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.DisplayName</div>
                                    <div class="text-muted small">@item.UserCode</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Email))
                                    {
                                        <div class="text-muted small">@item.Email</div>
                                    }
                                </td>
                                <td>@item.Role</td>
                                <td>
                                    <span class="status-chip @(item.IsOnline ? "online" : "offline")">
                                        @(item.IsOnline ? "Online" : "Offline")
                                    </span>
                                </td>
                                <td>@item.TotalSessions</td>
                                <td class="text-end">
                                    <a asp-action="Index"
                                       asp-route-keyword="@Model.AppUserKeyword"
                                       asp-route-editAppUser="@item.Id"
                                       class="btn btn-outline-primary btn-sm">Sửa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có hồ sơ phù hợp.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="system-panel">
            <div class="system-title">
                <h2>@(Model.AppUserForm.IsEditMode ? "Sửa app user" : "Thêm app user")</h2>
                @if (Model.AppUserForm.IsEditMode)
                {
                    <a asp-action="Index" asp-route-keyword="@Model.AppUserKeyword" class="btn btn-outline-secondary btn-sm">Hủy</a>
                }
            </div>
            <div class="system-panel-body">
                <form asp-action="SaveAppUser" method="post" class="system-form-grid">
                    @Html.AntiForgeryToken()
                    <input asp-for="AppUserForm.Id" type="hidden" />
                    <input asp-for="AppUserKeyword" type="hidden" />

                    <div>
                        <label asp-for="AppUserForm.UserCode" class="form-label">Mã người dùng</label>
                        <input asp-for="AppUserForm.UserCode" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.DisplayName" class="form-label">Tên hiển thị</label>
                        <input asp-for="AppUserForm.DisplayName" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.Email" class="form-label">Email</label>
                        <input asp-for="AppUserForm.Email" class="form-control" type="email" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.Role" class="form-label">Vai trò app</label>
                        <input asp-for="AppUserForm.Role" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.PhoneNumber" class="form-label">Số điện thoại</label>
                        <input asp-for="AppUserForm.PhoneNumber" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.PreferredLanguage" class="form-label">Ngôn ngữ</label>
                        <input asp-for="AppUserForm.PreferredLanguage" class="form-control" />
                    </div>

                    <div>
                        <label asp-for="AppUserForm.DevicePlatform" class="form-label">Thiết bị</label>
                        <input asp-for="AppUserForm.DevicePlatform" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-dark w-100">
                        @(Model.AppUserForm.IsEditMode ? "Lưu app user" : "Thêm app user")
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const roleSelect = document.getElementById("adminRoleSelect");
            const ownerFields = Array.from(document.querySelectorAll(".owner-field"));

            const updateOwnerFields = () => {
                const isOwner = roleSelect?.value === "PoiOwner";
                ownerFields.forEach((field) => {
                    field.classList.toggle("d-none", !isOwner);
                });
            };

            roleSelect?.addEventListener("change", updateOwnerFields);
            updateOwnerFields();
        })();
    </script>
}
