@model AudioManagementViewModel
@{
    ViewData["Title"] = "Quáº£n lÃ½ Audio / TTS";
    var selectedPoiName = Model.Pois.FirstOrDefault(x => x.Id == Model.Editor.PoiId)?.Name ?? "ChÆ°a chá»n POI";
}

<style>
    .audio-page {
        --audio-ink: #0f172a;
        --audio-muted: #64748b;
        --audio-panel: rgba(255,255,255,0.96);
        --audio-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        color: var(--audio-ink);
    }

    .audio-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .audio-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .audio-head p {
        margin: 0.45rem 0 0;
        color: var(--audio-muted);
        max-width: 760px;
    }

    .audio-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.9fr);
        gap: 1.2rem;
    }

    .audio-panel {
        background: var(--audio-panel);
        border-radius: 28px;
        box-shadow: var(--audio-shadow);
        overflow: hidden;
    }

    .audio-table {
        margin-bottom: 0;
        --bs-table-bg: transparent;
    }

    .audio-table thead th {
        background: rgba(248, 250, 252, 0.98);
        color: var(--audio-muted);
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 1rem 1.1rem;
        border-bottom-width: 0;
    }

    .audio-table tbody td {
        padding: 1rem 1.1rem;
        border-color: rgba(148, 163, 184, 0.12);
        vertical-align: middle;
    }

    .audio-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.36rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 700;
    }

    .audio-pill.source-tts {
        background: #e0f2fe;
        color: #0369a1;
    }

    .audio-pill.source-file {
        background: #ede9fe;
        color: #6d28d9;
    }

    .audio-pill.status-published {
        background: #dcfce7;
        color: #166534;
    }

    .audio-pill.status-draft {
        background: #fef3c7;
        color: #92400e;
    }

    .audio-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .audio-panel-body {
        padding: 1.4rem;
    }

    .audio-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .audio-form-grid .full {
        grid-column: 1 / -1;
    }

    .audio-page .form-control,
    .audio-page .form-select {
        min-height: 48px;
        border-radius: 16px;
        border-color: rgba(148, 163, 184, 0.24);
    }

    .audio-page textarea.form-control {
        min-height: 150px;
    }

    .audio-preview {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 22px;
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    }

    .audio-preview-label {
        color: var(--audio-muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .audio-preview-title {
        margin-top: 0.45rem;
        font-size: 1.25rem;
        font-weight: 800;
    }

    @@media (max-width: 1199.98px) {
        .audio-layout {
            grid-template-columns: 1fr;
        }

        .audio-head {
            flex-direction: column;
        }
    }
</style>

<div class="audio-page">
    <div class="audio-head">
        <div>
            <h1>Quáº£n lÃ½ Audio / TTS</h1>
        </div>
        <a asp-action="Index" asp-route-createNew="true" class="btn btn-primary btn-lg rounded-pill px-4">+ Táº¡o audio má»›i</a>
    </div>

    @if (TempData["AudioMessage"] is string audioMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@audioMessage</div>
    }

    <div class="audio-layout">
        <div class="audio-panel">
            <div class="table-responsive">
                <table class="table audio-table align-middle">
                    <thead>
                        <tr>
                            <th>TÃªn POI</th>
                            <th>NgÃ´n ngá»¯</th>
                            <th>Loáº¡i audio</th>
                            <th>Tráº¡ng thÃ¡i</th>
                            <th>NgÃ y cáº­p nháº­t</th>
                            <th>Thao tÃ¡c</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="fw-semibold">@item.PoiName</td>
                            <td>@item.Language</td>
                            <td>
                                <span class="audio-pill @(item.SourceType == "File" ? "source-file" : "source-tts")">
                                    @item.SourceType
                                </span>
                            </td>
                            <td>
                                <span class="audio-pill @(item.IsPublished ? "status-published" : "status-draft")">
                                    @(item.IsPublished ? "Äang dÃ¹ng" : "Báº£n nhÃ¡p")
                                </span>
                            </td>
                            <td>@item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="audio-actions">
                                    <a asp-action="Index" asp-route-audioId="@item.Id" class="btn btn-outline-primary btn-sm rounded-pill">Cáº­p nháº­t láº¡i</a>
                                    <button type="button"
                                            class="btn btn-outline-dark btn-sm rounded-pill js-audio-preview"
                                            data-script="@(item.SourceType == "TTS" ? item.ContentOrFile : string.Empty)">
                                        PhÃ¡t thá»­ audio
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="audio-panel">
            <div class="audio-panel-body">
                <form asp-action="Save" method="post" id="audioForm">
                    @Html.AntiForgeryToken()
                    <input asp-for="Editor.Id" type="hidden" />

                    <div class="audio-form-grid">
                        <div class="full">
                            <label asp-for="Editor.PoiId" class="form-label">Chá»n POI</label>
                            <select asp-for="Editor.PoiId" class="form-select" id="audioPoiId">
                                <option value="0">Chá»n Ä‘iá»ƒm cáº§n gáº¯n audio</option>
                                @foreach (var poi in Model.Pois)
                                {
                                    <option value="@poi.Id">@poi.Name</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.Language" class="form-label">Chá»n ngÃ´n ngá»¯</label>
                            <select asp-for="Editor.Language" class="form-select">
                                <option value="vi-VN">Tiáº¿ng Viá»‡t</option>
                                <option value="en-US">Tiáº¿ng Anh</option>
                                <option value="zh-CN">Tiáº¿ng Trung</option>
                                <option value="ko-KR">Tiáº¿ng HÃ n</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.SourceType" class="form-label">TTS hay file audio</label>
                            <select asp-for="Editor.SourceType" class="form-select" id="audioSourceType">
                                <option value="TTS">TTS</option>
                                <option value="File">File audio</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.VoiceType" class="form-label">Giá»ng Ä‘á»c</label>
                            <select asp-for="Editor.VoiceType" class="form-select">
                                <option value="Female">Female</option>
                                <option value="Male">Male</option>
                                <option value="Neutral">Neutral</option>
                            </select>
                        </div>

                        <div>
                            <label asp-for="Editor.EstimatedSeconds" class="form-label">Thá»i lÆ°á»£ng dá»± kiáº¿n</label>
                            <input asp-for="Editor.EstimatedSeconds" class="form-control" id="audioEstimatedSeconds" />
                        </div>

                        <div class="full" id="ttsScriptGroup">
                            <label asp-for="Editor.Script" class="form-label">Nháº­p script</label>
                            <textarea asp-for="Editor.Script" class="form-control" id="audioScript"></textarea>
                        </div>

                        <div class="full d-none" id="audioFileGroup">
                            <label asp-for="Editor.FilePath" class="form-label">ÄÆ°á»ng dáº«n file audio</label>
                            <input asp-for="Editor.FilePath" class="form-control" />
                        </div>

                        <div class="full">
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Editor.IsPublished" class="form-check-input" />
                                <label asp-for="Editor.IsPublished" class="form-check-label">Tráº¡ng thÃ¡i xuáº¥t báº£n</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">LÆ°u / cáº­p nháº­t</button>
                        <button type="button" class="btn btn-outline-dark rounded-pill px-4" id="previewSpeechButton">Nghe thá»­</button>
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" id="generateTtsButton">Sinh TTS</button>
                        <button type="button" class="btn btn-outline-success rounded-pill px-4" id="downloadAudioButton">Táº£i xuá»‘ng</button>
                    </div>
                </form>

                <div class="audio-preview">
                    <div class="audio-preview-label">Preview</div>
                    <div class="audio-preview-title" id="audioPreviewPoi">@selectedPoiName</div>
                    <div class="text-muted mt-2" id="audioPreviewSummary">
                        @(Model.Editor.SourceType == "File"
                            ? "Báº£n ghi Ä‘ang dÃ¹ng nguá»“n file audio."
                            : "Báº£n ghi Ä‘ang dÃ¹ng TTS vÃ  cÃ³ thá»ƒ nghe thá»­ trá»±c tiáº¿p trÃªn trÃ¬nh duyá»‡t.")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const scriptInput = document.getElementById("audioScript");
            const sourceType = document.getElementById("audioSourceType");
            const ttsGroup = document.getElementById("ttsScriptGroup");
            const fileGroup = document.getElementById("audioFileGroup");
            const previewButton = document.getElementById("previewSpeechButton");
            const generateButton = document.getElementById("generateTtsButton");
            const downloadButton = document.getElementById("downloadAudioButton");
            const estimatedSeconds = document.getElementById("audioEstimatedSeconds");
            const poiSelect = document.getElementById("audioPoiId");
            const previewPoi = document.getElementById("audioPreviewPoi");
            const previewSummary = document.getElementById("audioPreviewSummary");

            const syncSourceMode = () => {
                const isFile = sourceType.value === "File";
                ttsGroup.classList.toggle("d-none", isFile);
                fileGroup.classList.toggle("d-none", !isFile);
                previewSummary.textContent = isFile
                    ? "Báº£n ghi Ä‘ang dÃ¹ng nguá»“n file audio."
                    : "Báº£n ghi Ä‘ang dÃ¹ng TTS vÃ  cÃ³ thá»ƒ nghe thá»­ trá»±c tiáº¿p trÃªn trÃ¬nh duyá»‡t.";
            };

            const syncPoiLabel = () => {
                previewPoi.textContent = poiSelect.options[poiSelect.selectedIndex]?.text || "ChÆ°a chá»n POI";
            };

            const speakText = (text) => {
                if (!text || !("speechSynthesis" in window)) {
                    return;
                }

                window.speechSynthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                window.speechSynthesis.speak(utterance);
            };

            sourceType.addEventListener("change", syncSourceMode);
            poiSelect.addEventListener("change", syncPoiLabel);

            previewButton.addEventListener("click", () => {
                speakText(scriptInput.value.trim());
            });

            generateButton.addEventListener("click", () => {
                const words = scriptInput.value.trim().split(/\s+/).filter(Boolean).length;
                estimatedSeconds.value = words > 0 ? Math.max(15, Math.ceil(words / 2.5)) : estimatedSeconds.value;
                previewSummary.textContent = "ÄÃ£ Æ°á»›c lÆ°á»£ng thá»i lÆ°á»£ng TTS dá»±a trÃªn ná»™i dung script hiá»‡n táº¡i.";
            });

            downloadButton.addEventListener("click", () => {
                const content = scriptInput.value.trim();
                const blob = new Blob([content || "ChÆ°a cÃ³ ná»™i dung audio."], { type: "text/plain;charset=utf-8" });
                const url = URL.createObjectURL(blob);
                const link = document.createElement("a");
                link.href = url;
                link.download = "audio-preview.txt";
                link.click();
                URL.revokeObjectURL(url);
            });

            document.querySelectorAll(".js-audio-preview").forEach((button) => {
                button.addEventListener("click", () => {
                    speakText(button.dataset.script || "");
                });
            });

            syncSourceMode();
            syncPoiLabel();
        })();
    </script>
}
