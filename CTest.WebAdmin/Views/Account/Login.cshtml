@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - VK Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: #f3f7fb;
            color: #0f172a;
        }

        .login-panel {
            width: min(440px, calc(100vw - 2rem));
            padding: 1.5rem;
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 8px;
            background: #fff;
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.10);
        }

        .login-title {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 800;
        }

        .login-note {
            margin-top: 0.45rem;
            color: #64748b;
        }
    </style>
</head>
<body>
    <main class="login-panel">
        <h1 class="login-title">VK Admin</h1>
        <p class="login-note">Đăng nhập bằng tài khoản Admin hoặc Chủ nhà hàng.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="mb-3">
                <label asp-for="Username" class="form-label">Tài khoản</label>
                <input asp-for="Username" class="form-control" autocomplete="username" autofocus />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" class="form-control" type="password" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
        </form>
    </main>
</body>
</html>
