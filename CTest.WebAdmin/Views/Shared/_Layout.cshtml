<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Phố Ẩm Thực Vĩnh Khánh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        body {
            background-color: #f4f8ff;
        }

        .sidebar {
            width: 270px;
            min-height: 100vh;
            background: linear-gradient(180deg, #0d6efd 0%, #0a58ca 100%) !important;
        }

        .sidebar .nav-link {
            border-radius: 10px;
            padding: 10px 12px;
            transition: 0.2s ease-in-out;
        }

        .sidebar .nav-link:hover {
            background-color: rgba(255,255,255,0.18);
        }

        .content-area {
            min-height: 100vh;
            background-color: #f4f8ff;
        }

        header {
            background: #e7f1ff !important;
            border-bottom: 1px solid #cfe2ff !important;
        }

        .card, .table, .alert {
            border-radius: 14px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <aside class="sidebar text-white p-3">
            <h4 class="mb-4">Quản lý phố ẩm thực Vĩnh Khánh</h4>
            <nav class="nav flex-column gap-2">
                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-link text-white" asp-controller="Pois" asp-action="Index">Quản lý POI</a>
                <a class="nav-link text-white" asp-controller="AudioGuides" asp-action="Index">Audio / TTS</a>
                <a class="nav-link text-white" asp-controller="Translations" asp-action="Index">Bản dịch</a>
                <a class="nav-link text-white" asp-controller="QrCodes" asp-action="Index">QR code</a>
                <a class="nav-link text-white" asp-controller="Tours" asp-action="Index">Tour</a>
                <a class="nav-link text-white" asp-controller="Users" asp-action="Index">Quan ly nguoi dung</a>
                <a class="nav-link text-white" asp-controller="UsageLogs" asp-action="Index">Lịch sử sử dụng</a>
            </nav>
        </aside>

        <main class="content-area flex-grow-1">
            <header class="px-4 py-3">
                <div>
                    <div class="fw-semibold fs-5 text-primary">Hệ thống quản trị thuyết minh tự động</div>
                </div>
            </header>

            <div class="p-4">
                @RenderBody()
            </div>
        </main>
    </div>

          <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
