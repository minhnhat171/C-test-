<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.TourPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="TourPageRoot"
    Title="{Binding TourPageTitle}"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,28"
                             Spacing="18">
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 30">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#102A43" Offset="0" />
                        <GradientStop Color="#2F80FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="20"
                                     Spacing="10">
                    <Label Text="{Binding TourSectionTitle}"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="{Binding TourSectionSummary}"
                           FontSize="14"
                           TextColor="#DCEBFF"
                           LineBreakMode="WordWrap" />

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12,8"
                            HorizontalOptions="Start"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            IsVisible="{Binding HasActiveTour}">
                        <Label Text="{Binding ActiveTourBadgeText}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#2F80FF" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#FFFFFF"
                    Padding="18"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    IsVisible="{Binding HasActiveTour}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding ActiveTourName}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Label Text="{Binding ActiveTourSummary}"
                           FontSize="15"
                           TextColor="#486581"
                           LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Border BackgroundColor="#F4F8FF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding CurrentStopTitle}"
                                       FontSize="13"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding ActiveTourCurrentStopText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#163B6D" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#F4F8FF"
                                Padding="14"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding NextStopTitle}"
                                       FontSize="13"
                                       TextColor="#6B7C93" />
                                <Label Text="{Binding ActiveTourNextStopText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#163B6D" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Button Text="{Binding ViewRouteButtonText}"
                                Clicked="OnOpenActiveTourClicked"
                                BackgroundColor="#2F80FF"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="18" />

                        <Button Grid.Column="1"
                                Text="{Binding StopTourButtonText}"
                                Clicked="OnStopActiveTourClicked"
                                BackgroundColor="#102A43"
                                TextColor="White"
                                FontSize="16"
                                CornerRadius="18"
                                Padding="16,0" />
                    </Grid>

                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding ActiveTourStops}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#F8FBFF"
                                        Padding="14"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTourStopTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <Border BackgroundColor="#2F80FF"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <Label Text="{Binding Order}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="3">
                                            <Label Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#102A43" />
                                            <Label Text="{Binding Address}"
                                                   FontSize="14"
                                                   TextColor="#6B7C93"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="2" />
                                            <Label Text="{Binding StatusLabel}"
                                                   FontSize="13"
                                                   TextColor="#2F80FF" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#F8FBFF"
                    Padding="16"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    IsVisible="{Binding HasNoTourNotice}">
                <Label Text="{Binding NoTourNoticeText}"
                       FontSize="15"
                       TextColor="#5E7491"
                       LineBreakMode="WordWrap" />
            </Border>

            <VerticalStackLayout Spacing="14"
                                 IsVisible="{Binding IsTourPackageListVisible}"
                                 BindableLayout.ItemsSource="{Binding TourPackages}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#FFFFFF"
                                Padding="18"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 28">
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">
                                    <Border BackgroundColor="#E8F1FF"
                                            Padding="12"
                                            StrokeThickness="0"
                                            WidthRequest="48"
                                            HeightRequest="48"
                                            StrokeShape="RoundRectangle 18">
                                        <Image Source="tour_route_icon.svg"
                                               Aspect="AspectFit" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#102A43"
                                               LineBreakMode="WordWrap" />
                                        <Label Text="{Binding MetaLabel}"
                                               FontSize="14"
                                               TextColor="#4F7096" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Label Text="{Binding Description}"
                                       FontSize="15"
                                       TextColor="#486581"
                                       LineBreakMode="WordWrap" />

                                <Border BackgroundColor="#F4F8FF"
                                        Padding="12"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="{Binding StopsSummary}"
                                           FontSize="14"
                                           TextColor="#486581"
                                           LineBreakMode="WordWrap" />
                                </Border>

                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <Button Text="{Binding ActionLabel}"
                                            Clicked="OnStartTourClicked"
                                            BackgroundColor="#2F80FF"
                                            TextColor="White"
                                            FontSize="15"
                                            CornerRadius="18" />

                                    <Border Grid.Column="1"
                                            BackgroundColor="#E8F1FF"
                                            Padding="12,10"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Label Text="{Binding StatusLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#2F80FF" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
