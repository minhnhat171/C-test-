@model PoiManagementViewModel
@{
    ViewData["Title"] = "Quản lý POI";
}

<style>
    .poi-page {
        --poi-ink: #0f172a;
        --poi-muted: #64748b;
        --poi-line: rgba(148, 163, 184, 0.2);
        --poi-panel: rgba(255, 255, 255, 0.96);
        --poi-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        color: var(--poi-ink);
    }

    .poi-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .poi-hero h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.6rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .poi-hero p {
        margin: 0.45rem 0 0;
        color: var(--poi-muted);
        max-width: 760px;
    }

    .poi-panel {
        background: var(--poi-panel);
        border: 1px solid rgba(255,255,255,0.84);
        border-radius: 26px;
        box-shadow: var(--poi-shadow);
    }

    .poi-toolbar {
        padding: 1.2rem;
        margin-bottom: 1rem;
    }

    .poi-toolbar-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) 220px auto;
        gap: 0.9rem;
    }

    .poi-toolbar .form-control,
    .poi-toolbar .form-select {
        min-height: 48px;
        border-radius: 16px;
        border-color: rgba(148, 163, 184, 0.26);
    }

    .poi-table-wrap {
        overflow: hidden;
    }

    .poi-table {
        margin-bottom: 0;
        --bs-table-bg: transparent;
    }

    .poi-table thead th {
        background: rgba(248, 250, 252, 0.98);
        color: var(--poi-muted);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border-bottom-width: 0;
        padding: 1rem 1.1rem;
        vertical-align: middle;
        white-space: nowrap;
    }

    .poi-table tbody td {
        padding: 1rem 1.1rem;
        border-color: rgba(148, 163, 184, 0.12);
        vertical-align: middle;
    }

    .poi-id {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        height: 32px;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-weight: 800;
    }

    .poi-name {
        font-weight: 800;
    }

    .poi-address {
        color: var(--poi-muted);
        font-size: 0.92rem;
        margin-top: 0.2rem;
    }

    .poi-coordinates {
        font-family: Consolas, monospace;
        font-size: 0.9rem;
    }

    .poi-status {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.38rem 0.8rem;
        font-size: 0.84rem;
        font-weight: 700;
    }

    .poi-status.active {
        background: #dcfce7;
        color: #166534;
    }

    .poi-status.inactive {
        background: #fef2f2;
        color: #b91c1c;
    }

    .poi-status.pending {
        background: #fef3c7;
        color: #92400e;
    }

    .poi-owner-note {
        color: var(--poi-muted);
        font-size: 0.84rem;
        margin-top: 0.25rem;
    }

    .poi-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        justify-content: flex-end;
    }

    .poi-action-btn {
        border-radius: 999px;
        padding: 0.45rem 0.85rem;
        font-size: 0.84rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .poi-empty {
        padding: 2rem;
        text-align: center;
        color: var(--poi-muted);
    }

    @@media (max-width: 991.98px) {
        .poi-toolbar-grid {
            grid-template-columns: 1fr;
        }

        .poi-hero {
            flex-direction: column;
        }
    }
</style>

<div class="poi-page">
    <div class="poi-hero">
        <div>
            <h1>Quản lý POI</h1>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="MapPois" asp-action="Index" class="btn btn-outline-dark btn-lg rounded-pill px-4">Map Analytics</a>
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4">+ Thêm POI</a>
        </div>
    </div>

    @if (TempData["PoiMessage"] is string poiMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@poiMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
    }

    <div class="poi-panel poi-toolbar">
        <form method="get" asp-action="Index">
            <div class="poi-toolbar-grid">
                <input class="form-control" type="search" name="searchTerm" value="@Model.SearchTerm" placeholder="Tìm kiếm theo tên điểm..." />

                <select class="form-select" name="statusFilter">
                    <option value="all" selected="@(Model.StatusFilter == "all" ? "selected" : null)">Tất cả trạng thái</option>
                    <option value="active" selected="@(Model.StatusFilter == "active" ? "selected" : null)">Đang hoạt động</option>
                    <option value="pending" selected="@(Model.StatusFilter == "pending" ? "selected" : null)">Chờ duyệt</option>
                    <option value="inactive" selected="@(Model.StatusFilter == "inactive" ? "selected" : null)">Tạm khóa</option>
                </select>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-dark rounded-pill px-4 flex-grow-1">Lọc dữ liệu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Đặt lại</a>
                </div>
            </div>
        </form>
    </div>

    <div class="poi-panel poi-table-wrap">
        <div class="table-responsive">
            <table class="table poi-table align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên điểm</th>
                        <th>Địa chỉ</th>
                        <th>Tọa độ</th>
                        <th>Bán kính</th>
                        <th>Ưu tiên</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><span class="poi-id" title="@item.Id">@item.DisplayId</span></td>
                            <td>
                                <div class="poi-name">@item.Name</div>
                                <div class="poi-address">@item.Code</div>
                                @if (item.IsOwnerSubmitted)
                                {
                                    <div class="poi-owner-note">Chủ quán: @(string.IsNullOrWhiteSpace(item.OwnerLabel) ? "Chưa rõ" : item.OwnerLabel)</div>
                                }
                            </td>
                            <td>@item.Address</td>
                            <td class="poi-coordinates">@item.Latitude, @item.Longitude</td>
                            <td>@item.RadiusInMeters m</td>
                            <td>@item.Priority</td>
                            <td>
                                <span class="poi-status @item.ApprovalStatusCssClass">@item.ApprovalStatusLabel</span>
                            </td>
                            <td class="text-end">
                                <div class="poi-actions">
                                    @if (item.IsPendingApproval)
                                    {
                                        <form asp-action="Approve" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-success poi-action-btn">Duyệt</button>
                                        </form>
                                    }
                                    <a asp-controller="MapPois" asp-action="Index" asp-route-poiId="@item.Id" class="btn btn-outline-secondary poi-action-btn">Map Analytics</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark poi-action-btn">Xem</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary poi-action-btn">Sửa</a>
                                    <a asp-controller="QrCodes" asp-action="Index" asp-route-selectedTargetType="poi" asp-route-selectedTargetId="@item.Id" class="btn btn-outline-success poi-action-btn">Tạo QR</a>
                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa POI này không?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger poi-action-btn">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="poi-empty">Không tìm thấy POI phù hợp với bộ lọc hiện tại.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
