<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
    x:Name="MainRootPage"
    x:Class="VinhKhanhGuide.App.Views.MainPage"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView x:Name="MainScrollView"
                    Grid.Row="0">
            <VerticalStackLayout Padding="16,18,16,14"
                                 Spacing="14">
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#102A43" Offset="0" />
                            <GradientStop Color="#2F80FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Padding="16"
                                         Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Vinh Khanh Guide"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#DCEBFF" />

                                <Label Text="{Binding GreetingText}"
                                       FontSize="25"
                                       FontAttributes="Bold"
                                       TextColor="White" />

                                <Label Text="{Binding HomeIntroText}"
                                       FontSize="14"
                                       TextColor="#EAF3FF"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding CurrentUserInitials}"
                                    Clicked="OnOpenAccountPageClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#2F80FF"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    CornerRadius="25"
                                    Padding="0" />
                        </Grid>

                        <Border BackgroundColor="#FFFFFF"
                                StrokeThickness="0"
                                Padding="12"
                                StrokeShape="RoundRectangle 20">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#102A43" />
                                    <Label Text="{Binding LocationText}"
                                           FontSize="12"
                                           TextColor="#4F7096" />
                                    <Label Text="{Binding NearestPoiText}"
                                           FontSize="12"
                                           TextColor="#4F7096"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#D9E9FF"
                                        StrokeThickness="0"
                                        Padding="10,6"
                                        VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 16">
                                    <Label Text="{Binding MapModeBadgeText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#2F80FF" />
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        Padding="14"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding FirstTimeGuideTitle}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Label Text="{Binding HomePrimaryCtaHintText}"
                                   FontSize="13"
                                   TextColor="#6B7C93"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Border BackgroundColor="#F4F8FF"
                                    Padding="10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding FirstTimeGuideStepOneTitle}"
                                               FontSize="12"
                                               TextColor="#6B7C93" />
                                        <Label Text="{Binding FirstTimeGuideStepOneText}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#102A43" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="{Binding HomePrimaryCtaText}"
                                            Clicked="OnTourShortcutClicked"
                                            BackgroundColor="#102A43"
                                            TextColor="White"
                                            FontSize="12"
                                            CornerRadius="15"
                                            Padding="10,7"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F4F8FF"
                                    Padding="10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding FirstTimeGuideStepTwoTitle}"
                                               FontSize="12"
                                               TextColor="#6B7C93" />
                                        <Label Text="{Binding FirstTimeGuideStepTwoText}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#102A43" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="{Binding SearchSectionTitle}"
                                            Clicked="OnSearchGuideClicked"
                                            BackgroundColor="#E8F1FF"
                                            TextColor="#2F80FF"
                                            FontSize="12"
                                            CornerRadius="15"
                                            Padding="10,7"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F4F8FF"
                                    Padding="10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding FirstTimeGuideStepThreeTitle}"
                                               FontSize="12"
                                               TextColor="#6B7C93" />
                                        <Label Text="{Binding FirstTimeGuideStepThreeText}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#102A43" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="{Binding MapOpenLargeText}"
                                            Clicked="OnOpenFullScreenMapClicked"
                                            BackgroundColor="#E8F1FF"
                                            TextColor="#2F80FF"
                                            FontSize="12"
                                            CornerRadius="15"
                                            Padding="10,7"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <Border BackgroundColor="#F4F8FF"
                                    Padding="10"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="QR"
                                               FontSize="12"
                                               TextColor="#6B7C93" />
                                        <Label Text="Quét QR để mở nhanh POI hoặc tour."
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#102A43" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="Quét"
                                            Clicked="OnOpenQrScannerClicked"
                                            BackgroundColor="#2F80FF"
                                            TextColor="White"
                                            FontSize="12"
                                            CornerRadius="15"
                                            Padding="10,7"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding SearchSectionTitle}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Border BackgroundColor="#FFFFFF"
                            Padding="18,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <Label Text="⌕"
                                   FontSize="20"
                                   TextColor="#7B8BA3"
                                   VerticalTextAlignment="Center" />

                            <Entry x:Name="RestaurantSearchEntry"
                                   Grid.Column="1"
                                   Text="{Binding SearchQuery}"
                                   Placeholder="{Binding SearchPlaceholderText}"
                                   Completed="OnSearchCompleted"
                                   Focused="OnSearchFocused"
                                   Unfocused="OnSearchUnfocused"
                                   ReturnType="Search"
                                   BackgroundColor="Transparent"
                                   FontSize="17"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD"
                                   VerticalTextAlignment="Center" />

                            <Button Grid.Column="2"
                                    Text="✕"
                                    Clicked="OnClearSearchClicked"
                                    IsVisible="{Binding HasSearchQuery}"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    WidthRequest="34"
                                    HeightRequest="34"
                                    CornerRadius="17"
                                    Padding="0"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            IsVisible="{Binding HasSearchPreviewResults}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Label Text="{Binding SearchPreviewSummaryText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Button Grid.Column="1"
                                        Text="{Binding SearchPreviewOpenAllText}"
                                        Clicked="OnOpenPoiBrowsePageClicked"
                                        BackgroundColor="#E8F1FF"
                                        TextColor="#2F80FF"
                                        FontSize="13"
                                        CornerRadius="16"
                                        Padding="12,8" />
                            </Grid>

                            <VerticalStackLayout Spacing="8"
                                                 BindableLayout.ItemsSource="{Binding SearchPreviewItems}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F8FBFF"
                                                Padding="14"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="10">
                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="{Binding Name}"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="#102A43" />
                                                        <Label Text="{Binding Address}"
                                                               FontSize="13"
                                                               TextColor="#6B7C93"
                                                               LineBreakMode="TailTruncation" />
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding DistanceLabel}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#2F80FF"
                                                           VerticalOptions="Center" />
                                                </Grid>

                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="10">
                                                    <Button Text="{Binding Source={x:Reference MainRootPage}, Path=BindingContext.SelectedPoiDetailButtonText}"
                                                            Clicked="OnSearchPreviewDetailClicked"
                                                            BackgroundColor="#E8F1FF"
                                                            TextColor="#2F80FF"
                                                            FontSize="14"
                                                            CornerRadius="16" />

                                                    <Button Grid.Column="1"
                                                            Text="{Binding NarrationActionText}"
                                                            Clicked="OnSearchPreviewNarrationClicked"
                                                            BackgroundColor="#2F80FF"
                                                            TextColor="White"
                                                            FontSize="14"
                                                            CornerRadius="16" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            IsVisible="{Binding IsSearchSuggestionsVisible}">
                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding SearchSuggestions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FBFF"
                                            Padding="12,10"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSearchSuggestionTapped" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10">
                                            <Label Text="{Binding LeadingIcon}"
                                                   FontSize="18"
                                                   TextColor="#5E7491"
                                                   VerticalTextAlignment="Center" />

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="{Binding Text}"
                                                       FontSize="15"
                                                       TextColor="#102A43" />
                                                <Label Text="{Binding SupportingText}"
                                                       FontSize="13"
                                                       TextColor="#6B7C93"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding SearchResultStatusText}"
                           FontSize="14"
                           TextColor="#7B8BA3"
                           IsVisible="{Binding IsSearchResultEmpty}" />
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Padding="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="18,18,18,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding MapSectionTitle}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Label Text="{Binding MapPoiBadgeText}"
                                       FontSize="14"
                                       TextColor="#6B7C93" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding MapOpenLargeText}"
                                    Clicked="OnOpenFullScreenMapClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="16"
                                    Padding="14,8" />
                        </Grid>

                        <Border BackgroundColor="#F4F8FF"
                                Margin="18,0,18,12"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasMapCategoryFilter}">
                            <Label Text="{Binding ActiveMapCategoryFilterText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#2F80FF" />
                        </Border>

                        <Grid>
                            <mapsui:MapView x:Name="RestaurantMap"
                                            HeightRequest="240"
                                            IsZoomButtonVisible="False"
                                            IsNorthingButtonVisible="False"
                                            IsMyLocationButtonVisible="False"
                                            RotationLock="True" />

                            <VerticalStackLayout Spacing="8"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="End"
                                                 Margin="0,0,14,14">
                                <Button Text="+"
                                        Clicked="OnZoomInClicked"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#1685FF"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        Padding="0" />

                                <Button Text="-"
                                        Clicked="OnZoomOutClicked"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#1685FF"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        Padding="0" />

                                <ImageButton Source="locate_control_icon.svg"
                                             Clicked="OnCenterCurrentLocationClicked"
                                             Aspect="AspectFit"
                                             Padding="10"
                                        BackgroundColor="#FFFFFF"
                                             WidthRequest="40"
                                             HeightRequest="40"
                                             CornerRadius="20" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid Padding="18,14,18,18"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Text="{Binding StartGpsButtonText}"
                                    Clicked="OnStartTrackingClicked"
                                    IsEnabled="{Binding CanStartTracking}"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="{Binding StopGpsButtonText}"
                                    Clicked="OnStopTrackingClicked"
                                    IsEnabled="{Binding IsTracking}"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="2"
                                    Text="{Binding GoToEntranceButtonText}"
                                    Clicked="OnGpsOriginClicked"
                                    BackgroundColor="#102A43"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFF7ED"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasOfflineSnapshotNotice}">
                    <Label Text="{Binding OfflineSnapshotNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#9A3412"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#EEF7FF"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasManualLocationNotice}">
                    <Label Text="{Binding ManualLocationNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#1D4ED8"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#F8FAFC"
                        Padding="10"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasNoTourNotice}">
                    <Label Text="{Binding NoTourNoticeText}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#475569"
                           LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="#102A43"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding TourSectionTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White" />
                        <Label Text="{Binding TourSectionSummary}"
                               FontSize="14"
                               TextColor="#DCEBFF"
                               LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Button Text="{Binding HomePrimaryCtaText}"
                                    Clicked="OnOpenTourPageClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#102A43"
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    CornerRadius="18"
                                    HeightRequest="50" />

                            <Button Grid.Column="1"
                                    Text="{Binding StopTourButtonText}"
                                    Clicked="OnStopActiveTourClicked"
                                    BackgroundColor="#FFE7E1"
                                    TextColor="#B42318"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    CornerRadius="18"
                                    Padding="16,0"
                                    HeightRequest="50"
                                    IsVisible="{Binding HasActiveTour}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <Label Text="{Binding SelectedPoiSectionTitle}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Button Grid.Column="1"
                                    Text="{Binding PoiBrowseOpenPageText}"
                                    Clicked="OnOpenPoiBrowsePageClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="14"
                                    CornerRadius="16"
                                    Padding="12,8" />
                        </Grid>

                        <Grid ColumnDefinitions="104,*"
                              ColumnSpacing="14">
                            <Border BackgroundColor="#E8F1FF"
                                    HeightRequest="104"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 22">
                                <Image Source="{Binding SelectedPoiImageSource}"
                                       Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6">
                                <Label Text="{Binding SelectedPoiName}"
                                       FontSize="21"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding SelectedPoiAddress}"
                                       FontSize="14"
                                       TextColor="#6B7C93"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Text="{Binding SelectedPoiStatusText}"
                                       FontSize="14"
                                       TextColor="#4F7096"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding SelectedPoiNarrationStateText}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#2F80FF"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{Binding SelectedPoiDescription}"
                               FontSize="15"
                               TextColor="#486581"
                               LineBreakMode="TailTruncation"
                               MaxLines="3" />

                        <Border BackgroundColor="#F4F8FF"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiDish}">
                            <Label Text="{Binding SelectedPoiDishText}"
                                   FontSize="14"
                                   TextColor="#2F80FF"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <Button Text="{Binding SelectedPoiNarrationActionText}"
                                    Clicked="OnNarrateSelectedClicked"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="16"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="{Binding SelectedPoiDetailButtonText}"
                                    Clicked="OnOpenSelectedPoiDetailClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="16"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FFFFFF"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding ListeningHistorySectionTitle}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Label Text="{Binding ListeningHistorySectionSummary}"
                                       FontSize="14"
                                       TextColor="#6B7C93"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding ListeningHistorySeeAllText}"
                                    Clicked="OnOpenHistoryPageClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="16"
                                    Padding="14,8" />
                        </Grid>

                        <Border BackgroundColor="#F8FBFF"
                                Padding="16"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 20"
                                IsVisible="{Binding IsListeningHistoryDisplayEmpty}">
                            <Label Text="{Binding ListeningHistoryEmptyStateText}"
                                   FontSize="15"
                                   TextColor="#5E7491"
                                   LineBreakMode="WordWrap" />
                        </Border>

                        <VerticalStackLayout Spacing="10"
                                             BindableLayout.ItemsSource="{Binding ListeningHistoryPreviewItems}"
                                             IsVisible="{Binding HasListeningHistoryPreview}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FBFF"
                                            Padding="14"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnListeningHistoryPreviewTapped" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <Border BackgroundColor="#E8F1FF"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 22">
                                                <Label Text="▶"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#2F80FF" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="8">
                                                    <Label Text="{Binding PoiName}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="#102A43"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="1"
                                                           Text="{Binding StartedAtShortLabel}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="#2F80FF"
                                                           VerticalOptions="Center" />
                                                </Grid>

                                                <Label Text="{Binding DetailSummaryLabel}"
                                                       FontSize="13"
                                                       TextColor="#486581"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding StatusLabel}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding StatusAccentColor}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding FeaturedSectionTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding FeaturedSectionSummary}"
                               FontSize="14"
                               TextColor="#6B7C93"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding FeaturedDishes}"
                                    SelectionMode="None"
                                    HeightRequest="138">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="4"
                                             HorizontalItemSpacing="10"
                                             VerticalItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{Binding BackgroundColor}"
                                        Padding="12"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 24">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFeaturedDishCategoryTapped" />
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout Spacing="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center">
                                        <Border BackgroundColor="White"
                                                WidthRequest="48"
                                                HeightRequest="48"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 24">
                                            <Label Text="{Binding Icon}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   FontSize="22" />
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="#102A43" />

                                        <Label Text="{Binding CountLabel}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{Binding AccentColor}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Padding="20,8,20,18">
            <Border BackgroundColor="#FFFFFF"
                    Padding="8"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 30">
                <Grid ColumnDefinitions="*,*,*,*,*"
                      ColumnSpacing="7">
                    <Border BackgroundColor="#2F80FF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHomeTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="home_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding HomeNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="White" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenFullScreenMapTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="map_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding MapNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTourShortcutTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="tour_route_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding TourNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoryShortcutTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="history_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding HistoryNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="4"
                            BackgroundColor="#F8FBFF"
                            Padding="6"
                            HeightRequest="70"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenAccountPageTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="3"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="account_nav_icon.svg"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   Aspect="AspectFit" />
                            <Label Text="{Binding SettingsNavigationLabel}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="FullScreenMapOverlay"
              Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#F4F8FF"
              ZIndex="20">
            <Grid RowDefinitions="Auto,*"
                  Padding="16,48,16,20">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <Button Text="←"
                            Clicked="OnCloseFullScreenMapClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            WidthRequest="52"
                            HeightRequest="52"
                            CornerRadius="26" />

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="{Binding FullScreenMapTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding FullScreenMapSubtitle}"
                               FontSize="14"
                               TextColor="#6B7C93" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="{Binding StopListeningButtonText}"
                            Command="{Binding StopNarrationCommand}"
                            IsEnabled="{Binding IsNarrating}"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="15"
                            CornerRadius="20"
                            Padding="14,10" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        BackgroundColor="#FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32">
                    <mapsui:MapView x:Name="FullScreenRestaurantMap"
                                    IsZoomButtonVisible="False"
                                    IsNorthingButtonVisible="False"
                                    IsMyLocationButtonVisible="False"
                                    RotationLock="True" />
                </Border>

                <HorizontalStackLayout Grid.Row="1"
                                       Spacing="8"
                                       HorizontalOptions="Start"
                                       VerticalOptions="End"
                                       Margin="18,0,0,18">
                    <Button Text="Vị trí của tôi"
                            Clicked="OnFullScreenCenterCurrentLocationClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="13"
                            CornerRadius="18"
                            Padding="12,8" />
                    <Button Text="Gần đây"
                            Clicked="OnOpenPoiBrowsePageClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="13"
                            CornerRadius="18"
                            Padding="12,8" />
                    <Button Text="Lọc món"
                            Clicked="OnOpenDishFilterClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="13"
                            CornerRadius="18"
                            Padding="12,8" />
                </HorizontalStackLayout>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="12"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Margin="0,0,18,18">
                    <Button Text="+"
                            Clicked="OnFullScreenZoomInClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="24"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />

                    <Button Text="-"
                            Clicked="OnFullScreenZoomOutClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="24"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />

                    <Button Text="⌖"
                            Clicked="OnFullScreenCenterCurrentLocationClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="20"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
