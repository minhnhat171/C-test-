@model QrScanViewModel
@using System.Text.Json
@{
    Layout = null;
    var narrationText = string.IsNullOrWhiteSpace(Model.NarrationText)
        ? Model.Description
        : Model.NarrationText;
    var shouldAutoOpenApp = Model.AutoOpenApp && !string.IsNullOrWhiteSpace(Model.AppLaunchUrl);
    var hasAudioAsset = !string.IsNullOrWhiteSpace(Model.AudioAssetPath);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.TargetName - QR Audio Guide</title>
    <meta name="description" content="@Model.Description" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-top: #fff4d6;
            --bg-bottom: #f7efe4;
            --card: rgba(255, 255, 255, 0.92);
            --ink: #1f2937;
            --muted: #6b7280;
            --accent: #c2410c;
            --accent-dark: #9a3412;
            --line: rgba(148, 163, 184, 0.18);
            --shadow: 0 28px 60px rgba(31, 41, 55, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.8), transparent 30%),
                linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
            display: flex;
            justify-content: center;
            padding: 24px 16px 48px;
        }

        .scan-shell {
            width: min(100%, 760px);
        }

        .scan-card {
            background: var(--card);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 28px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .scan-hero {
            padding: 22px 22px 18px;
            background:
                radial-gradient(circle at right top, rgba(251, 191, 36, 0.28), transparent 36%),
                linear-gradient(135deg, rgba(255, 247, 237, 0.96), rgba(255, 255, 255, 0.96));
            border-bottom: 1px solid var(--line);
        }

        .scan-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 237, 213, 0.95);
            color: var(--accent-dark);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-title {
            margin: 14px 0 8px;
            font-size: clamp(1.9rem, 1.45rem + 2vw, 2.8rem);
            line-height: 1.06;
            letter-spacing: -0.04em;
        }

        .scan-description {
            margin: 0;
            color: var(--muted);
            line-height: 1.7;
            font-size: 1rem;
        }

        .scan-body {
            padding: 22px;
            display: grid;
            gap: 16px;
        }

        .scan-panel {
            border-radius: 22px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, 0.8);
            padding: 18px;
        }

        .scan-panel-label {
            margin: 0 0 10px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-control-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .scan-control {
            display: grid;
            gap: 8px;
        }

        .scan-select {
            width: 100%;
            min-height: 48px;
            border: 1px solid rgba(194, 65, 12, 0.16);
            border-radius: 16px;
            background: #fff7ed;
            color: var(--ink);
            font: inherit;
            padding: 0 14px;
        }

        .scan-text {
            margin: 0;
            line-height: 1.8;
            white-space: pre-wrap;
        }

        .scan-meta {
            display: grid;
            gap: 12px;
        }

        .scan-stop-list {
            margin: 0;
            padding-left: 1.2rem;
            line-height: 1.8;
        }

        .scan-meta-item {
            padding: 14px 16px;
            border-radius: 18px;
            background: #fffaf2;
            border: 1px solid rgba(251, 191, 36, 0.18);
        }

        .scan-meta-label {
            display: block;
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .scan-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .scan-btn {
            appearance: none;
            border: 0;
            border-radius: 999px;
            padding: 14px 18px;
            font: inherit;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .scan-btn:hover {
            transform: translateY(-1px);
        }

        .scan-btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, #ea580c 100%);
            color: white;
            box-shadow: 0 18px 30px rgba(194, 65, 12, 0.22);
        }

        .scan-btn-secondary {
            background: #fff7ed;
            color: var(--accent-dark);
            border: 1px solid rgba(194, 65, 12, 0.16);
        }

        .scan-link {
            color: var(--accent-dark);
            word-break: break-all;
        }

        .scan-note {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        @@media (max-width: 640px) {
            body {
                padding-inline: 12px;
            }

            .scan-hero,
            .scan-body {
                padding: 18px;
            }

            .scan-control-grid,
            .scan-actions {
                grid-template-columns: 1fr;
                display: grid;
            }

            .scan-btn {
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <main class="scan-shell">
        <section class="scan-card">
            <header class="scan-hero">
                <div class="scan-badge">@Model.TargetKindLabel QR Audio Guide</div>
                <h1 class="scan-title">@Model.TargetName</h1>
                <p class="scan-description">@Model.Description</p>
            </header>

            <div class="scan-body">
                <section class="scan-panel">
                    <p class="scan-panel-label">Nghe thuyet minh</p>

                    <div class="scan-control-grid">
                        <label class="scan-control">
                            <span class="scan-meta-label">Ngon ngu</span>
                            <select class="scan-select" id="languageSelect">
                                <option value="vi">Tieng Viet</option>
                                <option value="en">English</option>
                                <option value="zh">Chinese</option>
                                <option value="ko">Korean</option>
                                <option value="fr">Francais</option>
                            </select>
                        </label>

                        <label class="scan-control">
                            <span class="scan-meta-label">Che do nghe</span>
                            <select class="scan-select" id="playbackModeSelect">
                                <option value="tts">Giong doc tu dong</option>
                                <option value="audio">Ban thu san</option>
                            </select>
                        </label>
                    </div>

                    <div class="scan-actions">
                        @if (shouldAutoOpenApp)
                        {
                            <button type="button" class="scan-btn scan-btn-primary" id="openAppBtn">Mo app va nghe ngay</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="speakBtn">Nghe tren web</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="stopBtn">Dung doc web</button>
                        }
                        else
                        {
                            <button type="button" class="scan-btn scan-btn-primary" id="speakBtn">Nghe ngay</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="stopBtn">Dung doc</button>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.MapLink))
                        {
                            <a class="scan-btn scan-btn-secondary" href="@Model.MapLink" target="_blank" rel="noopener noreferrer">Mo ban do</a>
                        }
                        <a class="scan-btn scan-btn-secondary" href="/download-app">Tai ung dung</a>
                    </div>

                    <p class="scan-note" id="playbackHint">
                        @(hasAudioAsset
                            ? "POI nay da co ban thu san. Neu chon che do audio, web se uu tien phat cung nguon audio ma app dang dung."
                            : "POI nay chua co ban thu san. Neu chon che do audio, web se tu dong roi ve TTS giong app.")
                    </p>
                    <p class="scan-note" id="speechStatus">
                        @(shouldAutoOpenApp
                            ? "Trang se thu mo app truoc. Neu app chua mo duoc, web se phat theo tuy chon dang chon."
                            : "Trang se thu phat noi dung theo tuy chon dang chon sau khi mo.")
                    </p>
                    @if (shouldAutoOpenApp)
                    {
                        <p class="scan-note">Dung cho diem dung xe buyt tai Khanh Hoi, Vinh Hoi, Xom Chieu. Quet la nghe ngay, khong can GPS.</p>
                    }
                </section>

                <section class="scan-panel">
                    <p class="scan-panel-label">Noi dung thuyet minh</p>
                    <p class="scan-text" id="scanNarrationText">@narrationText</p>
                </section>

                @if (Model.TourStops.Count > 0)
                {
                    <section class="scan-panel">
                        <p class="scan-panel-label">Lo trinh tour</p>
                        <ol class="scan-stop-list">
                            @foreach (var stop in Model.TourStops)
                            {
                                <li>@stop</li>
                            }
                        </ol>
                    </section>
                }

                <section class="scan-meta">
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Dia chi</span>
                            <div>@Model.Address</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SpecialDish))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Mon goi y</span>
                            <div>@Model.SpecialDish</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.EstimatedDurationLabel))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Thong tin them</span>
                            <div>@Model.EstimatedDurationLabel</div>
                        </div>
                    }

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Ma target</span>
                        <div>@Model.TargetCode</div>
                    </div>

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Link cong khai</span>
                        <a class="scan-link" href="@Model.PublicUrl">@Model.PublicUrl</a>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <script src="@Url.Content("~/js/narration-player.js")"></script>
    <script>
        (() => {
            const fallbackNarrationText = @Html.Raw(JsonSerializer.Serialize(narrationText));
            const narrationByLanguage = @Html.Raw(JsonSerializer.Serialize(Model.NarrationByLanguage));
            const audioAssetPath = @Html.Raw(JsonSerializer.Serialize(Model.AudioAssetPath));
            const appLaunchUrl = @Html.Raw(JsonSerializer.Serialize(Model.AppLaunchUrl));
            const autoOpenApp = @Html.Raw(JsonSerializer.Serialize(shouldAutoOpenApp));
            const hasAudioAsset = @Html.Raw(JsonSerializer.Serialize(hasAudioAsset));
            const storageKeys = {
                language: "vk-web-language",
                playbackMode: "vk-web-playback-mode"
            };
            const narrationTextElement = document.getElementById("scanNarrationText");
            const playbackHint = document.getElementById("playbackHint");
            const speechStatus = document.getElementById("speechStatus");
            const languageSelect = document.getElementById("languageSelect");
            const playbackModeSelect = document.getElementById("playbackModeSelect");
            const openAppBtn = document.getElementById("openAppBtn");
            const speakBtn = document.getElementById("speakBtn");
            const stopBtn = document.getElementById("stopBtn");
            const narrationPlayer = window.VinhKhanhNarrationPlayer?.createPlayer({
                onStatus: (message) => {
                    if (speechStatus) {
                        speechStatus.textContent = message;
                    }
                }
            });
            let fallbackTimer = 0;

            const normalizeLanguage = (value) =>
                window.VinhKhanhNarrationPlayer?.normalizeLanguageCode(value) || "vi";

            const normalizePlaybackMode = (value) =>
                window.VinhKhanhNarrationPlayer?.normalizePlaybackMode(value) || "tts";

            const updateStatus = (message) => {
                if (speechStatus) {
                    speechStatus.textContent = message;
                }
            };

            const resolveNarrationText = (languageCode) => {
                const normalizedLanguage = normalizeLanguage(languageCode);
                if (narrationByLanguage && narrationByLanguage[normalizedLanguage]) {
                    return narrationByLanguage[normalizedLanguage];
                }

                return fallbackNarrationText;
            };

            const persistSelections = () => {
                try {
                    window.localStorage.setItem(storageKeys.language, normalizeLanguage(languageSelect?.value));
                    window.localStorage.setItem(storageKeys.playbackMode, normalizePlaybackMode(playbackModeSelect?.value));
                } catch (error) {
                }
            };

            const restoreSelections = () => {
                try {
                    const storedLanguage = normalizeLanguage(window.localStorage.getItem(storageKeys.language));
                    const storedPlaybackMode = normalizePlaybackMode(window.localStorage.getItem(storageKeys.playbackMode));

                    if (languageSelect) {
                        languageSelect.value = storedLanguage;
                    }

                    if (playbackModeSelect) {
                        playbackModeSelect.value = storedPlaybackMode;
                    }
                } catch (error) {
                    if (languageSelect) {
                        languageSelect.value = "vi";
                    }

                    if (playbackModeSelect) {
                        playbackModeSelect.value = "tts";
                    }
                }
            };

            const syncNarrationText = () => {
                if (narrationTextElement) {
                    narrationTextElement.textContent = resolveNarrationText(languageSelect?.value);
                }
            };

            const syncPlaybackHint = () => {
                if (!playbackHint) {
                    return;
                }

                if (normalizePlaybackMode(playbackModeSelect?.value) === "audio") {
                    playbackHint.textContent = hasAudioAsset
                        ? "Web dang uu tien ban thu san cung nguon audio voi app."
                        : "Diem nay chua co ban thu san, web se tu dong roi ve TTS neu ban bam nghe.";
                    return;
                }

                playbackHint.textContent = "Web dang dung TTS theo ngon ngu da chon, giong voi logic fallback ben app.";
            };

            const stopSpeaking = (message) => {
                if (fallbackTimer) {
                    window.clearTimeout(fallbackTimer);
                    fallbackTimer = 0;
                }

                if (!narrationPlayer) {
                    updateStatus(message || "Da dung phat thuyet minh.");
                    return;
                }

                narrationPlayer.stop(message || "Da dung phat thuyet minh.");
            };

            const playOnWeb = () => {
                if (fallbackTimer) {
                    window.clearTimeout(fallbackTimer);
                    fallbackTimer = 0;
                }

                persistSelections();
                syncNarrationText();
                syncPlaybackHint();

                if (!narrationPlayer) {
                    updateStatus("Web chua tai duoc bo phat narration.");
                    return;
                }

                narrationPlayer.play({
                    playbackMode: playbackModeSelect?.value || "tts",
                    audioAssetPath: audioAssetPath || "",
                    narrationText: resolveNarrationText(languageSelect?.value),
                    languageCode: languageSelect?.value || "vi",
                    voiceType: "neutral",
                    allowAudioFallback: true,
                    baseUrl: window.location.origin,
                    messages: {
                        playingAudio: "Dang phat ban thu san giong app...",
                        audioEnded: "Da phat xong. Ban co the bam nghe lai bat cu luc nao.",
                        audioFallback: hasAudioAsset
                            ? "Web khong mo duoc file audio nay. Dang chuyen sang TTS du phong."
                            : "Diem nay chua co ban thu san. Web dang chuyen sang TTS giong app.",
                        audioUnavailable: "Diem nay chua co ban thu san de phat tren web.",
                        audioFailed: "Khong phat duoc ban thu san nay tren web.",
                        playingTts: "Dang doc thuyet minh tren web...",
                        ttsEnded: "Da doc xong. Ban co the bam nghe lai de nghe tiep.",
                        ttsFailed: "Khong the phat TTS. Thu bam nghe lai mot lan nua.",
                        unsupportedTts: "Trinh duyet nay khong ho tro TTS.",
                        empty: "Chua co noi dung thuyet minh de phat."
                    }
                });
            };

            const openApp = () => {
                if (!autoOpenApp || !appLaunchUrl) {
                    playOnWeb();
                    return;
                }

                stopSpeaking();
                updateStatus("Dang chuyen qua app tren dien thoai...");

                fallbackTimer = window.setTimeout(() => {
                    if (!document.hidden) {
                        updateStatus("Chua mo duoc app. Web dang phat theo tuy chon hien tai.");
                        playOnWeb();
                    }
                }, 1800);

                window.location.href = appLaunchUrl;
            };

            document.addEventListener("visibilitychange", () => {
                if (!document.hidden || !fallbackTimer) {
                    return;
                }

                window.clearTimeout(fallbackTimer);
                fallbackTimer = 0;
                narrationPlayer?.stop();
                updateStatus("Da chuyen sang app. Neu dien thoai hoi xac nhan, hay chon Mo.");
            });

            languageSelect?.addEventListener("change", () => {
                persistSelections();
                syncNarrationText();
                syncPlaybackHint();
                stopSpeaking("Da cap nhat ngon ngu. Bam nghe lai de ap dung.");
            });

            playbackModeSelect?.addEventListener("change", () => {
                persistSelections();
                syncPlaybackHint();
                stopSpeaking("Da cap nhat che do nghe. Bam nghe lai de ap dung.");
            });

            openAppBtn?.addEventListener("click", openApp);
            speakBtn?.addEventListener("click", playOnWeb);
            stopBtn?.addEventListener("click", () => stopSpeaking("Da dung phat thuyet minh."));

            window.addEventListener("beforeunload", () => narrationPlayer?.stop());

            restoreSelections();
            syncNarrationText();
            syncPlaybackHint();

            if (autoOpenApp) {
                window.setTimeout(openApp, 400);
            } else {
                window.setTimeout(playOnWeb, 600);
            }
        })();
    </script>
</body>
</html>
