<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.ListeningHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ListeningHistoryRoot"
    Title="{Binding HistoryPageTitle}"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28"
                             Spacing="14">
            <Border BackgroundColor="#FFFFFF"
                    Padding="16"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding ListeningHistorySectionTitle}"
                               FontSize="23"
                               FontAttributes="Bold"
                               TextColor="#102A43" />

                        <Label Text="{Binding ListeningHistorySectionSummary}"
                               FontSize="14"
                               TextColor="#486581"
                               LineBreakMode="WordWrap" />

                        <Label Text="{Binding ListeningHistorySyncStatus}"
                               FontSize="13"
                               TextColor="#7B8BA3" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="{Binding ClearListeningHistoryButtonText}"
                            Clicked="OnClearAllClicked"
                            BackgroundColor="#FEE2E2"
                            TextColor="#B91C1C"
                            FontSize="13"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            Padding="10,8"
                            VerticalOptions="Start"
                            IsVisible="{Binding CanClearListeningHistory}"
                            IsEnabled="{Binding CanClearListeningHistory}" />
                </Grid>
            </Border>

            <Border BackgroundColor="#F8FBFF"
                    Padding="16"
                    Stroke="#D9E6F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 14"
                    IsVisible="{Binding IsListeningHistoryDisplayEmpty}">
                <Label Text="{Binding ListeningHistoryEmptyStateText}"
                       FontSize="15"
                       TextColor="#5E7491"
                       LineBreakMode="WordWrap" />
            </Border>

            <VerticalStackLayout Spacing="12"
                                 BindableLayout.ItemsSource="{Binding ListeningHistory}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#FFFFFF"
                                Padding="16"
                                Stroke="#D9E6F7"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Spacing="12">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12">
                                    <Border BackgroundColor="#E8F1FF"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22">
                                        <Image Source="play_icon.svg"
                                               HeightRequest="18"
                                               WidthRequest="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Aspect="AspectFit" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="8">
                                            <Label Text="{Binding PoiName}"
                                                   FontSize="17"
                                                   FontAttributes="Bold"
                                                   TextColor="#102A43"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding StartedAtShortLabel}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="#2F80FF"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <Label Text="{Binding DetailSummaryLabel}"
                                               FontSize="13"
                                               TextColor="#486581"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StatusLabel}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{Binding StatusAccentColor}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid ColumnDefinitions="*,*,Auto"
                                      ColumnSpacing="10">
                                    <Button Text="{Binding Source={x:Reference ListeningHistoryRoot}, Path=BindingContext.SelectedPoiDetailButtonText}"
                                            Clicked="OnHistoryDetailClicked"
                                            BackgroundColor="#E8F1FF"
                                            TextColor="#2F80FF"
                                            FontSize="14"
                                            CornerRadius="18" />

                                    <Button Grid.Column="1"
                                            Text="{Binding ReplayActionText}"
                                            Clicked="OnReplayClicked"
                                            IsEnabled="{Binding CanReplay}"
                                            BackgroundColor="#2F80FF"
                                            TextColor="White"
                                            FontSize="14"
                                            CornerRadius="18" />

                                    <Button Grid.Column="2"
                                            Text="{Binding Source={x:Reference ListeningHistoryRoot}, Path=BindingContext.DeleteListeningHistoryButtonText}"
                                            Clicked="OnDeleteClicked"
                                            BackgroundColor="#FEE2E2"
                                            TextColor="#B91C1C"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            WidthRequest="88"
                                            CornerRadius="18" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
