@model ListeningHistoryPageViewModel

@if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
{
    <div class="alert alert-warning mb-4">
        @Model.LoadErrorMessage
    </div>
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    @if (Model.HasSearch)
    {
        <span class="badge rounded-pill text-bg-light px-3 py-2">Tu khoa: @Model.SearchTerm</span>
    }
    <div class="small text-muted">@Model.TotalSessions luot khop bo loc hien tai</div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Tong luot nghe</div>
                <div class="display-6">@Model.TotalSessions</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">POI duoc nghe nhieu nhat</div>
                <div class="fw-bold fs-5">@Model.MostPlayedPoi</div>
                <div class="small text-muted mt-2">
                    @(Model.MostPlayedPoiListenCount == 0 ? "Chua co du lieu" : $"{Model.MostPlayedPoiListenCount} luot nghe")
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Thoi gian nghe trung binh</div>
                <div class="display-6 fs-3">@Model.AverageListenLabel</div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Tong thoi luong nghe</div>
                <div class="display-6 fs-3">@Model.TotalListenLabel</div>
                <div class="small text-muted mt-2">@Model.DistinctPoiCount POI da duoc nghe</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Bang xep hang POI</span>
        <span class="badge text-bg-light">@Model.RankingItems.Count POI</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th style="width: 80px;">Hang</th>
                    <th>POI</th>
                    <th style="width: 130px;">Luot nghe</th>
                    <th style="width: 130px;">Hoan tat</th>
                    <th style="width: 160px;">Thoi gian TB</th>
                    <th style="width: 160px;">Tong thoi luong</th>
                    <th style="width: 180px;">Lan cuoi</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.RankingItems.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Chua co du lieu su dung khop bo loc hien tai.</td>
                </tr>
            }
            else
            {
                @for (var index = 0; index < Model.RankingItems.Count; index++)
                {
                    var item = Model.RankingItems[index];
                    <tr>
                        <td><span class="badge text-bg-primary">#@(index + 1)</span></td>
                        <td>
                            <div class="fw-semibold">@item.PoiName</div>
                            <div class="small text-muted">@item.PoiCode</div>
                        </td>
                        <td>@item.ListenCount</td>
                        <td>
                            <div>@item.CompletedCount / @item.ListenCount</div>
                            <div class="small text-muted">@item.CompletionRateLabel</div>
                        </td>
                        <td>@item.AverageListenLabel</td>
                        <td>@item.TotalListenLabel</td>
                        <td>@item.LastStartedAtDisplay</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Lich su nghe</span>
        <span class="badge text-bg-light">@Model.TimelineItems.Count phien</span>
    </div>
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th style="width: 180px;">Thoi diem</th>
                    <th>POI</th>
                    <th style="width: 150px;">Kich hoat</th>
                    <th style="width: 120px;">Ngon ngu</th>
                    <th style="width: 140px;">Thoi luong</th>
                    <th style="width: 130px;">TTS queue</th>
                    <th style="width: 150px;">Trang thai</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.TimelineItems.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Khong tim thay lich su nghe phu hop.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.TimelineItems)
                {
                    var badgeClass = item.Completed
                        ? "text-bg-success"
                        : string.IsNullOrWhiteSpace(item.ErrorMessage)
                            ? "text-bg-warning"
                            : "text-bg-danger";

                    <tr>
                        <td>
                            <div>@item.StartedAtDisplay</div>
                            <div class="small text-muted">Ket thuc: @item.CompletedAtDisplay</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@item.PoiName</div>
                            <div class="small text-muted">@item.PoiCode</div>
                        </td>
                        <td>
                            <div>@item.TriggerType</div>
                            <div class="small text-muted">@item.Source / @(string.IsNullOrWhiteSpace(item.DevicePlatform) ? "--" : item.DevicePlatform)</div>
                        </td>
                        <td>@item.Language</td>
                        <td>@item.DurationLabel</td>
                        <td>
                            <span class="badge text-bg-light">#@item.TtsQueuePosition</span>
                            <div class="small text-muted">Som hon nghe truoc</div>
                        </td>
                        <td>
                            <span class="badge @badgeClass">@item.StatusLabel</span>
                            @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                            {
                                <div class="small text-danger mt-1">@item.ErrorMessage</div>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
