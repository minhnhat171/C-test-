@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"] as string ?? "Quản trị";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole("Admin");
    var isOwner = User.IsInRole("PoiOwner");
    var displayName = User.FindFirst("vkg.display_name")?.Value ?? User.Identity?.Name ?? "Tài khoản";
    var roleLabel = isAdmin ? "Admin" : isOwner ? "Chủ cửa hàng" : "Khách";

    string SidebarLinkClass(string controller) =>
        string.Equals(currentController, controller, System.StringComparison.OrdinalIgnoreCase)
            ? "sidebar-link is-active"
            : "sidebar-link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Vĩnh Khánh Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-shell" id="appShell">
        <aside class="sidebar">
            <div class="sidebar-shell">
                <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">VK</span>
                    <span>
                        <span class="sidebar-brand-title">Vĩnh Khánh</span>
                        <span class="sidebar-brand-subtitle">Admin Console</span>
                    </span>
                </a>

                <div class="sidebar-account">
                    <div class="sidebar-account-name text-truncate">@displayName</div>
                    <div class="sidebar-role">@roleLabel</div>
                </div>

                <nav class="sidebar-nav" aria-label="Điều hướng quản trị">
                    @if (isAdmin)
                    {
                        <div class="sidebar-section">Vận hành</div>
                        <a class="@SidebarLinkClass("Home")" asp-controller="Home" asp-action="Index">
                            <span class="nav-dot"></span><span>Tổng quan</span>
                        </a>
                        <a class="@SidebarLinkClass("Pois")" asp-controller="Pois" asp-action="Index">
                            <span class="nav-dot"></span><span>Điểm kinh doanh</span>
                        </a>
                        <a class="@SidebarLinkClass("MapPois")" asp-controller="MapPois" asp-action="Index">
                            <span class="nav-dot"></span><span>Bản đồ</span>
                        </a>

                        <div class="sidebar-section">Nội dung</div>
                        <a class="@SidebarLinkClass("QrCodes")" asp-controller="QrCodes" asp-action="Index">
                            <span class="nav-dot"></span><span>QR</span>
                        </a>
                        <a class="@SidebarLinkClass("Tours")" asp-controller="Tours" asp-action="Index">
                            <span class="nav-dot"></span><span>Tour</span>
                        </a>
                        <a class="@SidebarLinkClass("UsageLogs")" asp-controller="UsageLogs" asp-action="Index">
                            <span class="nav-dot"></span><span>Lịch sử nghe</span>
                        </a>

                        <div class="sidebar-section">Hệ thống</div>
                        <a class="@SidebarLinkClass("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">
                            <span class="nav-dot"></span><span>Tài khoản</span>
                        </a>
                        <a class="@SidebarLinkClass("SystemAdmin")" asp-controller="SystemAdmin" asp-action="Index">
                            <span class="nav-dot"></span><span>Người dùng app</span>
                        </a>
                    }
                    else if (isOwner)
                    {
                        <div class="sidebar-section">Chủ cửa hàng</div>
                        <a class="@SidebarLinkClass("Owner")" asp-controller="Owner" asp-action="Index">
                            <span class="nav-dot"></span><span>Khu vực của tôi</span>
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    @if (isAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-light w-100">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-light w-100">Đăng nhập</a>
                    }
                </div>
            </div>
        </aside>

        <main class="content-area">
            <header class="content-header">
                <div class="header-left">
                    <button type="button" class="sidebar-toggle" id="sidebarToggle" aria-label="Mở menu">Menu</button>
                    <div>
                        <div class="content-kicker">Quản lý vận hành</div>
                        <h1 class="content-title">@pageTitle</h1>
                    </div>
                </div>
                <div class="header-actions">
                    <span class="system-pill">API + Web</span>
                    <span class="role-badge">@roleLabel</span>
                </div>
            </header>

            <div class="content-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const toggle = document.getElementById("sidebarToggle");
            const shell = document.getElementById("appShell");
            if (!toggle || !shell) {
                return;
            }

            toggle.addEventListener("click", () => {
                shell.classList.toggle("is-sidebar-open");
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
