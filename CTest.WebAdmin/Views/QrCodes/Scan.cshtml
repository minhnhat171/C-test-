@model QrScanViewModel
@using System.Text.Json
@{
    Layout = null;
    var narrationText = string.IsNullOrWhiteSpace(Model.NarrationText)
        ? Model.Description
        : Model.NarrationText;
    var shouldAutoOpenApp = Model.AutoOpenApp && !string.IsNullOrWhiteSpace(Model.AppLaunchUrl);
    var hasAudioAsset = !string.IsNullOrWhiteSpace(Model.AudioAssetPath);
    var analyticsPoiId = Guid.Empty;
    var canTrackListeningHistory = string.Equals(Model.TargetType, "poi", StringComparison.OrdinalIgnoreCase) &&
                                   Guid.TryParse(Model.TargetId, out analyticsPoiId);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.TargetName - QR Audio Guide</title>
    <meta name="description" content="@Model.Description" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-top: #fff4d6;
            --bg-bottom: #f7efe4;
            --card: rgba(255, 255, 255, 0.92);
            --ink: #1f2937;
            --muted: #6b7280;
            --accent: #c2410c;
            --accent-dark: #9a3412;
            --line: rgba(148, 163, 184, 0.18);
            --shadow: 0 28px 60px rgba(31, 41, 55, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Be Vietnam Pro", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(255, 255, 255, 0.8), transparent 30%),
                linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
            display: flex;
            justify-content: center;
            padding: 24px 16px 48px;
        }

        .scan-shell {
            width: min(100%, 760px);
        }

        .scan-card {
            background: var(--card);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 28px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .scan-hero {
            padding: 22px 22px 18px;
            background:
                radial-gradient(circle at right top, rgba(251, 191, 36, 0.28), transparent 36%),
                linear-gradient(135deg, rgba(255, 247, 237, 0.96), rgba(255, 255, 255, 0.96));
            border-bottom: 1px solid var(--line);
        }

        .scan-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 237, 213, 0.95);
            color: var(--accent-dark);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-title {
            margin: 14px 0 8px;
            font-size: clamp(1.9rem, 1.45rem + 2vw, 2.8rem);
            line-height: 1.06;
            letter-spacing: -0.04em;
        }

        .scan-description {
            margin: 0;
            color: var(--muted);
            line-height: 1.7;
            font-size: 1rem;
        }

        .scan-body {
            padding: 22px;
            display: grid;
            gap: 16px;
        }

        .scan-panel {
            border-radius: 22px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, 0.8);
            padding: 18px;
        }

        .scan-panel-label {
            margin: 0 0 10px;
            color: var(--muted);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .scan-control-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .scan-control {
            display: grid;
            gap: 8px;
        }

        .scan-select {
            width: 100%;
            min-height: 48px;
            border: 1px solid rgba(194, 65, 12, 0.16);
            border-radius: 16px;
            background: #fff7ed;
            color: var(--ink);
            font: inherit;
            padding: 0 14px;
        }

        .scan-text {
            margin: 0;
            line-height: 1.8;
            white-space: pre-wrap;
        }

        .scan-meta {
            display: grid;
            gap: 12px;
        }

        .scan-stop-list {
            margin: 0;
            padding-left: 1.2rem;
            line-height: 1.8;
        }

        .scan-meta-item {
            padding: 14px 16px;
            border-radius: 18px;
            background: #fffaf2;
            border: 1px solid rgba(251, 191, 36, 0.18);
        }

        .scan-meta-label {
            display: block;
            color: var(--muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .scan-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .scan-btn {
            appearance: none;
            border: 0;
            border-radius: 999px;
            padding: 14px 18px;
            font: inherit;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .scan-btn:hover {
            transform: translateY(-1px);
        }

        .scan-btn-primary {
            background: linear-gradient(135deg, var(--accent) 0%, #ea580c 100%);
            color: white;
            box-shadow: 0 18px 30px rgba(194, 65, 12, 0.22);
        }

        .scan-btn-secondary {
            background: #fff7ed;
            color: var(--accent-dark);
            border: 1px solid rgba(194, 65, 12, 0.16);
        }

        .scan-link {
            color: var(--accent-dark);
            word-break: break-all;
        }

        .scan-note {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.7;
        }

        @@media (max-width: 640px) {
            body {
                padding-inline: 12px;
            }

            .scan-hero,
            .scan-body {
                padding: 18px;
            }

            .scan-control-grid,
            .scan-actions {
                grid-template-columns: 1fr;
                display: grid;
            }

            .scan-btn {
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <main class="scan-shell">
        <section class="scan-card">
            <header class="scan-hero">
                <div class="scan-badge">@Model.TargetKindLabel QR thuyết minh</div>
                <h1 class="scan-title">@Model.TargetName</h1>
                <p class="scan-description">@Model.Description</p>
            </header>

            <div class="scan-body">
                <section class="scan-panel">
                    <p class="scan-panel-label">Nghe thuyết minh</p>

                    <div class="scan-control-grid">
                        <label class="scan-control">
                            <span class="scan-meta-label">Ngôn ngữ</span>
                            <select class="scan-select" id="languageSelect">
                                <option value="vi">Tiếng Việt</option>
                                <option value="en">Tiếng Anh</option>
                                <option value="zh">Tiếng Trung</option>
                                <option value="ko">Tiếng Hàn</option>
                                <option value="fr">Tiếng Pháp</option>
                            </select>
                        </label>

                        <label class="scan-control">
                    <span class="scan-meta-label">Chế độ nghe</span>
                            <select class="scan-select" id="playbackModeSelect">
                            <option value="tts">Giọng đọc tự động</option>
                                <option value="audio">Bản thu sẵn</option>
                            </select>
                        </label>
                    </div>

                    <div class="scan-actions">
                        @if (shouldAutoOpenApp)
                        {
                            <button type="button" class="scan-btn scan-btn-primary" id="openAppBtn">Mở app và nghe ngay</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="speakBtn">Nghe trên web</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="stopBtn">D?ng d?c web</button>
                        }
                        else
                        {
                            <button type="button" class="scan-btn scan-btn-primary" id="speakBtn">Nghe ngay</button>
                            <button type="button" class="scan-btn scan-btn-secondary" id="stopBtn">D?ng d?c</button>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.MapLink))
                        {
                            <a class="scan-btn scan-btn-secondary" href="@Model.MapLink" target="_blank" rel="noopener noreferrer">M? b?n d?</a>
                        }
                        <a class="scan-btn scan-btn-secondary" href="/download-app">Tải ứng dụng</a>
                    </div>

                    <p class="scan-note" id="playbackHint">
                        @(hasAudioAsset
                            ? "POI này đã có bản thu sẵn. Nếu chọn chế độ audio, web sẽ ưu tiên phát cùng nguồn audio mà app đang dùng."
                            : "POI này chưa có bản thu sẵn. Nếu chọn chế độ audio, web sẽ tự động chuyển về TTS giống app.")
                    </p>
                    <p class="scan-note" id="speechStatus">
                        @(shouldAutoOpenApp
                            ? "Trang sẽ thử mở app trước. Nếu app chưa mở được, web sẽ phát theo tùy chọn đang chọn."
                            : "Trang sẽ thử phát nội dung theo tùy chọn đang chọn sau khi mở.")
                    </p>
                    @if (shouldAutoOpenApp)
                    {
                        <p class="scan-note">Dùng cho điểm dừng xe buýt tại Khánh Hội, Vĩnh Hội, Xóm Chiếu. Quét là nghe ngay, không cần GPS.</p>
                    }
                </section>

                <section class="scan-panel">
                    <p class="scan-panel-label">Nội dung thuyết minh</p>
                    <p class="scan-text" id="scanNarrationText">@narrationText</p>
                </section>

                @if (Model.TourStops.Count > 0)
                {
                    <section class="scan-panel">
                        <p class="scan-panel-label">Lộ trình tour</p>
                        <ol class="scan-stop-list">
                            @foreach (var stop in Model.TourStops)
                            {
                                <li>@stop</li>
                            }
                        </ol>
                    </section>
                }

                <section class="scan-meta">
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Địa chỉ</span>
                            <div>@Model.Address</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SpecialDish))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Món gợi ý</span>
                            <div>@Model.SpecialDish</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.EstimatedDurationLabel))
                    {
                        <div class="scan-meta-item">
                            <span class="scan-meta-label">Thông tin thêm</span>
                            <div>@Model.EstimatedDurationLabel</div>
                        </div>
                    }

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Mã đối tượng</span>
                        <div>@Model.TargetCode</div>
                    </div>

                    <div class="scan-meta-item">
                        <span class="scan-meta-label">Liên kết công khai</span>
                        <a class="scan-link" href="@Model.PublicUrl">@Model.PublicUrl</a>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <script src="@Url.Content("~/js/narration-player.js")"></script>
    <script>
        (() => {
            const fallbackNarrationText = @Html.Raw(JsonSerializer.Serialize(narrationText));
            const narrationByLanguage = @Html.Raw(JsonSerializer.Serialize(Model.NarrationByLanguage));
            const audioAssetPath = @Html.Raw(JsonSerializer.Serialize(Model.AudioAssetPath));
            const appLaunchUrl = @Html.Raw(JsonSerializer.Serialize(Model.AppLaunchUrl));
            const autoOpenApp = @Html.Raw(JsonSerializer.Serialize(shouldAutoOpenApp));
            const hasAudioAsset = @Html.Raw(JsonSerializer.Serialize(hasAudioAsset));
            const canTrackListeningHistory = @Html.Raw(JsonSerializer.Serialize(canTrackListeningHistory));
            const poiId = @Html.Raw(JsonSerializer.Serialize(canTrackListeningHistory ? analyticsPoiId : Guid.Empty));
            const heartbeatUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("WebHeartbeat", "QrCodes")));
            const disconnectUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("WebDisconnect", "QrCodes")));
            const listeningHistoryUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("CreateListeningHistory", "QrCodes")));
            const storageKeys = {
                deviceId: "vk-web-device-id",
                language: "vk-web-language",
                playbackMode: "vk-web-playback-mode"
            };
            const narrationTextElement = document.getElementById("scanNarrationText");
            const playbackHint = document.getElementById("playbackHint");
            const speechStatus = document.getElementById("speechStatus");
            const languageSelect = document.getElementById("languageSelect");
            const playbackModeSelect = document.getElementById("playbackModeSelect");
            const openAppBtn = document.getElementById("openAppBtn");
            const speakBtn = document.getElementById("speakBtn");
            const stopBtn = document.getElementById("stopBtn");
            const narrationPlayer = window.VinhKhanhNarrationPlayer?.createPlayer({
                onTrạng thái: (message, state) => {
                    if (speechStatus) {
                        speechStatus.textContent = message;
                    }

                    if (state === "ended") {
                        void finalizeListeningSession(true);
                    } else if (state === "error") {
                        void finalizeListeningSession(false, message);
                    }
                }
            });
            const heartbeatIntervalMs = 8000;
            const browserPlatform = "Web";
            const browserModel = [
                navigator.platform || "Browser",
                navigator.language || ""
            ].filter(Boolean).join(" | ");
            const appVersion = "web-qr";
            let fallbackTimer = 0;
            let heartbeatTimer = 0;
            let currentListeningSession = null;

            const normalizeLanguage = (value) =>
                window.VinhKhanhNarrationPlayer?.normalizeLanguageCode(value) || "vi";

            const normalizePlaybackMode = (value) =>
                window.VinhKhanhNarrationPlayer?.normalizePlaybackMode(value) || "tts";

            const updateStatus = (message) => {
                if (speechStatus) {
                    speechStatus.textContent = message;
                }
            };

            const buildDeviceId = () => {
                try {
                    const storedDeviceId = window.localStorage.getItem(storageKeys.deviceId);
                    if (storedDeviceId) {
                        return storedDeviceId;
                    }

                    const createdDeviceId = (window.crypto?.randomUUID?.() || `web-${Date.now()}-${Math.random().toString(16).slice(2)}`)
                        .replaceAll("-", "")
                        .toLowerCase();
                    window.localStorage.setItem(storageKeys.deviceId, createdDeviceId);
                    return createdDeviceId;
                } catch (error) {
                    return `web${Date.now().toString(16)}${Math.random().toString(16).slice(2, 10)}`;
                }
            };

            const browserDeviceId = buildDeviceId();
            const visitorSuffix = browserDeviceId.slice(-6).toUpperCase();
            const visitorCode = `web-${visitorSuffix}`;
            const visitorName = `Khách web ${visitorSuffix}`;

            const postJson = async (url, payload, options = {}) => {
                if (!url) {
                    return null;
                }

                const response = await fetch(url, {
                    method: options.method || "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload),
                    cache: "no-store",
                    credentials: "same-origin",
                    keepalive: options.keepalive === true
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                if (options.expectJson === false || response.status === 204) {
                    return null;
                }

                return await response.json();
            };

            const sendHeartbeat = async () => {
                try {
                    await postJson(heartbeatUrl, {
                        deviceId: browserDeviceId,
                        userCode: visitorCode,
                        userDisplayName: visitorName,
                        userEmail: "",
                        devicePlatform: browserPlatform,
                        deviceModel: browserModel,
                        appVersion: appVersion,
                        sentAtUtc: new Date().toISOString()
                    }, { expectJson: false });
                } catch (error) {
                }
            };

            const startHeartbeat = () => {
                if (heartbeatTimer) {
                    return;
                }

                void sendHeartbeat();
                heartbeatTimer = window.setInterval(() => {
                    void sendHeartbeat();
                }, heartbeatIntervalMs);
            };

            const disconnectHeartbeat = async (keepalive) => {
                if (heartbeatTimer) {
                    window.clearInterval(heartbeatTimer);
                    heartbeatTimer = 0;
                }

                try {
                    await postJson(disconnectUrl, {
                        deviceId: browserDeviceId,
                        disconnectedAtUtc: new Date().toISOString()
                    }, { expectJson: false, keepalive: keepalive === true });
                } catch (error) {
                }
            };

            const startListeningSession = async () => {
                if (!canTrackListeningHistory || !poiId || !listeningHistoryUrl) {
                    currentListeningSession = null;
                    return;
                }

                const session = {
                    historyId: null,
                    startedAtMs: Date.now(),
                    finalized: false,
                    createTask: null
                };

                currentListeningSession = session;

                session.createTask = (async () => {
                    try {
                    const response = await postJson(listeningHistoryUrl, {
                        poiId: poiId,
                        poiCode: @Html.Raw(JsonSerializer.Serialize(Model.TargetCode)),
                        poiName: @Html.Raw(JsonSerializer.Serialize(Model.TargetName)),
                        poiAddress: @Html.Raw(JsonSerializer.Serialize(Model.Address)),
                        poiDescription: @Html.Raw(JsonSerializer.Serialize(Model.Description)),
                        poiSpecialDish: @Html.Raw(JsonSerializer.Serialize(Model.SpecialDish)),
                        poiImageSource: "",
                        poiMapLink: @Html.Raw(JsonSerializer.Serialize(Model.MapLink)),
                        userCode: visitorCode,
                        userDisplayName: visitorName,
                        userEmail: "",
                        triggerType: "QR",
                        language: languageSelect?.value || "vi",
                        playbackMode: playbackModeSelect?.value || "tts",
                        narrationSnapshot: resolveNarrationText(languageSelect?.value),
                        audioAssetPath: audioAssetPath || "",
                        source: "web",
                        devicePlatform: browserPlatform,
                        autoTriggered: false,
                        startedAtUtc: new Date(session.startedAtMs).toISOString()
                    });

                        session.historyId = response?.id || null;
                    } catch (error) {
                    }
                })();

                await session.createTask;
            };

            const finalizeListeningSession = async (completed, errorMessage) => {
                const session = currentListeningSession;
                if (!session || session.finalized) {
                    return;
                }

                session.finalized = true;
                currentListeningSession = null;

                if (session.createTask) {
                    await session.createTask;
                }

                if (!session.historyId) {
                    return;
                }

                const listenSeconds = Math.max(1, Math.round((Date.now() - session.startedAtMs) / 1000));

                try {
                    await postJson(`${listeningHistoryUrl}/${encodeURIComponent(session.historyId)}`, {
                        listenSeconds: listenSeconds,
                        completed: completed === true,
                        completedAtUtc: new Date().toISOString(),
                        errorMessage: errorMessage || ""
                    }, { method: "PUT", expectJson: false, keepalive: true });
                } catch (error) {
                }
            };

            const resolveNarrationText = (languageCode) => {
                const normalizedLanguage = normalizeLanguage(languageCode);
                if (narrationByLanguage && narrationByLanguage[normalizedLanguage]) {
                    return narrationByLanguage[normalizedLanguage];
                }

                return fallbackNarrationText;
            };

            const persistSelections = () => {
                try {
                    window.localStorage.setItem(storageKeys.language, normalizeLanguage(languageSelect?.value));
                    window.localStorage.setItem(storageKeys.playbackMode, normalizePlaybackMode(playbackModeSelect?.value));
                } catch (error) {
                }
            };

            const restoreSelections = () => {
                try {
                    const storedLanguage = normalizeLanguage(window.localStorage.getItem(storageKeys.language));
                    const storedPlaybackMode = normalizePlaybackMode(window.localStorage.getItem(storageKeys.playbackMode));

                    if (languageSelect) {
                        languageSelect.value = storedLanguage;
                    }

                    if (playbackModeSelect) {
                        playbackModeSelect.value = storedPlaybackMode;
                    }
                } catch (error) {
                    if (languageSelect) {
                        languageSelect.value = "vi";
                    }

                    if (playbackModeSelect) {
                        playbackModeSelect.value = "tts";
                    }
                }
            };

            const syncNarrationText = () => {
                if (narrationTextElement) {
                    narrationTextElement.textContent = resolveNarrationText(languageSelect?.value);
                }
            };

            const syncPlaybackHint = () => {
                if (!playbackHint) {
                    return;
                }

                if (normalizePlaybackMode(playbackModeSelect?.value) === "audio") {
                    playbackHint.textContent = hasAudioAsset
                        ? "Web đang ưu tiên bản thu sẵn cùng nguồn audio với app."
                        : "Điểm này chưa có bản thu sẵn, web sẽ tự động chuyển về TTS nếu bạn bấm nghe.";
                    return;
                }

                playbackHint.textContent = "Web đang dùng TTS theo ngôn ngữ đã chọn, giống logic fallback bên app.";
            };

            const stopSpeaking = (message) => {
                if (fallbackTimer) {
                    window.clearTimeout(fallbackTimer);
                    fallbackTimer = 0;
                }

                void finalizeListeningSession(false);

                if (!narrationPlayer) {
                    updateStatus(message || "Đã dừng phát thuyết minh.");
                    return;
                }

                narrationPlayer.stop(message || "Đã dừng phát thuyết minh.");
            };

            const playOnWeb = () => {
                if (fallbackTimer) {
                    window.clearTimeout(fallbackTimer);
                    fallbackTimer = 0;
                }

                persistSelections();
                syncNarrationText();
                syncPlaybackHint();

                if (!narrationPlayer) {
                    updateStatus("Web chưa tải được bộ phát thuyết minh.");
                    return;
                }

                const currentNarrationText = resolveNarrationText(languageSelect?.value);
                const currentPlaybackMode = playbackModeSelect?.value || "tts";
                if (!currentNarrationText && !audioAssetPath) {
                    updateStatus("Chưa có nội dung thuyết minh để phát.");
                    return;
                }

                void finalizeListeningSession(false);
                void startListeningSession();

                narrationPlayer.play({
                    playbackMode: currentPlaybackMode,
                    audioAssetPath: audioAssetPath || "",
                    narrationText: currentNarrationText,
                    languageCode: languageSelect?.value || "vi",
                    voiceType: "neutral",
                    allowAudioFallback: true,
                    baseUrl: window.location.origin,
                    messages: {
                        playingAudio: "Đang phát bản thu sẵn giống app...",
                        audioEnded: "Đã phát xong. Bạn có thể bấm nghe lại bất cứ lúc nào.",
                        audioFallback: hasAudioAsset
                            ? "Web không mở được file audio này. Đang chuyển sang TTS dự phòng."
                            : "Điểm này chưa có bản thu sẵn. Web đang chuyển sang TTS giống app.",
                        audioUnavailable: "Điểm này chưa có bản thu sẵn để phát trên web.",
                        audioFailed: "Không phát được bản thu sẵn này trên web.",
                        playingTts: "Đang đọc thuyết minh trên web...",
                        ttsEnded: "Đã đọc xong. Bạn có thể bấm nghe lại để nghe tiếp.",
                        ttsFailed: "Không thể phát TTS. Thử bấm nghe lại một lần nữa.",
                        unsupportedTts: "Trình duyệt này không hỗ trợ TTS.",
                        empty: "Chưa có nội dung thuyết minh để phát."
                    }
                });
            };

            const openApp = () => {
                if (!autoOpenApp || !appLaunchUrl) {
                    playOnWeb();
                    return;
                }

                stopSpeaking();
                updateStatus("Đang chuyển qua app trên điện thoại...");

                fallbackTimer = window.setTimeout(() => {
                    if (!document.hidden) {
                        updateStatus("Chưa mở được app. Web đang phát theo tùy chọn hiện tại.");
                        playOnWeb();
                    }
                }, 1800);

                window.location.href = appLaunchUrl;
            };

            document.addEventListener("visibilitychange", () => {
                if (!document.hidden || !fallbackTimer) {
                    return;
                }

                window.clearTimeout(fallbackTimer);
                fallbackTimer = 0;
                void finalizeListeningSession(false);
                narrationPlayer?.stop();
                updateStatus("Đã chuyển sang app. Nếu điện thoại hỏi xác nhận, hãy chọn Mở.");
            });

            languageSelect?.addEventListener("change", () => {
                persistSelections();
                syncNarrationText();
                syncPlaybackHint();
                stopSpeaking("Đã cập nhật ngôn ngữ. Bấm nghe lại để áp dụng.");
            });

            playbackModeSelect?.addEventListener("change", () => {
                persistSelections();
                syncPlaybackHint();
                stopSpeaking("Đã cập nhật chế độ nghe. Bấm nghe lại để áp dụng.");
            });

            openAppBtn?.addEventListener("click", openApp);
            speakBtn?.addEventListener("click", playOnWeb);
            stopBtn?.addEventListener("click", () => stopSpeaking("Đã dừng phát thuyết minh."));

            window.addEventListener("beforeunload", () => {
                narrationPlayer?.stop();
                void finalizeListeningSession(false);
                void disconnectHeartbeat(true);
            });

            window.addEventListener("pagehide", () => {
                narrationPlayer?.stop();
                void finalizeListeningSession(false);
                void disconnectHeartbeat(true);
            });

            restoreSelections();
            syncNarrationText();
            syncPlaybackHint();
            startHeartbeat();

            if (autoOpenApp) {
                window.setTimeout(openApp, 400);
            } else {
                window.setTimeout(playOnWeb, 600);
            }
        })();
    </script>
</body>
</html>
