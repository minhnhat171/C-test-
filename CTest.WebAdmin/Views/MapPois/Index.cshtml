@using System.Globalization
@using System.Text.Json
@model MapPoiManagementViewModel
@{
    ViewData["Title"] = "Map Analytics";

    var hasCoordinates = Math.Abs(Model.Editor.Latitude) > 0.000001 || Math.Abs(Model.Editor.Longitude) > 0.000001;
    var initialLatitude = hasCoordinates ? Model.Editor.Latitude.ToString(CultureInfo.InvariantCulture) : "10.761450";
    var initialLongitude = hasCoordinates ? Model.Editor.Longitude.ToString(CultureInfo.InvariantCulture) : "106.702820";
    var activePoiCount = Model.Pois.Count(poi => poi.IsActive);
    var inactivePoiCount = Model.Pois.Count - activePoiCount;
    var activeDevices = Model.ActiveDeviceStats.Devices;
    var locatedActiveDevices = activeDevices
        .Where(item => item.Latitude.HasValue && item.Longitude.HasValue)
        .ToList();
    var routePoints = Model.ActiveDeviceStats.RoutePoints;
    var heatmapPointCount = routePoints.Count > 0 ? routePoints.Count : locatedActiveDevices.Count;
    var latestLocationAt = routePoints.Count > 0
        ? routePoints.Max(point => point.RecordedAtUtc)
        : (locatedActiveDevices.Any()
            ? locatedActiveDevices.Max(item => item.LocationTimestampUtc ?? item.LastSeenAtUtc)
            : (DateTimeOffset?)null);
    var maxTopListenCount = Math.Max(1, Model.TopListeningPois.Select(x => x.ListenCount).DefaultIfEmpty(0).Max());
    var topListeningPoi = Model.TopListeningPois.FirstOrDefault()?.PoiName ?? "Chưa có dữ liệu";
    var averageListenLabel = Model.AverageListenSeconds <= 0
        ? "0 giây"
        : $"{Model.AverageListenSeconds:0.#} giây";
    var analyticsByPoi = Model.TopListeningPois.ToDictionary(item => item.PoiId);
    var topListeningPoiId = Model.TopListeningPois.FirstOrDefault()?.PoiId ?? Guid.Empty;
    var mapPois = Model.Pois.Select(poi =>
    {
        analyticsByPoi.TryGetValue(poi.Id, out var poiAnalytics);

        return new
        {
            id = poi.Id.ToString(),
            code = poi.Code,
            name = poi.Name,
            address = poi.Address,
            description = poi.Description,
            latitude = poi.Latitude,
            longitude = poi.Longitude,
            radius = poi.RadiusInMeters,
            priority = poi.Priority,
            isActive = poi.IsActive,
            isTopListening = poi.Id == topListeningPoiId,
            listenCount = poiAnalytics?.ListenCount ?? 0,
            averageListenSeconds = poiAnalytics?.AverageListenSeconds ?? 0,
            selectUrl = Url.Action("Index", "MapPois", new { poiId = poi.Id }) ?? $"/MapPois?poiId={poi.Id}",
            editUrl = Url.Action("Edit", "Pois", new { id = poi.Id }) ?? $"/Pois/Edit/{poi.Id}",
            detailsUrl = Url.Action("Details", "Pois", new { id = poi.Id }) ?? $"/Pois/Details/{poi.Id}",
            qrUrl = Url.Action("Index", "QrCodes", new { selectedTargetType = "poi", selectedTargetId = poi.Id }) ?? $"/QrCodes?selectedTargetType=poi&selectedTargetId={poi.Id}",
            appLaunchUrl = $"vinhkhanhguide://poi/{poi.Id}?autoplay=1&source=webadmin-map"
        };
    }).ToList();
    var selectedAppLaunchUrl = Model.HasSelection
        ? $"vinhkhanhguide://poi/{Model.Editor.Id}?autoplay=1&source=webadmin-map"
        : string.Empty;
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    .map-poi-page {
        --map-ink: #0f172a;
        --map-muted: #64748b;
        --map-panel: rgba(255, 255, 255, 0.96);
        --map-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        --map-line: rgba(148, 163, 184, 0.18);
        color: var(--map-ink);
    }

    .map-poi-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .map-poi-head h1 {
        margin: 0;
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .map-poi-head p {
        margin: 0.45rem 0 0;
        color: var(--map-muted);
        max-width: 760px;
    }

    .map-poi-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 1.2rem;
    }

    .map-poi-panel {
        background: var(--map-panel);
        border-radius: 28px;
        box-shadow: var(--map-shadow);
        overflow: hidden;
    }

    .map-poi-content {
        padding: 1.3rem;
    }

    .map-poi-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .map-poi-toolbar h2 {
        margin: 0;
        font-size: clamp(1.35rem, 1.1rem + 1vw, 1.9rem);
        font-weight: 800;
        letter-spacing: -0.03em;
    }

    .map-poi-toolbar p {
        margin: 0.35rem 0 0;
        color: var(--map-muted);
    }

    .map-poi-map-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .map-poi-map-card,
    .map-poi-summary-card,
    .map-poi-form-card {
        border-radius: 26px;
        border: 1px solid rgba(148, 163, 184, 0.14);
        background: #f8fafc;
    }

    .map-poi-map-card {
        padding: 1rem;
    }

    .map-poi-summary-card,
    .map-poi-form-card {
        padding: 1.1rem;
    }

    .map-poi-map-frame {
        position: relative;
        height: 620px;
        border-radius: 22px;
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.18);
    }

    #poiMapCanvas {
        width: 100%;
        height: 100%;
    }

    .map-active-user-marker {
        width: 16px;
        height: 16px;
        border-radius: 999px;
        border: 3px solid #fff;
        background: #0ea5e9;
        box-shadow: 0 0 0 8px rgba(14, 165, 233, 0.16), 0 10px 24px rgba(15, 23, 42, 0.22);
    }

    .map-active-user-marker.device-color-1 {
        background: #22c55e;
        box-shadow: 0 0 0 8px rgba(34, 197, 94, 0.16), 0 10px 24px rgba(15, 23, 42, 0.22);
    }

    .map-active-user-marker.device-color-2 {
        background: #f97316;
        box-shadow: 0 0 0 8px rgba(249, 115, 22, 0.16), 0 10px 24px rgba(15, 23, 42, 0.22);
    }

    .map-active-user-marker.device-color-3 {
        background: #e11d48;
        box-shadow: 0 0 0 8px rgba(225, 29, 72, 0.16), 0 10px 24px rgba(15, 23, 42, 0.22);
    }

    .map-active-user-marker.device-color-4 {
        background: #8b5cf6;
        box-shadow: 0 0 0 8px rgba(139, 92, 246, 0.16), 0 10px 24px rgba(15, 23, 42, 0.22);
    }

    .map-route-popup {
        min-width: 210px;
        color: #0f172a;
    }

    .analytics-map-empty,
    .analytics-map-legend {
        position: absolute;
        z-index: 500;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.12);
        backdrop-filter: blur(10px);
    }

    .analytics-map-empty {
        top: 1rem;
        left: 1rem;
        max-width: 340px;
        padding: 0.95rem 1rem;
        color: #334155;
        line-height: 1.55;
    }

    .analytics-map-empty.is-hidden {
        display: none;
    }

    .analytics-map-legend {
        right: 1rem;
        bottom: 1rem;
        padding: 0.8rem 0.9rem;
    }

    .analytics-gradient {
        width: 144px;
        height: 10px;
        margin-top: 0.55rem;
        border-radius: 999px;
        background: linear-gradient(90deg, #38bdf8 0%, #2563eb 38%, #7c3aed 72%, #ef4444 100%);
    }

    .analytics-legend-scale {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 0.45rem;
        color: var(--map-muted);
        font-size: 0.78rem;
        font-weight: 700;
    }

    .map-poi-marker {
        display: block;
        width: 34px;
        height: 34px;
        color: #2563eb;
        filter: drop-shadow(0 10px 14px rgba(15, 23, 42, 0.24));
    }

    .map-poi-marker.is-selected {
        width: 38px;
        height: 38px;
        color: #0f172a;
        filter: drop-shadow(0 12px 18px rgba(15, 23, 42, 0.34));
    }

    .map-poi-marker.is-inactive {
        color: #94a3b8;
    }

    .map-poi-marker.has-listens {
        color: #14b8a6;
    }

    .map-poi-marker.is-top-listening {
        color: #f59e0b;
        filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.52)) drop-shadow(0 12px 18px rgba(15, 23, 42, 0.32));
    }

    .map-poi-marker svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .map-poi-popup {
        min-width: 220px;
    }

    .map-poi-popup-title {
        font-weight: 800;
        color: #0f172a;
    }

    .map-poi-popup-meta {
        margin-top: 0.3rem;
        color: #64748b;
        font-size: 0.84rem;
        line-height: 1.4;
    }

    .map-poi-popup-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.75rem;
    }

    .map-poi-popup-actions a,
    .map-poi-popup-actions span {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: #f1f5f9;
        color: #0f172a;
        font-size: 0.78rem;
        font-weight: 700;
        text-decoration: none;
    }

    .map-poi-kicker {
        color: var(--map-muted);
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .map-poi-status {
        margin-top: 0.8rem;
        color: var(--map-muted);
        line-height: 1.6;
    }

    .map-poi-metrics {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.8rem;
        margin-top: 1rem;
    }

    .map-poi-metric {
        padding: 0.9rem;
        border-radius: 18px;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.14);
    }

    .map-poi-metric strong {
        display: block;
        margin-top: 0.3rem;
        font-size: 1.15rem;
    }

    .map-analytics-list {
        display: grid;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .map-analytics-item {
        padding: 0.9rem;
        border-radius: 18px;
        background: #fff;
        border: 1px solid rgba(148, 163, 184, 0.14);
    }

    .map-analytics-item-title {
        font-weight: 800;
        color: #0f172a;
    }

    .map-analytics-item-meta {
        margin-top: 0.25rem;
        color: var(--map-muted);
        font-size: 0.86rem;
    }

    .map-analytics-track {
        height: 8px;
        margin-top: 0.55rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.16);
        overflow: hidden;
    }

    .map-analytics-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #2563eb 0%, #14b8a6 100%);
    }

    .map-analytics-requirements {
        display: grid;
        gap: 0.55rem;
        margin-top: 1rem;
    }

    .map-analytics-requirement {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        color: #334155;
        font-size: 0.92rem;
        line-height: 1.45;
    }

    .map-analytics-requirement::before {
        content: "";
        flex: 0 0 auto;
        width: 0.55rem;
        height: 0.55rem;
        margin-top: 0.38rem;
        border-radius: 999px;
        background: #2563eb;
    }

    .map-analytics-divider {
        margin: 1.1rem 0;
        border-top: 1px solid rgba(148, 163, 184, 0.18);
    }

    .map-poi-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .map-poi-form-grid .full {
        grid-column: 1 / -1;
    }

    .map-poi-page .form-control,
    .map-poi-page textarea,
    .map-poi-page .form-check-input {
        border-radius: 16px;
    }

    .map-poi-page .form-control,
    .map-poi-page textarea {
        min-height: 48px;
        border-color: rgba(148, 163, 184, 0.24);
    }

    .map-poi-page textarea {
        min-height: 120px;
    }

    .map-poi-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.2rem;
    }

    .map-poi-empty {
        padding: 2rem;
        color: var(--map-muted);
        text-align: center;
    }

    @@media (max-width: 1399.98px) {
        .map-poi-map-shell {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .map-poi-head,
        .map-poi-toolbar {
            flex-direction: column;
        }

        .map-poi-form-grid,
        .map-poi-metrics {
            grid-template-columns: 1fr;
        }

        .map-poi-map-frame {
            height: 420px;
        }
    }
</style>

<div class="map-poi-page">
    <div class="map-poi-head">
        <div>
            <h1>Map Analytics</h1>
            <p>Một bản đồ duy nhất cho POI, tuyến di chuyển ẩn danh, top địa điểm được nghe nhiều nhất, thời gian nghe trung bình và heatmap vị trí người dùng.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Pois" asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4">+ Tạo POI mới</a>
            <a asp-controller="Pois" asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">Về danh sách POI</a>
        </div>
    </div>

    @if (TempData["MapPoiMessage"] is string mapPoiMessage)
    {
        <div class="alert alert-success border-0 shadow-sm">@mapPoiMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadErrorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm">@Model.LoadErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.AnalyticsLoadErrorMessage))
    {
        <div class="alert alert-info border-0 shadow-sm">@Model.AnalyticsLoadErrorMessage</div>
    }

    <div class="map-poi-layout">
        <div class="map-poi-panel">
            <div class="map-poi-content">
                @if (!Model.HasSelection)
                {
                    <div class="map-poi-empty">Chọn một POI để bắt đầu chỉnh sửa trên bản đồ.</div>
                }
                else
                {
                    <div class="map-poi-toolbar">
                        <div>
                            <div class="map-poi-kicker">Đang chỉnh sửa</div>
                            <h2>@Model.Editor.Name</h2>
                            <p>@Model.Editor.Address</p>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <a href="@selectedAppLaunchUrl" class="btn btn-primary rounded-pill px-4">Mở trong app</a>
                            <a asp-controller="Pois" asp-action="Edit" asp-route-id="@Model.Editor.Id" class="btn btn-outline-primary rounded-pill px-4">M? form d?y d?</a>
                            <a asp-controller="QrCodes" asp-action="Index" asp-route-selectedTargetType="poi" asp-route-selectedTargetId="@Model.Editor.Id" class="btn btn-outline-success rounded-pill px-4">Tạo QR</a>
                        </div>
                    </div>

                    <div class="map-poi-map-shell">
                        <div class="map-poi-map-card">
                            <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                                <div>
                        <div class="map-poi-kicker">B?n d? analytics</div>
                        <div class="fw-semibold">POI, tuyến di chuyển ẩn danh và heatmap người dùng cùng hiển thị trên bản đồ</div>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="button" class="btn btn-outline-dark rounded-pill px-4" id="recenterMapButton">Căn giữa POI đang sửa</button>
                                    <button type="button" class="btn btn-outline-primary rounded-pill px-4" id="recenterAnalyticsButton">Căn giữa heatmap</button>
                                </div>
                            </div>

                            <div class="map-poi-map-frame">
                                <div id="poiMapCanvas"></div>
                                <div class="analytics-map-empty @(heatmapPointCount > 0 ? "is-hidden" : null)" id="analyticsMapEmptyState">
                                    Chưa có GPS hoặc route point để vẽ heatmap. Khi app gửi heartbeat kèm tọa độ, lớp analytics sẽ tự cập nhật trên map này.
                                </div>
                                <div class="analytics-map-legend">
                                    <div class="map-poi-kicker">Heatmap vị trí</div>
                                    <div class="analytics-gradient"></div>
                                    <div class="analytics-legend-scale">
                                        <span>Thấp</span>
                                        <span>Cao</span>
                                    </div>
                                </div>
                            </div>

                            <div class="map-poi-status" id="mapPoiStatus">
                                Map đang đọc @Model.Pois.Count POI từ API, @routePoints.Count điểm tuyến ẩn danh và @locatedActiveDevices.Count thiết bị online có GPS.
                            </div>
                        </div>

                        <div class="map-poi-summary-card">
                            <div class="map-poi-kicker">Map Analytics</div>
                            <div class="fw-semibold mt-2">Tất cả yêu cầu nằm trên một map</div>

                            <div class="map-poi-metrics">
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Tuyến ẩn danh</span>
                                    <strong id="analyticsRoutePointCount">@routePoints.Count</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Heatmap</span>
                                    <strong id="analyticsHeatmapPointCount">@heatmapPointCount</strong>
                                </div>
                                <div class="map-poi-metric">
                        <span class="map-poi-kicker">Top d?a di?m</span>
                                    <strong id="analyticsTopPoiName">@topListeningPoi</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">TB nghe / POI</span>
                                    <strong>@averageListenLabel</strong>
                                </div>
                            </div>

                            <div class="map-analytics-requirements">
                                <div class="map-analytics-requirement">Lưu tuyến di chuyển ẩn danh từ các heartbeat GPS gần nhất.</div>
                                <div class="map-analytics-requirement">Top địa điểm được nghe nhiều nhất từ lịch sử nghe.</div>
                                <div class="map-analytics-requirement">Thời gian trung bình nghe 1 POI: @averageListenLabel.</div>
                                <div class="map-analytics-requirement">Heatmap vị trí người dùng cập nhật realtime.</div>
                            </div>

                            <div class="map-analytics-list">
                                @if (Model.TopListeningPois.Any())
                                {
                                    @foreach (var item in Model.TopListeningPois)
                                    {
                                        var listenPercent = Math.Max(5, (int)Math.Round(item.ListenCount * 100.0 / maxTopListenCount));
                                            <div class="map-analytics-item">
                                                <div class="map-analytics-item-title">@item.PoiName</div>
                                            <div class="map-analytics-item-meta">@item.ListenCount lượt nghe, TB @($"{item.AverageListenSeconds:0.#} giây")</div>
                                            <div class="map-analytics-track">
                                                <div class="map-analytics-fill" style="width:@listenPercent%;"></div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="map-analytics-item">
                                        <div class="map-analytics-item-title">Chưa có dữ liệu nghe</div>
                                        <div class="map-analytics-item-meta">Bảng xếp hạng sẽ tự cập nhật khi app ghi lịch sử nghe.</div>
                                    </div>
                                }
                            </div>

                            <div class="map-analytics-divider"></div>

                            <div class="map-poi-kicker">Tóm tắt POI đang sửa</div>
                            <div class="fw-semibold mt-2" id="mapPoiNameLabel">@Model.Editor.Name</div>
                            <div class="text-muted mt-2" id="mapPoiAddressLabel">@Model.Editor.Address</div>

                            <div class="map-poi-metrics">
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Vi d?</span>
                                    <strong id="mapPoiLatValue">@initialLatitude</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Kinh d?</span>
                                    <strong id="mapPoiLngValue">@initialLongitude</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Bán kính</span>
                                    <strong id="mapPoiRadiusValue">@Model.Editor.RadiusInMeters m</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Ưu tiên</span>
                                    <strong id="mapPoiPriorityValue">#@Model.Editor.Priority</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Tổng POI</span>
                                    <strong>@Model.Pois.Count</strong>
                                </div>
                                <div class="map-poi-metric">
                                    <span class="map-poi-kicker">Tạm khóa</span>
                                    <strong>@inactivePoiCount</strong>
                                </div>
                            </div>

                            <div class="mt-3 text-muted">
                                Mã app: <strong>@Model.Editor.Code</strong><br />
                                QR sẵn sàng: <strong>@(Model.Editor.IsQrEnabled ? "Có" : "Chưa rõ")</strong><br />
                                Trạng thái: <strong id="mapPoiActiveValue">@(Model.Editor.IsActive ? "Đang hoạt động" : "Tạm khóa")</strong>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Model.Editor.MapLink))
                            {
                                <a href="@Model.Editor.MapLink" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary rounded-pill px-4 mt-3" id="mapPoiOpenLink">
                                    M? b?n d?
                                </a>
                            }
                            else
                            {
                                <a href="#" target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary rounded-pill px-4 mt-3 d-none" id="mapPoiOpenLink">
                                    M? b?n d?
                                </a>
                            }

                            <a href="@selectedAppLaunchUrl" class="btn btn-primary rounded-pill px-4 mt-3">
                                Mở POI này trong app
                            </a>
                        </div>
                    </div>

                    <div class="map-poi-form-card">
                        <form asp-action="Save" method="post">
                            @Html.AntiForgeryToken()

                            <input asp-for="SelectedPoiId" type="hidden" />
                            <input asp-for="Editor.Id" type="hidden" />
                            <input asp-for="Editor.Category" type="hidden" />
                            <input asp-for="Editor.CooldownMinutes" type="hidden" />
                            <input asp-for="Editor.SpecialDish" type="hidden" />
                            <input asp-for="Editor.ImageSource" type="hidden" />
                            <input asp-for="Editor.IsEditMode" type="hidden" />
                            <input asp-for="Editor.OwnerUserCode" type="hidden" />
                            <input asp-for="Editor.OwnerDisplayName" type="hidden" />
                            <input asp-for="Editor.OwnerEmail" type="hidden" />

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm"></div>

                            <div class="map-poi-form-grid">
                                <div>
                                    <label asp-for="Editor.Code" class="form-label">Mã POI</label>
                                    <input asp-for="Editor.Code" class="form-control" />
                                    <span asp-validation-for="Editor.Code" class="text-danger small"></span>
                                </div>

                                <div>
                                    <label asp-for="Editor.Priority" class="form-label">Priority</label>
                                    <input asp-for="Editor.Priority" class="form-control" id="mapPoiPriorityInput" />
                                    <span asp-validation-for="Editor.Priority" class="text-danger small"></span>
                                </div>

                                <div class="full">
                                    <label asp-for="Editor.Name" class="form-label">Tên điểm</label>
                                    <input asp-for="Editor.Name" class="form-control" id="mapPoiNameInput" />
                                    <span asp-validation-for="Editor.Name" class="text-danger small"></span>
                                </div>

                                <div class="full">
                                    <label asp-for="Editor.Address" class="form-label">Địa chỉ</label>
                                    <input asp-for="Editor.Address" class="form-control" id="mapPoiAddressInput" />
                                    <span asp-validation-for="Editor.Address" class="text-danger small"></span>
                                </div>

                                <div class="full">
                                    <label asp-for="Editor.Description" class="form-label">Mô tả</label>
                                    <textarea asp-for="Editor.Description" class="form-control" rows="4"></textarea>
                                    <span asp-validation-for="Editor.Description" class="text-danger small"></span>
                                </div>

                                <div class="full">
                                    <label asp-for="Editor.NarrationScript" class="form-label">Nội dung thuyết minh</label>
                                    <textarea asp-for="Editor.NarrationScript" class="form-control" rows="5"></textarea>
                                    <span asp-validation-for="Editor.NarrationScript" class="text-danger small"></span>
                                </div>

                                <div>
                                    <label asp-for="Editor.Latitude" class="form-label">Vi d?</label>
                                    <input asp-for="Editor.Latitude" class="form-control" id="mapPoiLatitude" />
                                    <span asp-validation-for="Editor.Latitude" class="text-danger small"></span>
                                </div>

                                <div>
                                    <label asp-for="Editor.Longitude" class="form-label">Kinh d?</label>
                                    <input asp-for="Editor.Longitude" class="form-control" id="mapPoiLongitude" />
                                    <span asp-validation-for="Editor.Longitude" class="text-danger small"></span>
                                </div>

                                <div>
                                    <label asp-for="Editor.RadiusInMeters" class="form-label">Bán kính kích hoạt (m)</label>
                                    <input asp-for="Editor.RadiusInMeters" class="form-control" id="mapPoiRadiusInput" />
                                    <span asp-validation-for="Editor.RadiusInMeters" class="text-danger small"></span>
                                </div>

                                <div>
                                    <label asp-for="Editor.MapLink" class="form-label">Liên kết bản đồ</label>
                                    <input asp-for="Editor.MapLink" class="form-control" id="mapPoiMapLink" />
                                    <span asp-validation-for="Editor.MapLink" class="text-danger small"></span>
                                </div>

                                <div class="full">
                                    <div class="form-check form-switch mt-2">
                                        <input asp-for="Editor.IsActive" class="form-check-input" id="mapPoiActiveInput" />
                                        <label asp-for="Editor.IsActive" class="form-check-label">POI đang hoạt động</label>
                                    </div>
                                </div>
                            </div>

                            <div class="map-poi-actions">
                                <button type="submit" class="btn btn-primary rounded-pill px-4">Luu thay d?i</button>
                                <a asp-controller="Pois" asp-action="Details" asp-route-id="@Model.Editor.Id" class="btn btn-outline-dark rounded-pill px-4">Xem chi tiết</a>
                                <a asp-action="Index" asp-route-poiId="@Model.Editor.Id" class="btn btn-outline-secondary rounded-pill px-4">Tải lại dữ liệu</a>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script>
        (() => {
            const mapPois = @Html.Raw(JsonSerializer.Serialize(mapPois, jsonOptions));
            const selectedPoiId = @Html.Raw(JsonSerializer.Serialize(Model.SelectedPoiId.ToString(), jsonOptions));
            const initialStats = @Html.Raw(JsonSerializer.Serialize(Model.ActiveDeviceStats, jsonOptions));
            const statsUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("ActiveDevices", "Home"), jsonOptions));
            const eventsUrl = @Html.Raw(JsonSerializer.Serialize(Url.Action("ActiveDeviceEvents", "Home"), jsonOptions));
            const latInput = document.getElementById("mapPoiLatitude");
            const lngInput = document.getElementById("mapPoiLongitude");
            const radiusInput = document.getElementById("mapPoiRadiusInput");
            const priorityInput = document.getElementById("mapPoiPriorityInput");
            const mapLinkInput = document.getElementById("mapPoiMapLink");
            const activeInput = document.getElementById("mapPoiActiveInput");
            const nameInput = document.getElementById("mapPoiNameInput");
            const addressInput = document.getElementById("mapPoiAddressInput");
            const openLink = document.getElementById("mapPoiOpenLink");
            const statusBox = document.getElementById("mapPoiStatus");
            const recenterButton = document.getElementById("recenterMapButton");
            const latLabel = document.getElementById("mapPoiLatValue");
            const lngLabel = document.getElementById("mapPoiLngValue");
            const radiusLabel = document.getElementById("mapPoiRadiusValue");
            const priorityLabel = document.getElementById("mapPoiPriorityValue");
            const activeLabel = document.getElementById("mapPoiActiveValue");
            const nameLabel = document.getElementById("mapPoiNameLabel");
            const addressLabel = document.getElementById("mapPoiAddressLabel");
            const recenterAnalyticsButton = document.getElementById("recenterAnalyticsButton");
            const analyticsRoutePointCount = document.getElementById("analyticsRoutePointCount");
            const analyticsHeatmapPointCount = document.getElementById("analyticsHeatmapPointCount");
            const analyticsMapEmptyState = document.getElementById("analyticsMapEmptyState");

            if (!latInput || !lngInput || !radiusInput || !priorityInput || !mapLinkInput) {
                return;
            }

            const fallbackLat = 10.761450;
            const fallbackLng = 106.702820;
            const selectedPoi = mapPois.find((poi) => poi.id === selectedPoiId) ?? null;

            const parseNumber = (value, fallback) => {
                const parsed = Number.parseFloat(value);
                return Number.isFinite(parsed) ? parsed : fallback;
            };

            const isUsableCoordinate = (lat, lng) =>
                Number.isFinite(lat) &&
                Number.isFinite(lng) &&
                Math.abs(lat) <= 90 &&
                Math.abs(lng) <= 180 &&
                (Math.abs(lat) > 0.000001 || Math.abs(lng) > 0.000001);

            const formatCoordinate = (value) => Number(value).toFixed(6);
            const buildMapLink = (lat, lng) => `https://maps.google.com/?q=${formatCoordinate(lat)},${formatCoordinate(lng)}`;
            const escapeHtml = (value) => String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            const houseMarkerSvg = `
                <svg viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                    <path d="M6.5 23.5 24 8l17.5 15.5" fill="none" stroke="#ffffff" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
                    <path d="M11 22.5 24 11l13 11.5V40H11V22.5Z" fill="currentColor" stroke="#ffffff" stroke-width="4" stroke-linejoin="round"></path>
                    <path d="M20 40V29h8v11" fill="#ffffff"></path>
                </svg>`;

            const buildMarkerIcon = (poi, isSelected) => L.divIcon({
                className: "",
                html: `<span class="map-poi-marker ${isSelected ? "is-selected" : ""} ${poi.isActive ? "" : "is-inactive"} ${Number(poi.listenCount || 0) > 0 ? "has-listens" : ""} ${poi.isTopListening ? "is-top-listening" : ""}">${houseMarkerSvg}</span>`,
                iconSize: isSelected ? [38, 38] : [34, 34],
                iconAnchor: isSelected ? [19, 34] : [17, 30],
                popupAnchor: [0, -30]
            });

            const buildPopupHtml = (poi, isSelected) => {
                const status = poi.isActive ? "Đang hoạt động" : "Tạm khóa";
                const address = poi.address?.trim() || "Chưa có địa chỉ";
                const code = poi.code?.trim() || "Chưa có ma";
                const listenCount = Number(poi.listenCount || 0);
                const averageListenSeconds = Number(poi.averageListenSeconds || 0);
                const selectedBadge = isSelected
                        ? '<span>Đang sửa</span>'
                    : `<a href="${escapeHtml(poi.selectUrl)}">Sửa trên map</a>`;

                return `
                    <div class="map-poi-popup">
                        <div class="map-poi-popup-title">${escapeHtml(poi.name || "POI chưa đặt tên")}</div>
                        <div class="map-poi-popup-meta">
                            ${escapeHtml(address)}<br />
                            ${escapeHtml(code)} - ${status} - Radius ${Number(poi.radius || 0)} m<br />
                            ${listenCount} lượt nghe - TB ${Number.isFinite(averageListenSeconds) ? averageListenSeconds.toFixed(1) : "0.0"} giây
                        </div>
                        <div class="map-poi-popup-actions">
                            ${selectedBadge}
                            <a href="${escapeHtml(poi.detailsUrl)}">Chi tiết</a>
                            <a href="${escapeHtml(poi.qrUrl)}">QR</a>
                            <a href="${escapeHtml(poi.appLaunchUrl)}">Mở app</a>
                        </div>
                    </div>`;
            };

            const syncTextPreview = () => {
                if (nameLabel) {
                    nameLabel.textContent = nameInput.value.trim() || "POI chưa đặt tên";
                }

                if (addressLabel) {
                    addressLabel.textContent = addressInput.value.trim() || "Địa chỉ sẽ hiển thị tại đây.";
                }
            };

            const syncMetaPreview = () => {
                const lat = parseNumber(latInput.value, fallbackLat);
                const lng = parseNumber(lngInput.value, fallbackLng);
                const radius = Math.max(1, parseNumber(radiusInput.value, 50));
                const priority = Math.max(1, parseNumber(priorityInput.value, 1));

                latLabel.textContent = formatCoordinate(lat);
                lngLabel.textContent = formatCoordinate(lng);
                radiusLabel.textContent = `${Math.round(radius)} m`;
                priorityLabel.textContent = `#${Math.round(priority)}`;

                if (activeLabel) {
                    activeLabel.textContent = activeInput && activeInput.checked ? "Đang hoạt động" : "Tạm khóa";
                }

                if (openLink) {
                    const href = mapLinkInput.value.trim();
                    if (href) {
                        openLink.href = href;
                        openLink.classList.remove("d-none");
                    } else {
                        openLink.href = "#";
                        openLink.classList.add("d-none");
                    }
                }
            };

            let map = null;
            let marker = null;
            let circle = null;
            let markerBounds = null;
            let heatLayer = null;
            let routeLayer = null;
            let activeDeviceLayer = null;
            let lastStats = initialStats;
            let isLoadingStats = false;

            const getCoordinates = () => ({
                lat: parseNumber(latInput.value, fallbackLat),
                lng: parseNumber(lngInput.value, fallbackLng)
            });

            const syncCircle = () => {
                if (!circle || !marker) {
                    return;
                }

                const radius = Math.max(1, parseNumber(radiusInput.value, 50));
                const position = marker.getLatLng();
                circle.setLatLng(position);
                circle.setRadius(radius);
            };

            const syncMapLink = (lat, lng) => {
                mapLinkInput.value = buildMapLink(lat, lng);
            };

            const applyCoordinates = (lat, lng, recenter) => {
                latInput.value = formatCoordinate(lat);
                lngInput.value = formatCoordinate(lng);
                syncMapLink(lat, lng);
                syncMetaPreview();

                if (!marker || !map) {
                    return;
                }

                marker.setLatLng([lat, lng]);
                syncCircle();

                if (recenter) {
                    map.setView([lat, lng], Math.max(map.getZoom(), 17));
                }
            };

            const hasDeviceLocation = (device) =>
                Number.isFinite(Number(device?.latitude)) &&
                Number.isFinite(Number(device?.longitude));

            const hasRouteLocation = (point) =>
                Number.isFinite(Number(point?.latitude)) &&
                Number.isFinite(Number(point?.longitude));

            const formatTime = (value) => {
                if (!value) {
                    return "Chưa có";
                }

                const date = new Date(value);
                if (Number.isNaN(date.getTime())) {
                    return "Chưa có";
                }

                return date.toLocaleString("vi-VN", {
                    day: "2-digit",
                    month: "2-digit",
                    year: "numeric",
                    hour: "2-digit",
                    minute: "2-digit"
                });
            };

            const buildActiveUserIcon = (index) => L.divIcon({
                className: "",
                html: `<span class="map-active-user-marker device-color-${index % 5}"></span>`,
                iconSize: [16, 16],
                iconAnchor: [8, 8],
                popupAnchor: [0, -10]
            });

            const getRoutePoints = (stats) =>
                Array.isArray(stats?.routePoints)
                    ? stats.routePoints.filter(hasRouteLocation)
                    : [];

            const getLocatedDevices = (stats) =>
                Array.isArray(stats?.devices)
                    ? stats.devices.filter(hasDeviceLocation)
                    : [];

            const getHeatPoints = (stats) => {
                const routeItems = getRoutePoints(stats);
                if (routeItems.length > 0) {
                    return routeItems.map((point) => ({
                        latitude: Number(point.latitude),
                        longitude: Number(point.longitude),
                        accuracyMeters: Number(point.accuracyMeters),
                        recordedAtUtc: point.recordedAtUtc
                    }));
                }

                return getLocatedDevices(stats).map((device) => ({
                    latitude: Number(device.latitude),
                    longitude: Number(device.longitude),
                    accuracyMeters: Number(device.accuracyMeters),
                    recordedAtUtc: device.locationTimestampUtc || device.lastSeenAtUtc
                }));
            };

            const updateAnalyticsCounters = (stats) => {
                const routeCount = getRoutePoints(stats).length;
                const heatCount = getHeatPoints(stats).length;

                if (analyticsRoutePointCount) {
                    analyticsRoutePointCount.textContent = routeCount.toString();
                }

                if (analyticsHeatmapPointCount) {
                    analyticsHeatmapPointCount.textContent = heatCount.toString();
                }

                if (analyticsMapEmptyState) {
                    analyticsMapEmptyState.classList.toggle("is-hidden", heatCount > 0);
                }
            };

            const renderRouteLayer = (stats) => {
                if (!map || !routeLayer || !window.L) {
                    return;
                }

                routeLayer.clearLayers();
                const routeGroups = new Map();

                for (const point of getRoutePoints(stats)) {
                    const routeId = point.anonymousRouteId || "ANON";
                    if (!routeGroups.has(routeId)) {
                        routeGroups.set(routeId, []);
                    }

                    routeGroups.get(routeId).push(point);
                }

                let routeIndex = 0;
                for (const [routeId, points] of routeGroups) {
                    const sortedPoints = points
                        .slice()
                        .sort((left, right) => new Date(left.recordedAtUtc) - new Date(right.recordedAtUtc));
                    const coordinates = sortedPoints.map((point) => [Number(point.latitude), Number(point.longitude)]);

                    if (coordinates.length >= 2) {
                        L.polyline(coordinates, {
                            color: routeIndex % 2 === 0 ? "#0f172a" : "#2563eb",
                            weight: 4,
                            opacity: 0.72,
                            dashArray: "8 8"
                        }).addTo(routeLayer);
                    }

                    sortedPoints.forEach((point, index) => {
                        const marker = L.circleMarker([Number(point.latitude), Number(point.longitude)], {
                            radius: index === sortedPoints.length - 1 ? 6 : 4,
                            color: "#ffffff",
                            weight: 2,
                            fillColor: index === sortedPoints.length - 1 ? "#ef4444" : "#2563eb",
                            fillOpacity: 0.9
                        });

                        marker.bindPopup(`
                            <div class="map-route-popup">
                                <div class="fw-semibold">Tuyen ${escapeHtml(routeId)}</div>
                                <div>${escapeHtml(formatCoordinate(point.latitude))}, ${escapeHtml(formatCoordinate(point.longitude))}</div>
                                <div>${escapeHtml(formatTime(point.recordedAtUtc))}</div>
                            </div>`);
                        marker.addTo(routeLayer);
                    });

                    routeIndex += 1;
                }
            };

            const renderActiveDeviceLayer = (stats) => {
                if (!map || !activeDeviceLayer || !window.L) {
                    return;
                }

                activeDeviceLayer.clearLayers();
                getLocatedDevices(stats).forEach((device, index) => {
                    const marker = L.marker([Number(device.latitude), Number(device.longitude)], {
                        icon: buildActiveUserIcon(index),
                    title: `Người dùng online #${index + 1}`
                    });

                    marker.bindPopup(`
                        <div class="map-route-popup">
                                <div class="fw-semibold">Người dùng online #${index + 1}</div>
                            <div>${escapeHtml(formatCoordinate(device.latitude))}, ${escapeHtml(formatCoordinate(device.longitude))}</div>
                            <div>${escapeHtml(formatTime(device.locationTimestampUtc || device.lastSeenAtUtc))}</div>
                        </div>`);
                    marker.addTo(activeDeviceLayer);
                });
            };

            const renderHeatLayer = (stats) => {
                if (!heatLayer) {
                    return;
                }

                heatLayer.setLatLngs(getHeatPoints(stats).map((point) => {
                    const accuracy = Number(point.accuracyMeters);
                    const weight = Number.isFinite(accuracy) && accuracy > 0
                        ? Math.max(0.35, 1 - Math.min(accuracy, 120) / 180)
                        : 0.75;

                    return [Number(point.latitude), Number(point.longitude), weight];
                }));
            };

            const renderAnalyticsLayers = (stats) => {
                lastStats = stats || {};
                updateAnalyticsCounters(lastStats);
                renderHeatLayer(lastStats);
                renderRouteLayer(lastStats);
                renderActiveDeviceLayer(lastStats);
            };

            const recenterAnalytics = () => {
                if (!map || !window.L) {
                    return;
                }

                const heatPoints = getHeatPoints(lastStats);
                if (heatPoints.length === 0) {
                    map.setView([fallbackLat, fallbackLng], 17);
                    return;
                }

                if (heatPoints.length === 1) {
                    map.setView([Number(heatPoints[0].latitude), Number(heatPoints[0].longitude)], 18);
                    return;
                }

                const bounds = L.latLngBounds(heatPoints.map((point) => [
                    Number(point.latitude),
                    Number(point.longitude)
                ]));

                map.fitBounds(bounds.pad(0.25), { maxZoom: 18 });
            };

            const loadStats = async () => {
                if (!statsUrl || isLoadingStats) {
                    return;
                }

                isLoadingStats = true;
                try {
                    const response = await fetch(statsUrl, { cache: "no-store" });
                    if (!response.ok) {
                        return;
                    }

                    renderAnalyticsLayers(await response.json());
                } catch {
                } finally {
                    isLoadingStats = false;
                }
            };

            const initializeMap = () => {
                if (!window.L) {
                    statusBox.textContent = "Không tải được thư viện bản đồ. Bạn vẫn có thể sửa thủ công các trường tọa độ.";
                    return;
                }

                const start = getCoordinates();
                map = L.map("poiMapCanvas", { zoomControl: true }).setView([start.lat, start.lng], 17);

                L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                    maxZoom: 19,
                    attribution: "&copy; OpenStreetMap"
                }).addTo(map);

                if (typeof L.heatLayer === "function") {
                    heatLayer = L.heatLayer([], {
                        radius: 32,
                        blur: 28,
                        maxZoom: 19,
                        minOpacity: 0.35,
                        gradient: {
                            0.2: "#38bdf8",
                            0.45: "#2563eb",
                            0.7: "#7c3aed",
                            1.0: "#ef4444"
                        }
                    }).addTo(map);
                }

                routeLayer = L.layerGroup().addTo(map);
                activeDeviceLayer = L.layerGroup().addTo(map);
                markerBounds = L.latLngBounds([]);

                for (const poi of mapPois) {
                    const lat = Number(poi.latitude);
                    const lng = Number(poi.longitude);

                    if (!isUsableCoordinate(lat, lng)) {
                        continue;
                    }

                    const isSelected = poi.id === selectedPoiId;
                    const poiMarker = L.marker([lat, lng], {
                        draggable: isSelected,
                        icon: buildMarkerIcon(poi, isSelected),
                        title: poi.name || poi.code || "POI"
                    }).addTo(map);

                    poiMarker.bindPopup(buildPopupHtml(poi, isSelected), { maxWidth: 320 });
                    markerBounds.extend([lat, lng]);

                    if (isSelected) {
                        marker = poiMarker;
                    }
                }

                if (!marker) {
                    marker = L.marker([start.lat, start.lng], {
                        draggable: true,
                        icon: buildMarkerIcon(selectedPoi ?? { isActive: true, listenCount: 0, isTopListening: false }, true),
                        title: selectedPoi?.name || "POI đang sửa"
                    }).addTo(map);

                    if (selectedPoi) {
                        marker.bindPopup(buildPopupHtml(selectedPoi, true), { maxWidth: 320 });
                    }
                }

                circle = L.circle(marker.getLatLng(), {
                    radius: Math.max(1, parseNumber(radiusInput.value, 50)),
                    color: "#2563eb",
                    fillColor: "#60a5fa",
                    fillOpacity: 0.18,
                    weight: 2
                }).addTo(map);

                marker.on("dragend", () => {
                    const position = marker.getLatLng();
                    applyCoordinates(position.lat, position.lng, false);
                    statusBox.textContent = "Đã cập nhật tọa độ từ marker.";
                });

                map.on("click", (event) => {
                    applyCoordinates(event.latlng.lat, event.latlng.lng, false);
                    statusBox.textContent = "Đã cập nhật tọa độ từ điểm bấm trên bản đồ.";
                });

                window.setTimeout(() => {
                    map.invalidateSize();

                    if (markerBounds?.isValid()) {
                        if (markerBounds.getNorthEast().equals(markerBounds.getSouthWest())) {
                            map.setView(markerBounds.getCenter(), 17);
                        } else {
                            map.fitBounds(markerBounds.pad(0.18), { maxZoom: 17 });
                        }
                    }
                }, 80);
            };

            latInput.addEventListener("input", () => {
                const { lat, lng } = getCoordinates();
                applyCoordinates(lat, lng, false);
            });

            lngInput.addEventListener("input", () => {
                const { lat, lng } = getCoordinates();
                applyCoordinates(lat, lng, false);
            });

            radiusInput.addEventListener("input", () => {
                syncCircle();
                syncMetaPreview();
            });

            priorityInput.addEventListener("input", syncMetaPreview);
            activeInput?.addEventListener("change", syncMetaPreview);
            nameInput.addEventListener("input", syncTextPreview);
            addressInput.addEventListener("input", syncTextPreview);
            mapLinkInput.addEventListener("input", syncMetaPreview);

            recenterButton?.addEventListener("click", () => {
                if (!map || !marker) {
                    return;
                }

                map.setView(marker.getLatLng(), 17);
            });

            recenterAnalyticsButton?.addEventListener("click", recenterAnalytics);

            syncTextPreview();
            syncMetaPreview();
            initializeMap();
            renderAnalyticsLayers(lastStats);
            void loadStats();
            window.setInterval(() => {
                void loadStats();
            }, 5000);

            if ("EventSource" in window && eventsUrl) {
                const source = new EventSource(eventsUrl);
                source.addEventListener("active-devices", (event) => {
                    try {
                        renderAnalyticsLayers(JSON.parse(event.data));
                    } catch {
                        void loadStats();
                    }
                });
                source.onerror = () => {
                    source.close();
                };
            }

            window.addEventListener("focus", () => {
                map?.invalidateSize();
                void loadStats();
            });

            window.addEventListener("resize", () => {
                map?.invalidateSize();
            });
        })();
    </script>
}
