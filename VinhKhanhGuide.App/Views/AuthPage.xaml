<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="VinhKhanhGuide.App.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F4F8FF"
    NavigationPage.HasNavigationBar="False"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="22,36,22,28" Spacing="18">

            <Border StrokeThickness="0"
                    Padding="22"
                    StrokeShape="RoundRectangle 34">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Color="#2F80FF" Offset="0.0" />
                        <GradientStop Color="#5A9CFF" Offset="0.55" />
                        <GradientStop Color="#8CC0FF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="10">
                    <Label Text="VinhKhanh"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="{Binding WelcomeTitle}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <Label Text="{Binding HeroDescription}"
                           FontSize="14"
                           LineHeight="1.2"
                           TextColor="#EAF3FF" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    Stroke="#D8E8FF"
                    StrokeThickness="1"
                    Padding="20"
                    StrokeShape="RoundRectangle 30">
                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding LanguagePromptTitle}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />

                        <Label Text="{Binding LanguagePromptSubtitle}"
                               FontSize="13"
                               TextColor="#5E7491" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#F8FBFF"
                            Stroke="#DCEBFF"
                            StrokeThickness="1"
                            Padding="16"
                            StrokeShape="RoundRectangle 22">
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#DCEBFF"
                                    StrokeThickness="1"
                                    Padding="12,2"
                                    StrokeShape="RoundRectangle 16">
                                <Picker Title="{Binding LanguagePickerPlaceholder}"
                                        TitleColor="#8AA1BF"
                                        TextColor="#102A43"
                                        ItemsSource="{Binding SupportedLanguages}"
                                        ItemDisplayBinding="{Binding Label}"
                                        SelectedItem="{Binding SelectedLanguageOption}" />
                            </Border>

                            <Label Text="{Binding SelectedLanguageSummary}"
                                   FontSize="12"
                                   TextColor="#486581" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#FFF1F2"
                            Stroke="#F9CBD3"
                            StrokeThickness="1"
                            Padding="14,12"
                            StrokeShape="RoundRectangle 18"
                            IsVisible="{Binding HasErrorMessage}">
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="13"
                               TextColor="#BE123C" />
                    </Border>

                    <Button Text="{Binding EnterAppButtonText}"
                            Command="{Binding EnterAppCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#2F80FF"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="18"
                            HeightRequest="54" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#2F80FF" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
