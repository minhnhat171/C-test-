@model UserManagementPageViewModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h2 class="mb-1">Quản lý người dùng</h2>
        <div class="text-muted">
            Theo dõi danh sách người dùng, xem chi tiết hoạt động nghe, lọc trực tuyến/ngoại tuyến,
            tìm kiếm nhanh và mở vị trí gần nhất trên bản đồ.
        </div>
    </div>
    <div class="small text-muted" id="refresh-status">Tự động cập nhật mỗi 10 giây</div>
</div>

<form id="user-filter-form" asp-controller="Users" asp-action="Index" method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label class="form-label fw-semibold" for="keyword">Tìm người dùng</label>
                <input class="form-control" id="keyword" name="keyword" value="@Model.SearchTerm" placeholder="Nhập mã, tên, email..." />
            </div>
            <div class="col-lg-3">
                <label class="form-label fw-semibold" for="status">Trạng thái</label>
                <select class="form-select" id="status" name="status">
                    @if (Model.SelectedStatus == "all")
                    {
                        <option value="all" selected>Tất cả</option>
                    }
                    else
                    {
                        <option value="all">Tất cả</option>
                    }

                    @if (Model.SelectedStatus == "online")
                    {
                        <option value="online" selected>Trực tuyến</option>
                    }
                    else
                    {
                        <option value="online">Trực tuyến</option>
                    }

                    @if (Model.SelectedStatus == "offline")
                    {
                        <option value="offline" selected>Ngoại tuyến</option>
                    }
                    else
                    {
                        <option value="offline">Ngoại tuyến</option>
                    }
                </select>
            </div>
            <div class="col-lg-3">
                <input type="hidden" name="selectedUserId" value="@(Model.SelectedUserId?.ToString() ?? string.Empty)" />
                <div class="small text-muted">Chi tiết và bản đồ sẽ tự động đổi theo người dùng đang chọn.</div>
            </div>
            <div class="col-lg-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Cập nhật</button>
                <a class="btn btn-outline-secondary" asp-controller="Users" asp-action="Index">Đặt lại</a>
            </div>
        </div>
    </div>
</form>

<div id="user-management-content">
    <partial name="_UserManagementContent" model="Model" />
</div>

@section Scripts {
    <script>
        (() => {
            const container = document.getElementById("user-management-content");
            const refreshStatus = document.getElementById("refresh-status");

            if (!container) {
                return;
            }

            async function refreshSnapshot() {
                const url = new URL(window.location.href);
                url.searchParams.set("partial", "true");

                try {
                    const response = await fetch(url.toString(), {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    container.innerHTML = await response.text();

                    if (refreshStatus) {
                        refreshStatus.textContent = `Tự động cập nhật lúc ${new Date().toLocaleTimeString("vi-VN")}`;
                    }
                } catch {
                    if (refreshStatus) {
                        refreshStatus.textContent = "Đang chờ API cập nhật người dùng mới...";
                    }
                }
            }

            const timerId = window.setInterval(refreshSnapshot, 10000);
            window.addEventListener("beforeunload", () => window.clearInterval(timerId), { once: true });
        })();
    </script>
}
