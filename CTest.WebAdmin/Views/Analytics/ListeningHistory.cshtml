@model ListeningHistoryPageViewModel
@{
    ViewData["Title"] = "Lich su nghe";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h2 class="mb-1">Lich su nghe</h2>
        <div class="text-muted">
            Theo doi luot nghe tu app, sap xep theo thoi gian, loc theo ngay / tuan / thang
            va xem xep hang POI duoc nghe nhieu nhat.
        </div>
    </div>
    <div class="small text-muted" id="refresh-status">Tu dong cap nhat moi 8 giay</div>
</div>

<form id="history-filter-form" asp-controller="Analytics" asp-action="ListeningHistory" method="get" class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="period">Moc thoi gian</label>
                <select class="form-select" id="period" name="period">
                    @if (Model.SelectedPeriod == "all")
                    {
                        <option value="all" selected>Tat ca</option>
                    }
                    else
                    {
                        <option value="all">Tat ca</option>
                    }

                    @if (Model.SelectedPeriod == "day")
                    {
                        <option value="day" selected>24 gio qua</option>
                    }
                    else
                    {
                        <option value="day">24 gio qua</option>
                    }

                    @if (Model.SelectedPeriod == "week")
                    {
                        <option value="week" selected>7 ngay qua</option>
                    }
                    else
                    {
                        <option value="week">7 ngay qua</option>
                    }

                    @if (Model.SelectedPeriod == "month")
                    {
                        <option value="month" selected>30 ngay qua</option>
                    }
                    else
                    {
                        <option value="month">30 ngay qua</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="sortBy">Sap xep</label>
                <select class="form-select" id="sortBy" name="sortBy">
                    @if (Model.SelectedSortBy == "time_desc")
                    {
                        <option value="time_desc" selected>Moi nhat truoc</option>
                    }
                    else
                    {
                        <option value="time_desc">Moi nhat truoc</option>
                    }

                    @if (Model.SelectedSortBy == "time_asc")
                    {
                        <option value="time_asc" selected>Cu nhat truoc</option>
                    }
                    else
                    {
                        <option value="time_asc">Cu nhat truoc</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" for="view">Man hinh chinh</label>
                <select class="form-select" id="view" name="view">
                    @if (Model.SelectedView == "timeline")
                    {
                        <option value="timeline" selected>Dong thoi gian</option>
                    }
                    else
                    {
                        <option value="timeline">Dong thoi gian</option>
                    }

                    @if (Model.SelectedView == "ranking")
                    {
                        <option value="ranking" selected>Xep hang POI</option>
                    }
                    else
                    {
                        <option value="ranking">Xep hang POI</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Cap nhat</button>
                <a class="btn btn-outline-secondary" asp-controller="Analytics" asp-action="ListeningHistory">Dat lai</a>
            </div>
        </div>
    </div>
</form>

<div id="listening-history-content">
    <partial name="_ListeningHistoryContent" model="Model" />
</div>

@section Scripts {
    <script>
        (() => {
            const container = document.getElementById("listening-history-content");
            const refreshStatus = document.getElementById("refresh-status");

            if (!container) {
                return;
            }

            async function refreshSnapshot() {
                const url = new URL(window.location.href);
                url.searchParams.set("partial", "true");

                try {
                    const response = await fetch(url.toString(), {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    container.innerHTML = await response.text();

                    if (refreshStatus) {
                        refreshStatus.textContent = `Tu dong cap nhat luc ${new Date().toLocaleTimeString("vi-VN")}`;
                    }
                } catch {
                    if (refreshStatus) {
                        refreshStatus.textContent = "Dang cho API hoac app gui du lieu moi...";
                    }
                }
            }

            const timerId = window.setInterval(refreshSnapshot, 8000);
            window.addEventListener("beforeunload", () => window.clearInterval(timerId), { once: true });
        })();
    </script>
}
