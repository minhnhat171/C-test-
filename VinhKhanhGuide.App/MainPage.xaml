<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui8"
    x:Class="VinhKhanhGuide.App.MainPage"
    BackgroundColor="#F4F8FF"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <ScrollView x:Name="MainScrollView"
                    Grid.Row="0">
            <VerticalStackLayout Padding="20,24,20,18"
                                 Spacing="18">

                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 34">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#2F80FF" Offset="0" />
                            <GradientStop Color="#6AA8FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Padding="22"
                                         Spacing="18">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Vinh Khanh Guide"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#DCEBFF" />

                                <Label Text="{Binding CurrentUserDisplayName, StringFormat='Xin chào, {0}'}"
                                       FontSize="30"
                                       FontAttributes="Bold"
                                       TextColor="White" />

                                <Label Text="{Binding CurrentUserStatusLine}"
                                       FontSize="16"
                                       TextColor="#EAF3FF" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding CurrentUserInitials}"
                                    Clicked="OnOpenAccountPageClicked"
                                    BackgroundColor="#FFFFFF"
                                    TextColor="#2F80FF"
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    CornerRadius="28"
                                    Padding="0" />
                        </Grid>

                        <Border BackgroundColor="#FFFFFF"
                                StrokeThickness="0"
                                Padding="16"
                                StrokeShape="RoundRectangle 24">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#102A43" />
                                    <Label Text="{Binding LocationText}"
                                           FontSize="14"
                                           TextColor="#4F7096" />
                                    <Label Text="{Binding NearestPoiText}"
                                           FontSize="14"
                                           TextColor="#4F7096" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#D9E9FF"
                                        StrokeThickness="0"
                                        Padding="12,8"
                                        VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 16">
                                    <Label Text="{Binding MapModeBadgeText}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2F80FF" />
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Tìm kiếm"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <Border BackgroundColor="#FFFFFF"
                            Padding="18,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <Label Text="⌕"
                                   FontSize="20"
                                   TextColor="#7B8BA3"
                                   VerticalTextAlignment="Center" />

                            <Entry x:Name="RestaurantSearchEntry"
                                   Grid.Column="1"
                                   Text="{Binding SearchQuery}"
                                   Placeholder="Tìm quán hoặc tour"
                                   Completed="OnSearchCompleted"
                                   Focused="OnSearchFocused"
                                   Unfocused="OnSearchUnfocused"
                                   ReturnType="Search"
                                   BackgroundColor="Transparent"
                                   FontSize="17"
                                   TextColor="#102A43"
                                   PlaceholderColor="#92A4BD"
                                   VerticalTextAlignment="Center" />

                            <Button Grid.Column="2"
                                    Text="✕"
                                    Clicked="OnClearSearchClicked"
                                    IsVisible="{Binding HasSearchQuery}"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    WidthRequest="34"
                                    HeightRequest="34"
                                    CornerRadius="17"
                                    Padding="0"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22"
                            IsVisible="{Binding IsSearchSuggestionsVisible}">
                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding SearchSuggestions}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FBFF"
                                            Padding="12,10"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSearchSuggestionTapped" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="10">
                                            <Label Text="{Binding LeadingIcon}"
                                                   FontSize="18"
                                                   TextColor="#5E7491"
                                                   VerticalTextAlignment="Center" />

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2">
                                                <Label Text="{Binding Text}"
                                                       FontSize="15"
                                                       TextColor="#102A43" />
                                                <Label Text="{Binding SupportingText}"
                                                       FontSize="13"
                                                       TextColor="#6B7C93"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding SearchResultStatusText}"
                           FontSize="14"
                           TextColor="#7B8BA3"
                           IsVisible="{Binding IsSearchResultEmpty}" />
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Padding="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="18,18,18,12"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Bản đồ khám phá"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#102A43" />
                                <Label Text="{Binding MapPoiBadgeText}"
                                       FontSize="14"
                                       TextColor="#6B7C93" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Mở lớn"
                                    Clicked="OnOpenFullScreenMapClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="16"
                                    Padding="14,8" />
                        </Grid>

                        <Grid>
                            <mapsui:MapView x:Name="RestaurantMap"
                                            HeightRequest="250"
                                            IsZoomButtonVisible="False"
                                            IsNorthingButtonVisible="False"
                                            IsMyLocationButtonVisible="False"
                                            RotationLock="True" />

                            <VerticalStackLayout Spacing="8"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="End"
                                                 Margin="0,0,14,14">
                                <Button Text="+"
                                        Clicked="OnZoomInClicked"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#2F80FF"
                                        FontSize="22"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        CornerRadius="21" />

                                <Button Text="-"
                                        Clicked="OnZoomOutClicked"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#2F80FF"
                                        FontSize="22"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        CornerRadius="21" />

                                <Button Text="◎"
                                        Clicked="OnCenterCurrentLocationClicked"
                                        BackgroundColor="#FFFFFF"
                                        TextColor="#2F80FF"
                                        FontSize="20"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        CornerRadius="21" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid Padding="18,14,18,18"
                              ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Text="Bật GPS"
                                    Command="{Binding StartTrackingCommand}"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="Tắt GPS"
                                    Command="{Binding StopTrackingCommand}"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="15"
                                    CornerRadius="18" />

                            <Button Grid.Column="2"
                                    Text="Điểm đầu"
                                    Clicked="OnGpsOriginClicked"
                                    BackgroundColor="#102A43"
                                    TextColor="White"
                                    FontSize="15"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout x:Name="TourSectionAnchor"
                                     Spacing="14">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Border BackgroundColor="#D9E9FF"
                                Padding="12"
                                StrokeThickness="0"
                                WidthRequest="48"
                                HeightRequest="48"
                                StrokeShape="RoundRectangle 18">
                            <Image Source="tour_route_icon.svg"
                                   Aspect="AspectFit" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                            <Label Text="Tour"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Label Text="{Binding TourSectionSummary}"
                                   FontSize="14"
                                   TextColor="#6B7C93" />
                        </VerticalStackLayout>
                    </Grid>

                    <CollectionView ItemsSource="{Binding TourPackages}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnTourSelectionChanged"
                                    HeightRequest="230"
                                    IsVisible="{Binding HasTours}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#FFFFFF"
                                        Padding="18"
                                        WidthRequest="290"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 28">
                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12">
                                            <Border BackgroundColor="#E8F1FF"
                                                    Padding="12"
                                                    StrokeThickness="0"
                                                    WidthRequest="48"
                                                    HeightRequest="48"
                                                    StrokeShape="RoundRectangle 18">
                                                <Image Source="tour_route_icon.svg"
                                                       Aspect="AspectFit" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="4"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       TextColor="#102A43"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding MetaLabel}"
                                                       FontSize="14"
                                                       TextColor="#4F7096" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Label Text="{Binding Description}"
                                               FontSize="15"
                                               TextColor="#486581"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="3" />

                                        <Border BackgroundColor="#F4F8FF"
                                                Padding="12"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <Label Text="{Binding StopsSummary}"
                                                   FontSize="14"
                                                   TextColor="#486581"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="3" />
                                        </Border>

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <Border BackgroundColor="#2F80FF"
                                                    Padding="12,10"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 18">
                                                <Label Text="{Binding ActionLabel}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       TextColor="White" />
                                            </Border>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="#E8F1FF"
                                                    Padding="12,10"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 18">
                                                <Label Text="{Binding StatusLabel}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#2F80FF" />
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Border BackgroundColor="#FFFFFF"
                            Padding="18"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28"
                            IsVisible="{Binding HasActiveTour}">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding ActiveTourName}"
                                           FontSize="24"
                                           FontAttributes="Bold"
                                           TextColor="#102A43" />
                                    <Label Text="{Binding ActiveTourSummary}"
                                           FontSize="15"
                                           TextColor="#486581" />
                                </VerticalStackLayout>

                                <Border Grid.Column="1"
                                        BackgroundColor="#D9E9FF"
                                        Padding="12,8"
                                        VerticalOptions="Start"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">
                                    <Label Text="Tour đang chạy"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#2F80FF" />
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Border BackgroundColor="#F4F8FF"
                                        Padding="14"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Chặng hiện tại"
                                               FontSize="14"
                                               TextColor="#6B7C93" />
                                        <Label Text="{Binding ActiveTourCurrentStopText}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#163B6D" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="#F4F8FF"
                                        Padding="14"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Chặng kế tiếp"
                                               FontSize="14"
                                               TextColor="#6B7C93" />
                                        <Label Text="{Binding ActiveTourNextStopText}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#163B6D" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Button Text="Xem lộ trình"
                                        Clicked="OnTourShortcutClicked"
                                        BackgroundColor="#2F80FF"
                                        TextColor="White"
                                        FontSize="16"
                                        CornerRadius="18" />

                                <Button Grid.Column="1"
                                        Text="Dừng tour"
                                        Clicked="OnStopActiveTourClicked"
                                        BackgroundColor="#102A43"
                                        TextColor="White"
                                        FontSize="16"
                                        CornerRadius="18" />
                            </Grid>

                            <CollectionView ItemsSource="{Binding ActiveTourStops}"
                                            SelectionMode="None"
                                            HeightRequest="220"
                                            IsVisible="{Binding HasActiveTourStops}">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical"
                                                       ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F8FBFF"
                                                Padding="14"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 20">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="12">
                                                <Border BackgroundColor="#2F80FF"
                                                        WidthRequest="36"
                                                        HeightRequest="36"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 18">
                                                    <Label Text="{Binding Order}"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="White" />
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="3">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="#102A43" />
                                                    <Label Text="{Binding Address}"
                                                           FontSize="14"
                                                           TextColor="#6B7C93"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding StatusLabel}"
                                                           FontSize="13"
                                                           TextColor="#2F80FF" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Border BackgroundColor="#FFFFFF"
                        Padding="18"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Điểm đang xem"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />

                        <Grid ColumnDefinitions="104,*"
                              ColumnSpacing="14">
                            <Border BackgroundColor="#E8F1FF"
                                    HeightRequest="104"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 22">
                                <Image Source="{Binding SelectedPoiImageSource}"
                                       Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6">
                                <Label Text="{Binding SelectedPoiName}"
                                       FontSize="21"
                                       FontAttributes="Bold"
                                       TextColor="#102A43"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding SelectedPoiAddress}"
                                       FontSize="14"
                                       TextColor="#6B7C93"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                                <Label Text="{Binding SelectedPoiStatusText}"
                                       FontSize="14"
                                       TextColor="#4F7096"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{Binding SelectedPoiDescription}"
                               FontSize="15"
                               TextColor="#486581"
                               LineBreakMode="TailTruncation"
                               MaxLines="3" />

                        <Border BackgroundColor="#F4F8FF"
                                Padding="12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                IsVisible="{Binding HasSelectedPoiDish}">
                            <Label Text="{Binding SelectedPoiDishText}"
                                   FontSize="14"
                                   TextColor="#2F80FF"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">
                            <Button Text="{Binding SelectedPoiNarrationActionText}"
                                    Clicked="OnNarrateSelectedClicked"
                                    BackgroundColor="#2F80FF"
                                    TextColor="White"
                                    FontSize="16"
                                    CornerRadius="18" />

                            <Button Grid.Column="1"
                                    Text="Chi tiết"
                                    Clicked="OnOpenSelectedPoiDetailClicked"
                                    BackgroundColor="#E8F1FF"
                                    TextColor="#2F80FF"
                                    FontSize="16"
                                    CornerRadius="18" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Danh sách quán"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#102A43" />

                    <VerticalStackLayout Spacing="14"
                                         BindableLayout.ItemsSource="{Binding FilteredPoiStatuses}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#FFFFFF"
                                        Padding="16"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 28">
                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="96,*"
                                              ColumnSpacing="14">
                                            <Border BackgroundColor="#E8F1FF"
                                                    HeightRequest="96"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 20">
                                                <Image Source="{Binding ImageSource}"
                                                       Aspect="AspectFill" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="6">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="8">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="19"
                                                           FontAttributes="Bold"
                                                           TextColor="#102A43"
                                                           LineBreakMode="TailTruncation" />

                                                    <Border Grid.Column="1"
                                                            BackgroundColor="#D9E9FF"
                                                            Padding="10,6"
                                                            VerticalOptions="Start"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 14">
                                                        <Label Text="{Binding DistanceLabel}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="#2F80FF" />
                                                    </Border>
                                                </Grid>

                                                <Label Text="{Binding Address}"
                                                       FontSize="14"
                                                       TextColor="#6B7C93"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />

                                                <Border BackgroundColor="#EAF3FF"
                                                        Padding="8,4"
                                                        HorizontalOptions="Start"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        IsVisible="{Binding HasTourBadge}">
                                                    <Label Text="{Binding TourBadgeText}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#2F80FF" />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Label Text="{Binding Description}"
                                               FontSize="15"
                                               TextColor="#486581"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="3" />

                                        <Border BackgroundColor="#F4F8FF"
                                                Padding="12"
                                                HorizontalOptions="Start"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 16"
                                                IsVisible="{Binding HasSpecialDish}">
                                            <Label Text="{Binding SpecialDishLabel}"
                                                   FontSize="13"
                                                   TextColor="#2F80FF"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                        </Border>

                                        <Grid ColumnDefinitions="*,*"
                                              ColumnSpacing="10">
                                            <Button Text="Chi tiết"
                                                    Clicked="OnOpenPoiDetailClicked"
                                                    BackgroundColor="#E8F1FF"
                                                    TextColor="#2F80FF"
                                                    FontSize="15"
                                                    CornerRadius="18" />

                                            <Button Grid.Column="1"
                                                    Text="{Binding NarrationActionText}"
                                                    Clicked="OnPoiNarrationClicked"
                                                    BackgroundColor="#2F80FF"
                                                    TextColor="White"
                                                    FontSize="15"
                                                    CornerRadius="18">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding IsNarrationActive}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor"
                                                                Value="#102A43" />
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Padding="20,8,20,18">
            <Border BackgroundColor="#FFFFFF"
                    Padding="10"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 30">
                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="10">
                    <Border BackgroundColor="#F4F8FF"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHomeTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="home_nav_icon.svg"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   Aspect="AspectFit" />
                            <Label Text="Trang chủ"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#F4F8FF"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGpsOriginTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="gps_origin_icon.svg"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   Aspect="AspectFit" />
                            <Label Text="GPS gốc"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="#F4F8FF"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTourShortcutTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="tour_route_icon.svg"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   Aspect="AspectFit" />
                            <Label Text="Tour"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3"
                            BackgroundColor="#F4F8FF"
                            Padding="8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenAccountPageTapped" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Image Source="account_nav_icon.svg"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   Aspect="AspectFit" />
                            <Label Text="Tài khoản"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#2F80FF" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="FullScreenMapOverlay"
              Grid.RowSpan="2"
              IsVisible="False"
              BackgroundColor="#F4F8FF"
              ZIndex="20">
            <Grid RowDefinitions="Auto,*"
                  Padding="16,48,16,20">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12">
                    <Button Text="←"
                            Clicked="OnCloseFullScreenMapClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            WidthRequest="52"
                            HeightRequest="52"
                            CornerRadius="26" />

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">
                        <Label Text="Bản đồ lộ trình"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="Chạm vào ghim để xem chi tiết quán"
                               FontSize="14"
                               TextColor="#6B7C93" />
                    </VerticalStackLayout>

                    <Button Grid.Column="2"
                            Text="Dừng nghe"
                            Command="{Binding StopNarrationCommand}"
                            IsEnabled="{Binding IsNarrating}"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="15"
                            CornerRadius="20"
                            Padding="14,10" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        BackgroundColor="#FFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32">
                    <mapsui:MapView x:Name="FullScreenRestaurantMap"
                                    IsZoomButtonVisible="False"
                                    IsNorthingButtonVisible="False"
                                    IsMyLocationButtonVisible="False"
                                    RotationLock="True" />
                </Border>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="12"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Margin="0,0,18,18">
                    <Button Text="+"
                            Clicked="OnFullScreenZoomInClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="24"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />

                    <Button Text="-"
                            Clicked="OnFullScreenZoomOutClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="24"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />

                    <Button Text="◎"
                            Clicked="OnFullScreenCenterCurrentLocationClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#2F80FF"
                            FontSize="20"
                            WidthRequest="54"
                            HeightRequest="54"
                            CornerRadius="27" />
                </VerticalStackLayout>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
