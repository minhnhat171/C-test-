                    <mapsui:MapView x:Name="FullScreenRestaurantMap"
                                    IsZoomButtonVisible="False"
                                    IsNorthingButtonVisible="False"
                                    IsMyLocationButtonVisible="False"
                                    RotationLock="True" />
                </Border>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="12"
                                     HorizontalOptions="End"
                                     VerticalOptions="End"
                                     Margin="0,0,18,18">
                    <Button Text="+"
                            Clicked="OnFullScreenZoomInClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#111111"
                            FontSize="26"
                            WidthRequest="56"
                            HeightRequest="56"
                            CornerRadius="28" />

                    <Button Text="-"
                            Clicked="OnFullScreenZoomOutClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#111111"
                            FontSize="26"
                            WidthRequest="56"
                            HeightRequest="56"
                            CornerRadius="28" />

                    <Button Text="."
                            Clicked="OnFullScreenCenterCurrentLocationClicked"
                            BackgroundColor="#FFFFFF"
                            TextColor="#111111"
                            FontSize="30"
                            WidthRequest="56"
                            HeightRequest="56"
                            CornerRadius="28" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

    </Grid>

</ContentPage>
